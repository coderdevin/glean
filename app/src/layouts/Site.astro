---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** Set true on /submit, /admin etc. so they aren't crawled. */
  noindex?: boolean;
  /** og:type — "article" on /a/* picks, "website" everywhere else. */
  ogType?: "website" | "article";
  /** ISO timestamp for article:published_time (only on pick pages). */
  publishedTime?: string;
  /**
   * Page-specific JSON-LD. The site-wide WebSite + Organization graph is
   * always emitted; pages pass their own node (Article, BreadcrumbList, …)
   * here and it's appended. Object or array, serialized as-is.
   */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
import { CSS_VERSION } from "~/lib/assets";
import Lang from "~/components/Lang.astro";
import {
  htmlLang as toHtmlLang,
  ogLocale as toOgLocale,
  hreflangCode,
  localizedPath,
} from "~/lib/i18n";
const {
  title,
  description,
  ogImage,
  noindex = false,
  ogType = "website",
  publishedTime,
  jsonLd,
} = Astro.props;
const lang = Astro.locals.lang ?? "zh";
const htmlLang = toHtmlLang(lang);
const ogLocale = toOgLocale(lang);
const siteOrigin = new URL(Astro.site ?? "https://glean.smartcoder.ai").origin;
// `basePath` is the language-agnostic path the middleware computed (no /en).
// All URL math (canonical, hreflang, nav links, lang toggle) derives from it,
// so an English page never accidentally points at the Chinese tree.
const basePath = Astro.locals.basePath ?? Astro.url.pathname;
const path = basePath;
const canonical = siteOrigin + localizedPath(basePath, lang);
// Localize a nav/footer href into the current language tree.
const L = (p: string): string => localizedPath(p, lang);
// hreflang alternates — both languages plus x-default (→ Chinese, the primary
// edition). Emitted on every page; reciprocal so Google clusters the pair.
const alternates = [
  { hreflang: hreflangCode("zh"), href: siteOrigin + localizedPath(basePath, "zh") },
  { hreflang: hreflangCode("en"), href: siteOrigin + localizedPath(basePath, "en") },
  { hreflang: "x-default", href: siteOrigin + localizedPath(basePath, "zh") },
];

// Site-wide knowledge graph — emitted on every page so search + answer
// engines can resolve the publisher entity. Page-specific nodes (Article,
// BreadcrumbList) are passed via the `jsonLd` prop and appended below.
const siteGraph: Record<string, unknown>[] = [
  {
    "@type": "WebSite",
    "@id": `${siteOrigin}/#website`,
    url: `${siteOrigin}/`,
    name: "Glean · 拾遗",
    description:
      "双语技术日刊与周刊 · A bilingual tech daily & weekly. Hand-curated, human-reviewed.",
    inLanguage: ["zh-CN", "en"],
    publisher: { "@id": `${siteOrigin}/#org` },
  },
  {
    "@type": "Organization",
    "@id": `${siteOrigin}/#org`,
    name: "Glean · 拾遗",
    url: `${siteOrigin}/`,
  },
];
const graph = {
  "@context": "https://schema.org",
  "@graph": [...siteGraph, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])],
};
// Optional public-contact email surfaced in the footer. Leave unset (no var)
// to hide the Contact link entirely — sensible default for forks.
const contactEmail = Astro.locals.runtime?.env?.CONTACT_EMAIL ?? "";
const isActive = (prefix: string): boolean => {
  if (prefix === "/") return path === "/";
  return path === prefix || path.startsWith(prefix + "/");
};
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Mobile address-bar tint tracks --c-canvas (warm-50 light / ink-900 dark). */}
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#faf9f6" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#1c1b1a" />
    {/* PWA: installable to the home screen ("添加到主屏幕"), launches standalone.
        Icons live in /public; no service worker (no offline) so the site's
        Cache-Control + bustForPick stay authoritative. */}
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="拾遗" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    {!noindex && alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}
    {noindex && <meta name="robots" content="noindex" />}

    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Glean · 拾遗" />
    <meta property="og:locale" content={ogLocale} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}

    {/* `<` escaped to < so a title containing </script> can't break out. */}
    <script type="application/ld+json" set:html={JSON.stringify(graph).replace(/</g, "\\u003c")} />


    <link rel="alternate" type="application/rss+xml" title="Glean · Daily" href="/rss/daily.xml" />
    <link rel="alternate" type="application/rss+xml" title="Glean · Weekly" href="/rss/weekly.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Only the regular weight is referenced by --f-display. The upstream
         style.css also pulls light + bold + mono variants we never use,
         which adds megabytes of woff2 subsets. font-display: swap is set
         in the @font-face rules, so the system CJK serif renders first. -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/lxgwwenkai-regular.css" />
    <link rel="stylesheet" href={`/styles.css?v=${CSS_VERSION}`} />
  </head>
  <body data-lang={lang}>
    <a href="#main" class="skip-link">跳到主要内容 · Skip to content</a>

    <header class="top-nav">
      <div class="top-nav__inner">
        <a href={L("/")} class="brand">
          <span class="brand__mark" aria-hidden="true">拾</span>
          <span class="brand__wordmark">
            <span class="brand__name">Glean</span>
            <span class="brand__subname">拾遗</span>
          </span>
        </a>
        <nav class="nav-links" id="primary-nav" aria-label="主导航">
          <a class="nav-link" href={L("/")} aria-current={isActive("/") ? "page" : undefined}>
            <Lang zh="首页" en="Home" />
          </a>
          <a class="nav-link" href={L("/weekly")} aria-current={isActive("/weekly") ? "page" : undefined}>
            <Lang zh="周刊" en="Weekly" />
          </a>
          <a class="nav-link" href={L("/daily")} aria-current={isActive("/daily") ? "page" : undefined}>
            <Lang zh="日刊" en="Daily" />
          </a>
          <a class="nav-link" href={L("/tag")} aria-current={isActive("/tag") || isActive("/a") ? "page" : undefined}>
            <Lang zh="标签" en="Tags" />
          </a>
          <a class="nav-link" href={L("/about")} aria-current={isActive("/about") || isActive("/standards") ? "page" : undefined}>
            <Lang zh="关于" en="About" />
          </a>
          <a class="nav-link" href={L("/me/notes")} aria-current={isActive("/me") ? "page" : undefined}>
            <Lang zh="我的笔记" en="My notes" />
          </a>
          <a class="nav-link nav-link--cta nav-link--drawer-only" href={L("/submit")}>
            <Lang zh="提交链接" en="Submit a link" />
          </a>
        </nav>
        <button class="nav-toggle" type="button" aria-label="打开菜单 · Open menu" aria-expanded="false" aria-controls="primary-nav">
          <span></span><span></span><span></span>
        </button>
        <div class="nav-spacer"></div>
        <div class="nav-right">
          {/* Language toggle is now real navigation between the two URL trees
              (was a CSS-only DOM toggle), so each language is a crawlable,
              shareable URL. rel=alternate + hreflang signals the pairing. */}
          <div class="lang-toggle" aria-label="Language">
            <a href={localizedPath(basePath, "zh")} class={lang === "zh" ? "is-active" : ""}
               hreflang="zh-CN" aria-current={lang === "zh" ? "true" : undefined}>中</a>
            <a href={localizedPath(basePath, "en")} class={lang === "en" ? "is-active" : ""}
               hreflang="en" aria-current={lang === "en" ? "true" : undefined}>EN</a>
          </div>
          <a href={L("/submit")} class="nav-link nav-link--cta">
            <Lang zh="提交链接" en="Submit a link" />
          </a>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer__grid">
          <div>
            <div class="footer__brand">
              <span class="brand__mark" aria-hidden="true">拾</span>
              <span class="brand__wordmark"><span class="brand__name">Glean</span><span class="brand__subname">拾遗</span></span>
            </div>
            <p class="t-body-sm footer__blurb">
              <Lang
                zh="双语技术日刊与周刊。从信息洪流里把值得读的拣回来；每条人审。"
                en="A bilingual tech daily & weekly. I pick up the links worth reading. Every link human-reviewed."
              />
            </p>
          </div>
          <div class="footer__col">
            <h2><Lang zh="阅读" en="Read" /></h2>
            <ul>
              <li><a href={L("/weekly")}><Lang zh="所有周刊" en="All weeklies" /></a></li>
              <li><a href={L("/daily")}><Lang zh="今日日刊" en="Today" /></a></li>
              <li><a href={L("/tag")}><Lang zh="所有标签" en="All tags" /></a></li>
              <li><a href={`/rss/daily.xml${lang === "en" ? "?lang=en" : ""}`}><Lang zh="RSS · 日刊" en="RSS · daily" /></a></li>
              <li><a href={`/rss/weekly.xml${lang === "en" ? "?lang=en" : ""}`}><Lang zh="RSS · 周刊" en="RSS · weekly" /></a></li>
            </ul>
          </div>
          <div class="footer__col">
            <h2><Lang zh="参与" en="Contribute" /></h2>
            <ul>
              <li><a href={L("/submit")}><Lang zh="提交链接" en="Submit a link" /></a></li>
              <li><a href={L("/standards")}><Lang zh="编辑标准" en="Editorial standards" /></a></li>
              <li><a href="/design-system"><Lang zh="设计系统" en="Design system" /></a></li>
            </ul>
          </div>
          <div class="footer__col">
            <h2><Lang zh="关于" en="About" /></h2>
            <ul>
              <li><a href={L("/about")}><Lang zh="关于" en="About" /></a></li>
              {contactEmail && <li><a href={`mailto:${contactEmail}`}><Lang zh="联系我们" en="Contact" /></a></li>}
            </ul>
          </div>
        </div>
        <div class="footer__bottom">
          <span><Lang zh="© 2026 Glean · 拾遗 · 双语技术内容" en="© 2026 Glean · Bilingual tech curation" /></span>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Mobile nav toggle.
      (function () {
        const toggle = document.querySelector(".nav-toggle");
        const links = document.getElementById("primary-nav");
        if (!toggle || !links) return;
        const close = () => {
          links.classList.remove("is-open");
          toggle.setAttribute("aria-expanded", "false");
          document.body.style.overflow = "";
        };
        toggle.addEventListener("click", () => {
          const open = links.classList.toggle("is-open");
          toggle.setAttribute("aria-expanded", String(open));
          document.body.style.overflow = open ? "hidden" : "";
        });
        links.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
        document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
      })();

      // The language toggle is now plain navigation between the /  and  /en
      // URL trees (see the <a class="lang-toggle"> links above), so the old
      // CSS/cookie DOM-swap handler is gone — the server renders one language
      // per URL.

      // Subscribe / notify-me form — progressive: posts to /api/subscribe,
      // falls back to the .is-subscribed class on success so the bilingual
      // confirmation copy renders the same as the static prototype.
      (function () {
        document.querySelectorAll("[data-subscribe-form]").forEach((form) => {
          form.addEventListener("submit", async (e) => {
            e.preventDefault();
            const status = form.querySelector(".subscribe-card__status");
            const btn = form.querySelector("button[type=submit]");
            if (btn) btn.disabled = true;
            try {
              const fd = new FormData(form);
              const res = await fetch("/api/subscribe", { method: "POST", body: fd });
              if (!res.ok) throw new Error(await res.text());
              let needsConfirm = false;
              try { needsConfirm = (await res.json()).needsConfirm === true; } catch {}
              form.classList.add("is-subscribed");
              if (status) {
                const lang = document.body.getAttribute("data-lang") || "zh";
                status.textContent = needsConfirm
                  ? (lang === "zh"
                      ? "确认邮件已发出，去邮箱点一下链接就好。"
                      : "Check your inbox — click the link to confirm.")
                  : (lang === "zh"
                      ? "登记好了，到时第一时间通知你。"
                      : "You’re on the list — we’ll be in touch.");
              }
            } catch (err) {
              if (status) status.textContent = String(err.message ?? err);
              if (btn) btn.disabled = false;
            }
          });
        });
      })();
    </script>
  </body>
</html>
