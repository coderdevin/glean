---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** Set true on /submit, /admin etc. so they aren't crawled. */
  noindex?: boolean;
}
import { CSS_VERSION } from "~/lib/assets";
const { title, description, ogImage, noindex = false } = Astro.props;
const lang = Astro.locals.lang ?? "zh";
const htmlLang = lang === "zh" ? "zh-CN" : "en";
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const path = Astro.url.pathname;
// Optional public-contact email surfaced in the footer. Leave unset (no var)
// to hide the Contact link entirely — sensible default for forks.
const contactEmail = Astro.locals.runtime?.env?.CONTACT_EMAIL ?? "";
const isActive = (prefix: string): boolean => {
  if (prefix === "/") return path === "/";
  return path === prefix || path.startsWith(prefix + "/");
};
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Mobile address-bar tint tracks --c-canvas (warm-50 light / ink-900 dark). */}
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#faf9f6" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#1c1b1a" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}

    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <link rel="alternate" type="application/rss+xml" title="Glean · Daily" href="/rss/daily.xml" />
    <link rel="alternate" type="application/rss+xml" title="Glean · Weekly" href="/rss/weekly.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Only the regular weight is referenced by --f-display. The upstream
         style.css also pulls light + bold + mono variants we never use,
         which adds megabytes of woff2 subsets. font-display: swap is set
         in the @font-face rules, so the system CJK serif renders first. -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/lxgwwenkai-regular.css" />
    <link rel="stylesheet" href={`/styles.css?v=${CSS_VERSION}`} />
  </head>
  <body data-lang={lang}>
    <a href="#main" class="skip-link">跳到主要内容 · Skip to content</a>

    <header class="top-nav">
      <div class="top-nav__inner">
        <a href="/" class="brand">
          <svg class="brand__mark" viewBox="0 0 30 24" fill="currentColor" aria-hidden="true">
            <circle cx="10" cy="5" r="2.4" />
            <path d="M2 12 Q10 22 18 12 Z" />
            <circle class="brand__mark-pick" cx="25" cy="15" r="1.6" />
          </svg>
          <span class="brand__wordmark">
            <span class="brand__name">Glean</span>
            <span class="brand__subname">拾遗</span>
          </span>
        </a>
        <nav class="nav-links" id="primary-nav" aria-label="主导航">
          <a class="nav-link" href="/" aria-current={isActive("/") ? "page" : undefined}>
            <span class="lang-zh">首页</span><span class="lang-en">Home</span>
          </a>
          <a class="nav-link" href="/weekly" aria-current={isActive("/weekly") ? "page" : undefined}>
            <span class="lang-zh">周刊</span><span class="lang-en">Weekly</span>
          </a>
          <a class="nav-link" href="/daily" aria-current={isActive("/daily") ? "page" : undefined}>
            <span class="lang-zh">日刊</span><span class="lang-en">Daily</span>
          </a>
          <a class="nav-link" href="/tag" aria-current={isActive("/tag") || isActive("/a") ? "page" : undefined}>
            <span class="lang-zh">标签</span><span class="lang-en">Tags</span>
          </a>
          <a class="nav-link" href="/about" aria-current={isActive("/about") || isActive("/standards") ? "page" : undefined}>
            <span class="lang-zh">关于</span><span class="lang-en">About</span>
          </a>
          <a class="nav-link nav-link--cta nav-link--drawer-only" href="/submit">
            <span class="lang-zh">提交链接</span><span class="lang-en">Submit a link</span>
          </a>
        </nav>
        <button class="nav-toggle" type="button" aria-label="打开菜单 · Open menu" aria-expanded="false" aria-controls="primary-nav">
          <span></span><span></span><span></span>
        </button>
        <div class="nav-spacer"></div>
        <div class="nav-right">
          <div class="lang-toggle" role="tablist" aria-label="Language">
            <button type="button" data-lang-set="zh" class={lang === "zh" ? "is-active" : ""} role="tab" aria-selected={lang === "zh"}>中</button>
            <button type="button" data-lang-set="en" class={lang === "en" ? "is-active" : ""} role="tab" aria-selected={lang === "en"}>EN</button>
          </div>
          <a href="/submit" class="nav-link nav-link--cta">
            <span class="lang-zh">提交链接</span><span class="lang-en">Submit a link</span>
          </a>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer__grid">
          <div>
            <div class="footer__brand">
              <svg class="brand__mark" viewBox="0 0 30 24" fill="currentColor" aria-hidden="true">
                <circle cx="10" cy="5" r="2.4" />
                <path d="M2 12 Q10 22 18 12 Z" />
                <circle class="brand__mark-pick" cx="25" cy="15" r="1.6" />
              </svg>
              <span class="brand__wordmark"><span class="brand__name">Glean</span><span class="brand__subname">拾遗</span></span>
            </div>
            <p class="t-body-sm footer__blurb">
              <span class="lang-zh">双语技术日刊与周刊。从信息洪流里把值得读的拣回来；每条人审。</span>
              <span class="lang-en">A bilingual tech daily &amp; weekly. I pick up the links worth reading. Every link human-reviewed.</span>
            </p>
          </div>
          <div class="footer__col">
            <h2><span class="lang-zh">阅读</span><span class="lang-en">Read</span></h2>
            <ul>
              <li><a href="/weekly"><span class="lang-zh">所有周刊</span><span class="lang-en">All weeklies</span></a></li>
              <li><a href="/daily"><span class="lang-zh">今日日刊</span><span class="lang-en">Today</span></a></li>
              <li><a href="/tag"><span class="lang-zh">所有标签</span><span class="lang-en">All tags</span></a></li>
              <li><a href="/rss/daily.xml"><span class="lang-zh">RSS · 日刊</span><span class="lang-en">RSS · daily</span></a></li>
              <li><a href="/rss/weekly.xml"><span class="lang-zh">RSS · 周刊</span><span class="lang-en">RSS · weekly</span></a></li>
            </ul>
          </div>
          <div class="footer__col">
            <h2><span class="lang-zh">参与</span><span class="lang-en">Contribute</span></h2>
            <ul>
              <li><a href="/submit"><span class="lang-zh">提交链接</span><span class="lang-en">Submit a link</span></a></li>
              <li><a href="/standards"><span class="lang-zh">编辑标准</span><span class="lang-en">Editorial standards</span></a></li>
              <li><a href="/design-system"><span class="lang-zh">设计系统</span><span class="lang-en">Design system</span></a></li>
            </ul>
          </div>
          <div class="footer__col">
            <h2><span class="lang-zh">关于</span><span class="lang-en">About</span></h2>
            <ul>
              <li><a href="/about"><span class="lang-zh">关于</span><span class="lang-en">About</span></a></li>
              {contactEmail && <li><a href={`mailto:${contactEmail}`}><span class="lang-zh">联系我们</span><span class="lang-en">Contact</span></a></li>}
            </ul>
          </div>
        </div>
        <div class="footer__bottom">
          <span><span class="lang-zh">© 2026 Glean · 拾遗 · 双语技术内容</span><span class="lang-en">© 2026 Glean · Bilingual tech curation</span></span>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Mobile nav toggle.
      (function () {
        const toggle = document.querySelector(".nav-toggle");
        const links = document.getElementById("primary-nav");
        if (!toggle || !links) return;
        const close = () => {
          links.classList.remove("is-open");
          toggle.setAttribute("aria-expanded", "false");
          document.body.style.overflow = "";
        };
        toggle.addEventListener("click", () => {
          const open = links.classList.toggle("is-open");
          toggle.setAttribute("aria-expanded", String(open));
          document.body.style.overflow = open ? "hidden" : "";
        });
        links.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
        document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
      })();

      // Bilingual toggle — persists via cookie so SSR picks it up next nav.
      document.addEventListener("click", (e) => {
        const t = e.target.closest("[data-lang-set]");
        if (!t) return;
        const lang = t.getAttribute("data-lang-set");
        document.body.setAttribute("data-lang", lang);
        document.documentElement.lang = lang === "zh" ? "zh-CN" : "en";
        document.cookie = "glean_lang=" + lang + "; path=/; max-age=" + (60 * 60 * 24 * 365) + "; samesite=lax";
        document.querySelectorAll("[data-lang-set]").forEach((b) => {
          const active = b.getAttribute("data-lang-set") === lang;
          b.classList.toggle("is-active", active);
          b.setAttribute("aria-selected", active ? "true" : "false");
        });
      });

      // Subscribe / notify-me form — progressive: posts to /api/subscribe,
      // falls back to the .is-subscribed class on success so the bilingual
      // confirmation copy renders the same as the static prototype.
      (function () {
        document.querySelectorAll("[data-subscribe-form]").forEach((form) => {
          form.addEventListener("submit", async (e) => {
            e.preventDefault();
            const status = form.querySelector(".subscribe-card__status");
            const btn = form.querySelector("button[type=submit]");
            if (btn) btn.disabled = true;
            try {
              const fd = new FormData(form);
              const res = await fetch("/api/subscribe", { method: "POST", body: fd });
              if (!res.ok) throw new Error(await res.text());
              let needsConfirm = false;
              try { needsConfirm = (await res.json()).needsConfirm === true; } catch {}
              form.classList.add("is-subscribed");
              if (status) {
                const lang = document.body.getAttribute("data-lang") || "zh";
                status.textContent = needsConfirm
                  ? (lang === "zh"
                      ? "确认邮件已发出，去邮箱点一下链接就好。"
                      : "Check your inbox — click the link to confirm.")
                  : (lang === "zh"
                      ? "登记好了，到时第一时间通知你。"
                      : "You’re on the list — we’ll be in touch.");
              }
            } catch (err) {
              if (status) status.textContent = String(err.message ?? err);
              if (btn) btn.disabled = false;
            }
          });
        });
      })();
    </script>
  </body>
</html>
