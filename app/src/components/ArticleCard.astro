---
import TagBadge from "./TagBadge.astro";
import Lang from "./Lang.astro";
import { localizedPath } from "~/lib/i18n";

export interface ArticleCardPick {
  id: string;
  slug: string;
  title_zh: string;
  title_en: string;
  summary_zh: string;
  summary_en: string;
  bullets: { zh: string; en: string }[];
  editor_note_zh: string | null;
  editor_note_en: string | null;
  source_url: string;
  source_host: string;
  read_minutes: number;
  category: string;
  submitter_name: string | null;
  published_at: Date | null;
  tags: { slug: string; name_zh: string; name_en: string; family: string }[];
}

interface Props {
  pick: ArticleCardPick;
  /** Render as the lead/featured slot of a daily strip — includes head badge. */
  featured?: boolean;
  /** Render in dark-surface variant (used inside admin / weekly cover). */
  dark?: boolean;
}
const { pick, featured = false, dark = false } = Astro.props;
const lang = Astro.locals.lang ?? "zh";
const L = (p: string): string => localizedPath(p, lang);
const classes = ["article-card"];
if (dark) classes.push("article-card--featured");
const showBullets = featured && pick.bullets.length > 0;
const showEditor = featured && (pick.editor_note_zh || pick.editor_note_en);
---
<article class={classes.join(" ")}>
  <div class="article-card__head">
    {featured && <span class="badge badge--coral"><Lang zh="头条" en="Lead" /></span>}
    <span>{pick.source_host} · {pick.read_minutes} min read</span>
  </div>
  <h3 class="article-card__title">
    <a href={L(`/a/${pick.slug}`)}>
      <Lang zh={pick.title_zh} en={pick.title_en} />
    </a>
  </h3>
  <p class="article-card__summary">
    <Lang zh={pick.summary_zh} en={pick.summary_en} />
  </p>
  {showBullets && (
    <ul class="article-card__bullets">
      {pick.bullets.map((b) => (
        <li><Lang zh={b.zh} en={b.en} /></li>
      ))}
    </ul>
  )}
  {showEditor && (
    <div class="article-card__editorial">
      <span class="article-card__editorial-label"><Lang zh="编辑短评" en="Editor’s note" /></span>
      <Lang zh={pick.editor_note_zh ?? undefined} en={pick.editor_note_en ?? undefined} />
    </div>
  )}
  <div class="article-card__footer">
    <div class="article-card__meta">
      {pick.tags.map((t) => (
        <TagBadge slug={t.slug} nameZh={t.name_zh} nameEn={t.name_en} family={t.family} href={L(`/tag/${t.slug}`)} />
      ))}
    </div>
  </div>
</article>
