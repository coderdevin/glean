---
export interface WeeklyCoverIssue {
  number: number;
  slug: string;
  title_zh: string;
  title_en: string;
  date_start: string;
  date_end: string;
  intro_zh: string;
  intro_en: string;
  pick_count: number;
  cover_image_url: string | null;
}

interface Props { issue: WeeklyCoverIssue; }
const { issue } = Astro.props;
import { issueNo, weeklyDateRange } from "~/lib/weeklyFormat";
import Lang from "./Lang.astro";
import { localizedPath } from "~/lib/i18n";
const lang = Astro.locals.lang ?? "zh";
const L = (p: string): string => localizedPath(p, lang);
---
<article class="weekly-cover">
  <a class="weekly-cover__link" href={L(`/weekly/${issue.number}`)}>
    <div class="weekly-cover__meta">
      <span class="t-caption-up">{issueNo(issue.number)}</span>
      <span class="text-muted-soft">{weeklyDateRange(issue.date_start, issue.date_end)}</span>
    </div>
    <h2 class="weekly-cover__title">
      <Lang zh={issue.title_zh} en={issue.title_en} />
    </h2>
    <p class="weekly-cover__intro">
      <Lang zh={issue.intro_zh} en={issue.intro_en} />
    </p>
    <div class="weekly-cover__footer">
      <span class="t-body-sm text-muted">
        <Lang zh={`${issue.pick_count} 篇`} en={`${issue.pick_count} picks`} />
      </span>
      <span class="t-body-sm text-link">
        <Lang zh="读这期 →" en="Read issue →" />
      </span>
    </div>
  </a>
</article>
