---
export interface WeeklyCoverIssue {
  number: number;
  slug: string;
  title_zh: string;
  title_en: string;
  date_start: string;
  date_end: string;
  intro_zh: string;
  intro_en: string;
  pick_count: number;
  cover_image_url: string | null;
}

interface Props { issue: WeeklyCoverIssue; }
const { issue } = Astro.props;
import { issueNo, weeklyDateRange } from "~/lib/weeklyFormat";
---
<article class="weekly-cover">
  <a class="weekly-cover__link" href={`/weekly/${issue.number}`}>
    <div class="weekly-cover__meta">
      <span class="t-caption-up">{issueNo(issue.number)}</span>
      <span class="text-muted-soft">{weeklyDateRange(issue.date_start, issue.date_end)}</span>
    </div>
    <h2 class="weekly-cover__title">
      <span class="lang-zh">{issue.title_zh}</span>
      <span class="lang-en">{issue.title_en}</span>
    </h2>
    <p class="weekly-cover__intro">
      <span class="lang-zh">{issue.intro_zh}</span>
      <span class="lang-en">{issue.intro_en}</span>
    </p>
    <div class="weekly-cover__footer">
      <span class="t-body-sm text-muted">
        <span class="lang-zh">{issue.pick_count} 篇</span>
        <span class="lang-en">{issue.pick_count} picks</span>
      </span>
      <span class="t-body-sm text-link">
        <span class="lang-zh">读这期 →</span>
        <span class="lang-en">Read issue →</span>
      </span>
    </div>
  </a>
</article>
