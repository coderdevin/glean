---
export const prerender = false;
import Admin from "~/layouts/Admin.astro";
import StatusPill from "~/components/StatusPill.astro";
import { db } from "~/db/client";
import { submissions, submissionEvents } from "~/db/schema";
import { getAdminProcessingStatus } from "~/lib/adminProcessingStatus";
import { formatTimeHM, formatTimeHMS, siteTz } from "~/lib/datetime";
import { isInFlight } from "~/lib/submissionStatus";
import { asc, eq } from "drizzle-orm";

const id = Astro.params.id;
if (!id) return new Response("Not found", { status: 404 });

const env = Astro.locals.runtime.env;
const drizzle = db(env.DB);
const rows = await drizzle.select().from(submissions).where(eq(submissions.id, id)).limit(1);
const row = rows[0];
if (!row) return new Response("Not found", { status: 404 });

// Position inside the "ready" queue, so J/K (prev/next) can wire up.
// Only computed when the current row is itself ready — for other statuses
// the strip just shows the status without a queue counter.
let queueContext: { total: number; index: number; prevId: string | null; nextId: string | null } | null = null;
if (row.status === "ready") {
  const ready = await drizzle
    .select({ id: submissions.id })
    .from(submissions)
    .where(eq(submissions.status, "ready"))
    .orderBy(asc(submissions.createdAt));
  const idx = ready.findIndex((r) => r.id === row.id);
  if (idx >= 0) {
    queueContext = {
      total: ready.length,
      index: idx,
      prevId: ready[idx - 1]?.id ?? null,
      nextId: ready[idx + 1]?.id ?? null,
    };
  }
}

let rawText: string | null = null;
let rawTotalChars: number | null = null;
const RAW_PREVIEW_CHARS = 8000;
if (row.rawR2Key) {
  try {
    const obj = await env.RAW.get(row.rawR2Key);
    if (obj) {
      const full = await obj.text();
      rawTotalChars = full.length;
      rawText = full.slice(0, RAW_PREVIEW_CHARS);
    }
  } catch (err) {
    console.warn("r2 read failed", err);
  }
}

const aiBullets: { zh: string; en: string }[] = (() => {
  try { return JSON.parse(row.aiBulletsJson ?? "[]"); } catch { return []; }
})();
const aiTags: string[] = (() => {
  try { return JSON.parse(row.aiTagsJson ?? "[]"); } catch { return []; }
})();
const aiSubscores: Record<string, number> | null = (() => {
  try { return row.aiSubscoresJson ? JSON.parse(row.aiSubscoresJson) : null; } catch { return null; }
})();
const aiGlossary: { en: string; zh: string; meaning: string; anchor?: string }[] = (() => {
  try { return JSON.parse(row.aiGlossaryJson ?? "[]"); } catch { return []; }
})();
const aiNextHints: string[] = (() => {
  try { return JSON.parse(row.aiNextHintsJson ?? "[]"); } catch { return []; }
})();
const bulletsZhText = aiBullets.map((b) => b.zh).join("\n");
const bulletsEnText = aiBullets.map((b) => b.en).join("\n");
const tz = siteTz(env);
const submitTime = formatTimeHM(row.createdAt, tz);

const events = await drizzle
  .select()
  .from(submissionEvents)
  .where(eq(submissionEvents.submissionId, row.id))
  .orderBy(asc(submissionEvents.createdAt));

type EventRow = typeof events[number];
type RenderedEvent = {
  ts: string;
  tsISO: string;
  stage: EventRow["stage"];
  status: EventRow["status"];
  message: string | null;
  meta: Record<string, unknown> | null;
  elapsedSincePrev: string | null;
  state: "ok" | "active" | "warn" | "fail";
  glyph: string;
};
const stateForEvent = (e: EventRow): RenderedEvent["state"] => {
  if (e.status === "failed" || e.status === "rejected") return "fail";
  if (e.status === "skipped") return "warn";
  if (e.status === "started") return "active";
  return "ok";
};
const glyphFor = (state: RenderedEvent["state"], status: EventRow["status"]): string => {
  if (state === "fail") return "✗";
  if (state === "warn") return "⊘";
  if (state === "active") return "◌";
  if (status === "queued") return "↪";
  return "✓";
};
const fmtElapsed = (ms: number): string => {
  if (ms < 1000) return `+${ms}ms`;
  const s = ms / 1000;
  if (s < 60) return `+${s.toFixed(s < 10 ? 1 : 0)}s`;
  const m = Math.floor(s / 60);
  const rem = Math.round(s - m * 60);
  return `+${m}m${rem ? ` ${rem}s` : ""}`;
};
const renderedEvents: RenderedEvent[] = events.map((e, idx) => {
  const ts = e.createdAt ? new Date(e.createdAt) : new Date();
  const prevEvent = idx > 0 ? events[idx - 1] : undefined;
  const prevCreatedAt = prevEvent?.createdAt ?? null;
  const elapsed = prevCreatedAt ? ts.getTime() - new Date(prevCreatedAt).getTime() : null;
  let meta: Record<string, unknown> | null = null;
  if (e.metaJson) {
    try { meta = JSON.parse(e.metaJson) as Record<string, unknown>; } catch { meta = null; }
  }
  const state = stateForEvent(e);
  return {
    ts: formatTimeHMS(ts, tz),
    tsISO: ts.toISOString(),
    stage: e.stage,
    status: e.status,
    message: e.message,
    meta,
    elapsedSincePrev: elapsed != null ? fmtElapsed(elapsed) : null,
    state,
    glyph: glyphFor(state, e.status),
  };
});

Astro.response.headers.set("Cache-Control", "no-store");

const isProcessing = isInFlight(row.status);
const processingStatus = isProcessing
  ? getAdminProcessingStatus({
      status: row.status,
      rawR2Key: row.rawR2Key,
      processingStartedAt: row.processingStartedAt,
      processingModel: row.processingModel,
      createdAt: row.createdAt,
      rawTotalChars,
    })
  : null;

const sourceHost = (() => { try { return new URL(row.url).host; } catch { return row.url; } })();
const shortId = `${row.id.slice(0, 7)}…${row.id.slice(-4)}`;
// Same heuristic as publish.ts uses for the published pick: ~1000 chars/min
// across a mix of ZH and EN. Floor at 1, only shown when we have raw text.
const readMinutes = rawTotalChars ? Math.max(1, Math.round(rawTotalChars / 1000)) : null;

// Pipeline header derivation. The terminal-log panel is always rendered;
// status + model + elapsed are sourced from row + adminProcessingStatus +
// the latest event so the editor can see "what stage are we at" without
// reading the log itself.
const modelShort = (model: string | null | undefined): string | null => {
  if (!model) return null;
  const cleaned = model.replace(/^deepseek[-/]/i, "").toLowerCase();
  if (cleaned.includes("flash")) return "V4-Flash";
  if (cleaned.includes("v4-pro")) return "V4-Pro";
  return model;
};
const activeEventIdx = (() => {
  if (!isProcessing) return -1;
  for (let i = renderedEvents.length - 1; i >= 0; i--) {
    if (renderedEvents[i]!.status === "started") return i;
  }
  return -1;
})();
const pipelineModel = processingStatus?.modelLabel
  ?? modelShort(row.processingModel)
  ?? modelShort(row.aiModel?.split("/")[1])
  ?? null;
const pipelineState: "running" | "complete" | "failed" | "rejected" | "queued" | "idle" = (() => {
  if (row.status === "failed") return "failed";
  if (row.status === "rejected") return "rejected";
  if (row.status === "ready" || row.status === "published") return "complete";
  if (row.status === "analyzing" || row.status === "composing") return "running";
  if (row.status === "pending") return "queued";
  return "idle";
})();
const pipelineHeadline: string = (() => {
  switch (pipelineState) {
    case "running": return "RUNNING";
    case "complete": return "COMPLETE";
    case "failed": return "AI FAILED";
    case "rejected": return "REJECTED BY EDITOR";
    case "queued": return "QUEUED";
    default: return "IDLE";
  }
})();
const pipelineFailureReason: string | null = (() => {
  if (pipelineState === "failed") return (row.aiSectionsError ?? "").trim() || null;
  if (pipelineState === "rejected") return (row.rejectReason ?? "").trim() || null;
  return null;
})();
const pipelineStartedAt = row.processingStartedAt ?? row.createdAt ?? new Date();
const pipelineElapsedMs = Math.max(0, Date.now() - pipelineStartedAt.getTime());
const fmtClock = (ms: number): string => {
  const totalSec = Math.floor(ms / 1000);
  const m = Math.floor(totalSec / 60);
  const s = totalSec % 60;
  if (m === 0) return `${s}s`;
  return `${m}m ${s.toString().padStart(2, "0")}s`;
};
const pipelineElapsedLabel = fmtClock(pipelineElapsedMs);
const pipelineProgressPct = processingStatus?.progressPct ?? (pipelineState === "complete" ? 100 : 0);
const pipelineWindowLabel = processingStatus?.windowLabel ?? null;
const pipelineIsStalled = processingStatus?.isPastWindow ?? false;

// Body sections are guaranteed present once status is 'ready'/'published'.
// While composing, the body drawer shows the "生成中" placeholder.
const sectionsComposing = row.status === "composing";
const failureErrorShort = row.aiSectionsError ? row.aiSectionsError.replace(/\s+/g, " ").slice(0, 200) : null;

type SectionPair = {
  heading_zh?: string;
  heading_en?: string;
  body_zh: string;
  body_en: string;
  anchor_id?: string;
};
const aiSections: SectionPair[] = (() => {
  if (!row.aiSectionsJson) return [];
  try {
    const v = JSON.parse(row.aiSectionsJson);
    return Array.isArray(v) ? (v as SectionPair[]) : [];
  } catch { return []; }
})();
// Total chars across sections — gives editor a sense of body coverage.
const sectionsTotalChars = aiSections.reduce(
  (n, s) => n + (s.body_zh?.length ?? 0) + (s.body_en?.length ?? 0),
  0,
);
---
<Admin title={`审核 · ${row.id.slice(0, 8)}…`}>

  <form id="ar-form" action={`/api/admin/${row.id}/save`} method="post" autocomplete="off">
    <header class="r2-strip">
      <a href="/admin" class="r2-strip__back">← Queue</a>
      {queueContext && (
        <span class="r2-strip__pos">
          Ready <strong>{queueContext.index + 1}</strong> / {queueContext.total}
        </span>
      )}
      <StatusPill status={row.status} />
      <span class="r2-strip__id" title={row.id}>{shortId}</span>
      <span class="r2-strip__meta">
        <a href={row.url} class="t-code" rel="noopener" style="color: inherit">{sourceHost}</a>
        {row.extractedLang && <> · {row.extractedLang}</>}
        {row.aiModel && <> · {row.aiModel}</>}
        {row.aiLatencyMs ? <> · {(row.aiLatencyMs / 1000).toFixed(1)}s</> : null}
        {row.aiTokens ? <> · {row.aiTokens.toLocaleString()} tok</> : null}
      </span>
      <div class="r2-strip__tools">
        <button type="button" class="r2-strip__tool" data-drawer-open="src-drawer">
          Source <kbd>V</kbd>
        </button>
        <button
          type="button"
          class={`r2-strip__tool${row.status === "failed" ? " is-warn" : ""}`}
          data-drawer-open="body-drawer"
          title={sectionsComposing
            ? "Sections 生成中"
            : row.status === "failed"
              ? `Sections 失败: ${failureErrorShort ?? "未知错误"}`
              : "正文双语段落"}
        >
          Body <kbd>B</kbd>
          {aiSections.length > 0 && <span class="r2-strip__tool-count">{aiSections.length}</span>}
          {sectionsComposing && <span class="r2-strip__tool-dot" aria-label="pending"></span>}
          {row.status === "failed" && <span class="r2-strip__tool-bang" aria-hidden="true">!</span>}
        </button>
        <button type="button" class="r2-strip__tool" data-drawer-open="ai-drawer">
          AI <kbd>I</kbd>
        </button>
        <div class="opmenu" id="opmenu">
          <button type="button" class="r2-strip__tool" data-opmenu-toggle>⋯</button>
          <div class="opmenu__list" role="menu">
            <button type="button" class="opmenu__item" data-action="refetch">
              Refetch source
            </button>
            <button type="button" class="opmenu__item" data-action="rerun-pro">
              Re-run V4-Pro <span class="text-muted-soft">· 2–12min</span>
            </button>
            <button type="button" class="opmenu__item" data-action="rerun-flash">
              Re-run V4-Flash <span class="text-muted-soft">· 1–4min</span>
            </button>
            <a href={row.url} class="opmenu__item" rel="noopener" target="_blank">Open source ↗</a>
            <div class="opmenu__sep"></div>
            <button type="button" class="opmenu__item opmenu__item--danger" data-action="delete">
              Delete permanently
            </button>
          </div>
        </div>
      </div>
    </header>

    <main class="r2" id="main">
      {renderedEvents.length > 0 && (
        <section
          class={`r2-pipeline is-${pipelineState}${pipelineIsStalled ? " is-stalled" : ""}${pipelineState === "complete" && !pipelineIsStalled ? " is-collapsed" : ""}`}
          aria-live="polite"
          data-pipeline
          data-pipeline-state={pipelineState}
          data-event-count={renderedEvents.length}
        >
          <header class="r2-pipeline__head" data-pipeline-toggle role="button" tabindex="0" aria-expanded="true" aria-controls={`pipeline-body-${row.id}`}>
            <div class="r2-pipeline__title">
              <span class="r2-pipeline__bullet" aria-hidden="true"></span>
              <span class="r2-pipeline__title-text">pipeline · {pipelineHeadline}</span>
              {pipelineModel && <span class="r2-pipeline__model">· {pipelineModel}</span>}
              <span class="r2-pipeline__count">{renderedEvents.length} events</span>
            </div>
            <div class="r2-pipeline__elapsed">
              <span
                class="r2-pipeline__elapsed-main"
                data-pipeline-elapsed
                data-started-at={pipelineStartedAt.toISOString()}
                data-running={isProcessing ? "1" : "0"}
              >{pipelineElapsedLabel}</span>
              {pipelineWindowLabel && <small>{pipelineWindowLabel}</small>}
            </div>
            <span class="r2-pipeline__chevron" aria-hidden="true">▾</span>
          </header>
          <div class="r2-pipeline__body" id={`pipeline-body-${row.id}`}>
          {pipelineFailureReason && (
            <div class={`r2-pipeline__reason r2-pipeline__reason--${pipelineState}`}>
              <span class="r2-pipeline__reason-label">
                {pipelineState === "rejected" ? "原因 · Rejected by editor" : "原因 · AI failure"}
              </span>
              <pre class="r2-pipeline__reason-msg">{pipelineFailureReason}</pre>
            </div>
          )}
          {isProcessing && (
            <div class="r2-pipeline__meter" aria-hidden="true">
              <span style={`width: ${pipelineProgressPct}%`}></span>
            </div>
          )}
          <ol class="r2-pipeline__log" data-active-idx={activeEventIdx}>
            {renderedEvents.map((e, idx) => {
              const isActive = idx === activeEventIdx;
              const rowState = isActive ? "active" : e.state;
              const metaEntries = e.meta ? Object.entries(e.meta) : [];
              return (
                <li class={`r2-pipeline__row is-${rowState}`}>
                  <div class="r2-pipeline__line">
                    <span class="r2-pipeline__glyph" aria-hidden="true">{isActive ? "◌" : e.glyph}</span>
                    <span class="r2-pipeline__ts t-code">{e.ts}</span>
                    <span class="r2-pipeline__stage">{e.stage}</span>
                    <span class="r2-pipeline__status">{e.status}</span>
                    <span class="r2-pipeline__delta t-code">{e.elapsedSincePrev ?? ""}</span>
                  </div>
                  {(metaEntries.length > 0 || e.message || isActive) && (
                    <div class="r2-pipeline__sub">
                      {e.message && (
                        <div class="r2-pipeline__sub-row r2-pipeline__sub-row--msg">
                          <span class="r2-pipeline__sub-glyph" aria-hidden="true">⤷</span>
                          <span>{e.message}</span>
                        </div>
                      )}
                      {metaEntries.map(([k, v]) => (
                        <div class="r2-pipeline__sub-row">
                          <span class="r2-pipeline__sub-glyph" aria-hidden="true">⤷</span>
                          <span class="r2-pipeline__sub-kv">
                            <span class="r2-pipeline__sub-k">{k}</span>
                            <span class="r2-pipeline__sub-eq">=</span>
                            <span class="r2-pipeline__sub-v">{
                              Array.isArray(v)
                                ? (v.length ? v.join(",") : "—")
                                : typeof v === "object" && v !== null
                                  ? JSON.stringify(v)
                                  : String(v)
                            }</span>
                          </span>
                        </div>
                      ))}
                      {isActive && (
                        <div class="r2-pipeline__sub-row r2-pipeline__sub-row--live">
                          <span class="r2-pipeline__sub-glyph" aria-hidden="true">⤷</span>
                          <span>
                            running…
                            <span
                              class="r2-pipeline__live-tick t-code"
                              data-live-since={e.tsISO}
                            >{e.elapsedSincePrev ?? "0s"}</span>
                          </span>
                        </div>
                      )}
                    </div>
                  )}
                </li>
              );
            })}
          </ol>
          {pipelineIsStalled && (
            <div class="r2-pipeline__hint">
              已超过正常窗口。可以用右上角 ⋯ 里的 Re-run 重新入队。
            </div>
          )}
          </div>
        </section>
      )}

      <article class="r2-card" id="r2-card">
        <div class="r2-card__eyebrow">
          <a href={row.url} rel="noopener" target="_blank" title="Open source">{sourceHost} ↗</a>
          {row.extractedLang && (
            <>
              <span class="r2-card__sep">·</span>
              <span>{row.extractedLang}</span>
            </>
          )}
          {readMinutes && (
            <>
              <span class="r2-card__sep">·</span>
              <span>{readMinutes} min read</span>
            </>
          )}
          <div class="lang3-toggle" role="tablist" aria-label="Show language">
            <button type="button" data-lang3="both" class="is-active">Both</button>
            <button type="button" data-lang3="zh">中</button>
            <button type="button" data-lang3="en">EN</button>
          </div>
        </div>

        <h1
          class="r2-title ie lang-zh-only"
          contenteditable="true"
          spellcheck="false"
          data-mirror="title_zh"
          data-placeholder="点击写中文标题"
          data-empty={!row.aiTitleZh ? "1" : undefined}
        >{row.aiTitleZh ?? ""}</h1>
        <h2
          class="r2-title r2-title--en ie lang-en-only"
          contenteditable="true"
          spellcheck="false"
          data-mirror="title_en"
          data-placeholder="Click to write English title"
          data-empty={!row.aiTitleEn ? "1" : undefined}
        >{row.aiTitleEn ?? ""}</h2>

        <div class="r2-bilingual">
          <p
            class="r2-summary ie lang-zh-only"
            contenteditable="true"
            spellcheck="false"
            data-mirror="summary_zh"
            data-placeholder="点击写中文摘要"
            data-empty={!row.aiSummaryZh ? "1" : undefined}
          >{row.aiSummaryZh ?? ""}</p>
          <p
            class="r2-summary r2-summary--en ie lang-en-only"
            contenteditable="true"
            spellcheck="false"
            data-mirror="summary_en"
            data-placeholder="Click to write English summary"
            data-empty={!row.aiSummaryEn ? "1" : undefined}
          >{row.aiSummaryEn ?? ""}</p>
        </div>

        <ul class="r2-bullets" id="r2-bullets">
          {aiBullets.length === 0 && (
            <li class="r2-bullets__row" data-bullet-row>
              <span class="r2-bullets__zh ie lang-zh-only" contenteditable="true" data-bullet-zh data-placeholder="点击加一条要点 (中)" data-empty="1"></span>
              <span class="r2-bullets__en ie lang-en-only" contenteditable="true" data-bullet-en data-placeholder="And English…" data-empty="1"></span>
              <button type="button" class="r2-bullets__remove" data-bullet-remove aria-label="Remove">×</button>
            </li>
          )}
          {aiBullets.map((b) => (
            <li class="r2-bullets__row" data-bullet-row>
              <span class="r2-bullets__zh ie lang-zh-only" contenteditable="true" data-bullet-zh data-placeholder="(中)" data-empty={!b.zh ? "1" : undefined}>{b.zh}</span>
              <span class="r2-bullets__en ie lang-en-only" contenteditable="true" data-bullet-en data-placeholder="(en)" data-empty={!b.en ? "1" : undefined}>{b.en}</span>
              <button type="button" class="r2-bullets__remove" data-bullet-remove aria-label="Remove">×</button>
            </li>
          ))}
        </ul>
        <button type="button" class="r2-bullets__add" id="r2-bullets-add" style="margin-top: 14px">+ 加一条要点 / Add bullet</button>

        <div class="r2-note">
          <span class="r2-note__label">Editor's note · 你的话</span>
          <div
            class="r2-note__body ie lang-zh-only"
            contenteditable="true"
            spellcheck="false"
            data-mirror="editor_zh"
            data-placeholder="一句你的视角——AI 没法替你写的那一段"
            data-empty={!row.editorNoteZh ? "1" : undefined}
          >{row.editorNoteZh ?? ""}</div>
          <div
            class="r2-note__body ie lang-en-only"
            contenteditable="true"
            spellcheck="false"
            data-mirror="editor_en"
            data-placeholder="One line in your voice"
            data-empty={!row.editorNoteEn ? "1" : undefined}
          >{row.editorNoteEn ?? ""}</div>
        </div>

        <div class="r2-footer">
          <div class="chips" id="r2-chips">
            {aiTags.map((t) => (
              <span class="chip" data-chip>
                <span data-chip-text>{t}</span>
                <button type="button" class="chip__remove" data-chip-remove aria-label="Remove tag">×</button>
              </span>
            ))}
            <input
              type="text"
              class="chip-input"
              id="r2-chip-input"
              placeholder="+ tag"
              autocomplete="off"
              maxlength="30"
            />
          </div>

          <div class="r2-meta">
            <span><span class="r2-meta__label">cat</span>
              <select class="r2-meta__edit" name="category">
                <option value="code" selected={row.aiCategory === "code"}>code</option>
                <option value="infra" selected={row.aiCategory === "infra"}>infra</option>
                <option value="data" selected={row.aiCategory === "data"}>data</option>
              </select>
            </span>
            <span class="r2-meta__sep">·</span>
            <span><span class="r2-meta__label">score</span>
              <input
                type="number"
                class="r2-meta__edit"
                name="score"
                step="0.01"
                min="0"
                max="1"
                value={row.aiScore?.toString() ?? "0.5"}
                style="width: 64px"
              />
            </span>
            <span class="r2-meta__sep">·</span>
            <span><span class="r2-meta__label">by</span>
              <input
                type="text"
                class="r2-meta__edit"
                name="submitter"
                value={row.submitterName ?? ""}
                placeholder="Devin"
                maxlength="40"
                style="width: 110px"
              />
            </span>
          </div>
        </div>
      </article>

      {/* Hidden mirror fields. Visible contenteditable copies its content here on every edit. */}
      <div hidden aria-hidden="true">
        <input type="hidden" name="title_zh" value={row.aiTitleZh ?? ""} />
        <input type="hidden" name="title_en" value={row.aiTitleEn ?? ""} />
        <textarea name="summary_zh">{row.aiSummaryZh ?? ""}</textarea>
        <textarea name="summary_en">{row.aiSummaryEn ?? ""}</textarea>
        <textarea name="bullets_zh" id="ar-bullets-zh">{bulletsZhText}</textarea>
        <textarea name="bullets_en" id="ar-bullets-en">{bulletsEnText}</textarea>
        <input type="hidden" name="editor_zh" value={row.editorNoteZh ?? ""} />
        <input type="hidden" name="editor_en" value={row.editorNoteEn ?? ""} />
