  {/* AI details drawer (I) */}
  <div class="drawer" id="ai-drawer" role="dialog" aria-modal="true" aria-labelledby="ai-drawer-title">
    <div class="drawer__backdrop" data-drawer-close></div>
    <aside class="drawer__panel">
      <header class="drawer__header">
        <span id="ai-drawer-title">AI details · I</span>
        <button type="button" class="drawer__close" data-drawer-close aria-label="Close">×</button>
      </header>
      <div class="drawer__body">
        {aiSubscores ? (
          <div class="r2-ai__group">
            <div class="r2-ai__group-label">5-dim subscores</div>
            {Object.entries(aiSubscores).map(([k, v]) => (
              <div class="r2-ai__row">
                <span class="r2-ai__row-label">{k}</span>
                <span class="r2-ai__row-bar"><span class="r2-ai__row-fill" style={`width: ${Math.round(Number(v) * 100)}%`}></span></span>
                <span class="r2-ai__row-val">{Number(v).toFixed(2)}</span>
              </div>
            ))}
          </div>
        ) : (
