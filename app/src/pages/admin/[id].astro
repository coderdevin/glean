  {/* Hidden helper forms triggered from the ⋯ menu */}
  <form id="op-refetch" action={`/api/admin/${row.id}/refetch`} method="post" hidden></form>
  <form id="op-rerun-pro" action="/api/admin/process" method="post" hidden>
    <input type="hidden" name="id" value={row.id} />
    <input type="hidden" name="model" value="deepseek-v4-pro" />
  </form>
  <form id="op-rerun-flash" action="/api/admin/process" method="post" hidden>
    <input type="hidden" name="id" value={row.id} />
    <input type="hidden" name="model" value="deepseek-v4-flash" />
  </form>
  <form id="op-delete" action={`/api/admin/${row.id}/delete`} method="post" hidden></form>

  {/* Destructive-action confirm modal — replaces the native window.prompt
       that ships with no design. Currently used only by the ⋯ Delete flow;
       structure is reusable if we add more confirm paths later. */}
  <div class="confirm" id="confirm-delete" role="dialog" aria-modal="true" aria-labelledby="confirm-delete-title" aria-hidden="true">
    <div class="confirm__backdrop" data-confirm-close></div>
    <div class="confirm__panel" role="document">
      <header class="confirm__header">
        <span class="confirm__icon" aria-hidden="true">⚠</span>
        <h2 id="confirm-delete-title" class="confirm__title">彻底删除提交</h2>
      </header>
      <div class="confirm__body">
        <p>这一步会一并删除关联的已发布 pick + R2 原文。<strong>不可恢复。</strong></p>
        <p class="confirm__hint">
          输入 <code class="confirm__sentinel">删除</code> 或 <code class="confirm__sentinel">DELETE</code> 继续。
        </p>
        <input
          type="text"
          id="confirm-delete-input"
          class="confirm__input"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder="删除 / DELETE"
          aria-label="Type 删除 or DELETE to confirm"
        />
      </div>
      <footer class="confirm__actions">
        <button type="button" class="btn btn-secondary confirm__cancel" data-confirm-close>
          取消 <kbd>Esc</kbd>
        </button>
        <button type="button" id="confirm-delete-go" class="btn btn-danger" disabled>
          删除 <kbd>⏎</kbd>
        </button>
      </footer>
    </div>
  </div>

  <style>@keyframes pulse { 0%, 100% { opacity: 1 } 50% { opacity: 0.35 } }</style>

  <script is:inline define:vars={{ submissionId: row.id, prevId: queueContext?.prevId ?? null, nextId: queueContext?.nextId ?? null, isProcessingJS: isProcessing, publishBlocked: row.status !== "ready" }}>
    (() => {
      const form = document.getElementById("ar-form");
      if (!form) return;

      // ---- Plain-text paste & single-line key handling for every .ie cell.
      // Paste-as-text avoids ending up with arbitrary HTML in the field; the
      // hidden form mirror uses innerText anyway, but stripping at paste-time
      // keeps the visible state clean too.
      const insertPlainText = (text) => {
        const sel = window.getSelection();
        if (!sel || !sel.rangeCount) return;
        const r = sel.getRangeAt(0);
        r.deleteContents();
        r.insertNode(document.createTextNode(text));
        r.collapse(false);
        sel.removeAllRanges();
        sel.addRange(r);
      };
      document.querySelectorAll(".ie").forEach((el) => {
        el.addEventListener("paste", (e) => {
          e.preventDefault();
          const text = (e.clipboardData || window.clipboardData).getData("text/plain");
          insertPlainText(text);
          el.dispatchEvent(new Event("input", { bubbles: true }));
        });
      });
      // Titles are single-line — Enter should commit, not insert a newline.
      document.querySelectorAll(".r2-title.ie").forEach((el) => {
        el.addEventListener("keydown", (e) => {
          if (e.key === "Enter") { e.preventDefault(); el.blur(); }
        });
      });

      // ---- Mirror logic: copy contenteditable text into hidden form fields.
      const syncMirror = (el) => {
        const name = el.dataset.mirror;
        if (!name) return;
        const target = form.querySelector(`[name="${name}"]`);
        if (!target) return;
        const value = (el.innerText ?? "").trim();
        target.value = value;
        el.dataset.empty = value ? "" : "1";
      };
      document.querySelectorAll("[data-mirror]").forEach((el) => {
        // Initialize empty state.
        if (!(el.innerText ?? "").trim()) el.dataset.empty = "1";
        el.addEventListener("input", () => { syncMirror(el); scheduleAutosave(); });
        el.addEventListener("blur", () => syncMirror(el));
      });

      // ---- Bullets: list of {zh, en}. Joined into two hidden textareas.
      const list = document.getElementById("r2-bullets");
      const bulletsZh = document.getElementById("ar-bullets-zh");
      const bulletsEn = document.getElementById("ar-bullets-en");
      const syncBullets = () => {
        const rows = list.querySelectorAll("[data-bullet-row]");
        const zh = [];
        const en = [];
        rows.forEach((r) => {
          const z = (r.querySelector("[data-bullet-zh]").innerText ?? "").trim();
          const e = (r.querySelector("[data-bullet-en]").innerText ?? "").trim();
          // Skip totally empty rows on submit. Keep them visible while editing.
          if (z || e) { zh.push(z); en.push(e); }
        });
        bulletsZh.value = zh.join("\n");
        bulletsEn.value = en.join("\n");
      };
      const bindBulletRow = (row) => {
        row.querySelectorAll("[data-bullet-zh], [data-bullet-en]").forEach((cell) => {
          const updateEmpty = () => { cell.dataset.empty = (cell.innerText ?? "").trim() ? "" : "1"; };
          cell.addEventListener("input", () => { syncBullets(); updateEmpty(); scheduleAutosave(); });
          cell.addEventListener("blur", () => { syncBullets(); updateEmpty(); });
        });
        row.querySelector("[data-bullet-remove]")?.addEventListener("click", () => {
          row.remove();
          syncBullets();
          scheduleAutosave();
        });
      };
      list.querySelectorAll("[data-bullet-row]").forEach(bindBulletRow);
      document.getElementById("r2-bullets-add")?.addEventListener("click", () => {
        const tpl = document.createElement("li");
        tpl.className = "r2-bullets__row";
        tpl.dataset.bulletRow = "1";
        tpl.innerHTML = `
          <span class="r2-bullets__zh ie lang-zh-only" contenteditable="true" data-bullet-zh data-placeholder="(中)" data-empty="1"></span>
          <span class="r2-bullets__en ie lang-en-only" contenteditable="true" data-bullet-en data-placeholder="(en)" data-empty="1"></span>
          <button type="button" class="r2-bullets__remove" data-bullet-remove aria-label="Remove">×</button>
        `;
        list.appendChild(tpl);
        bindBulletRow(tpl);
        tpl.querySelector("[data-bullet-zh]").focus();
      });

      // ---- Tags / chips.
      const chips = document.getElementById("r2-chips");
      const chipInput = document.getElementById("r2-chip-input");
      const tagsHidden = document.getElementById("ar-tags");
      const syncTags = () => {
        const slugs = [];
        chips.querySelectorAll("[data-chip]").forEach((c) => {
          const t = c.querySelector("[data-chip-text]").textContent.trim();
          if (t) slugs.push(t);
        });
        tagsHidden.value = slugs.join(",");
      };
      const addChip = (raw) => {
        const slug = raw.trim().toLowerCase().replace(/[\s,，]+/g, "-").replace(/[^a-z0-9-]/g, "");
        if (!slug) return;
        // Dedupe.
        const existing = [...chips.querySelectorAll("[data-chip-text]")].map((s) => s.textContent.trim());
        if (existing.includes(slug)) return;
        const el = document.createElement("span");
        el.className = "chip";
        el.dataset.chip = "1";
        el.innerHTML = `<span data-chip-text>${slug}</span><button type="button" class="chip__remove" data-chip-remove aria-label="Remove tag">×</button>`;
        chips.insertBefore(el, chipInput);
        el.querySelector("[data-chip-remove]").addEventListener("click", () => { el.remove(); syncTags(); scheduleAutosave(); });
        syncTags();
        scheduleAutosave();
      };
      chips.querySelectorAll("[data-chip-remove]").forEach((btn) => {
        btn.addEventListener("click", () => { btn.closest("[data-chip]").remove(); syncTags(); scheduleAutosave(); });
      });
      chipInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === "," || e.key === "，") {
          e.preventDefault();
          addChip(chipInput.value);
          chipInput.value = "";
        } else if (e.key === "Backspace" && !chipInput.value) {
          const last = chips.querySelectorAll("[data-chip]");
          if (last.length) { last[last.length - 1].remove(); syncTags(); scheduleAutosave(); }
        }
      });
      chipInput.addEventListener("blur", () => {
        if (chipInput.value.trim()) { addChip(chipInput.value); chipInput.value = ""; }
      });

      // ---- Auto-save (debounced 700ms).
      const status = document.getElementById("r2-save-status");
      let saveTimer = null;
      let inFlight = false;
      const setStatus = (text, kind) => {
        if (!status) return;
        status.textContent = text;
        status.className = "r2-actionbar__status" + (kind ? ` is-${kind}` : "");
      };
      const scheduleAutosave = () => {
        // Don't auto-save while still processing.
        if (form.dataset.processing === "1") return;
        clearTimeout(saveTimer);
        saveTimer = setTimeout(doAutosave, 700);
      };
      const doAutosave = async () => {
        if (inFlight) return;
        inFlight = true;
        setStatus("Saving…", "saving");
        try {
          const fd = new FormData(form);
          const res = await fetch(`/api/admin/${submissionId}/save`, { method: "POST", body: fd, redirect: "manual" });
          // Accept 200, 303 (redirect), or opaque-redirect — all mean OK.
          if (res.ok || res.type === "opaqueredirect" || (res.status >= 300 && res.status < 400)) {
            setStatus(`Saved ${new Date().toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}`, "saved");
          } else {
            setStatus("Save failed", "saving");
          }
        } catch (err) {
          setStatus("Save failed", "saving");
        } finally {
          inFlight = false;
        }
      };
      form.dataset.processing = isProcessingJS ? "1" : "0";
      // Save on visible input changes to category/score/byline too.
      form.querySelectorAll("select[name], input[name='score'], input[name='submitter']").forEach((el) => {
        el.addEventListener("change", scheduleAutosave);
        el.addEventListener("input", scheduleAutosave);
      });

      // ---- Live tick for the pipeline panel. Updates both the header's
      // overall elapsed clock and any active row's "running… XmYs" sub-row
      // once a second so the editor sees motion between the 4s page reloads.
      const fmtClock = (ms) => {
        const totalSec = Math.max(0, Math.floor(ms / 1000));
        const m = Math.floor(totalSec / 60);
        const s = totalSec % 60;
        if (m === 0) return `${s}s`;
        return `${m}m ${s.toString().padStart(2, "0")}s`;
      };
      const headEl = document.querySelector("[data-pipeline-elapsed]");
      const tickEl = document.querySelector("[data-live-since]");
      const tickHead = () => {
        if (!headEl) return;
        if (headEl.dataset.running !== "1") return;
        const started = headEl.dataset.startedAt ? new Date(headEl.dataset.startedAt).getTime() : NaN;
        if (!Number.isFinite(started)) return;
        headEl.textContent = fmtClock(Date.now() - started);
      };
      const tickRow = () => {
        if (!tickEl) return;
        const since = tickEl.dataset.liveSince ? new Date(tickEl.dataset.liveSince).getTime() : NaN;
        if (!Number.isFinite(since)) return;
        tickEl.textContent = fmtClock(Date.now() - since);
      };
      tickHead(); tickRow();
      if (isProcessingJS) setInterval(() => { tickHead(); tickRow(); }, 1000);

      // ---- Pipeline panel collapse/expand. Default is set server-side
      // (collapsed when the row is complete, expanded otherwise). User
      // preference is persisted in localStorage so a session-wide choice
      // survives reloads/auto-refreshes.
      const pipelineEl = document.querySelector("[data-pipeline]");
      if (pipelineEl) {
        const headerEl = pipelineEl.querySelector("[data-pipeline-toggle]");
        const PREF_KEY = "glean.admin.pipelineCollapsed";
        const setCollapsed = (collapsed) => {
          pipelineEl.classList.toggle("is-collapsed", collapsed);
          headerEl?.setAttribute("aria-expanded", collapsed ? "false" : "true");
        };
        // Honor stored preference if present, otherwise leave server default.
        const stored = localStorage.getItem(PREF_KEY);
        if (stored === "1") setCollapsed(true);
        else if (stored === "0") setCollapsed(false);
        const toggle = () => {
          const collapsed = !pipelineEl.classList.contains("is-collapsed");
          setCollapsed(collapsed);
          localStorage.setItem(PREF_KEY, collapsed ? "1" : "0");
        };
        headerEl?.addEventListener("click", toggle);
        headerEl?.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") { e.preventDefault(); toggle(); }
        });
      }

      // ---- In-flight feedback for any submit button. The form-target server
      // endpoint will redirect on its own; this just makes sure the user sees
      // *something* happen between click and redirect (otherwise the AI drawer
      // looks frozen for 100-400ms while the request is in flight).
      document.querySelectorAll("button[type='submit']").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          // Only act on the actual button the user clicked, not bubbled keys.
          // Skip our main publish/reject/save buttons in the action bar — those
          // are already in the user's natural sight line; the spinner here is
          // for the drawer-embedded operator actions like Re-run V4-Pro.
          if (btn.closest(".r2-actionbar")) return;
          // Defer to the next tick so we don't block the form submission.
          setTimeout(() => {
            btn.classList.add("is-submitting");
            // Stash original text so a failed submit could restore (best-effort).
            if (!btn.dataset.origLabel) btn.dataset.origLabel = btn.textContent || "";
            // Keep the button width stable while spinner shows.
            btn.style.minWidth = btn.offsetWidth + "px";
            btn.textContent = btn.dataset.queuingLabel || (btn.textContent.includes("Re-run") ? "Queuing…" : "…");
          }, 0);
        });
      });

      // ---- Drawer open/close.
      // Used to be a <meta http-equiv="refresh"> tag, but that wiped any open
      // drawer every 4s — annoying when you're inspecting AI details. Now a
      // JS interval polls only when isProcessing is true AND no drawer is
      // open AND nothing is focused (so you don't lose a mid-edit field).
      const openDrawer = (id) => {
        document.querySelectorAll(".drawer.is-open").forEach((d) => d.classList.remove("is-open"));
        const d = document.getElementById(id);
        if (d) d.classList.add("is-open");
        pauseRefresh();
      };
      const closeDrawers = () => {
        document.querySelectorAll(".drawer.is-open").forEach((d) => d.classList.remove("is-open"));
        maybeResumeRefresh();
      };
      document.querySelectorAll("[data-drawer-open]").forEach((btn) => {
        btn.addEventListener("click", () => openDrawer(btn.dataset.drawerOpen));
      });
      document.querySelectorAll("[data-drawer-close]").forEach((btn) => {
        btn.addEventListener("click", closeDrawers);
      });

      // ---- Auto-refresh while processing (replaces the meta tag).
      let refreshTimer = null;
      const REFRESH_MS = 4000;
      const startRefresh = () => {
        if (!isProcessingJS) return;
        clearInterval(refreshTimer);
        refreshTimer = setInterval(() => {
          if (document.querySelector(".drawer.is-open")) return;
          const a = document.activeElement;
          if (a && (a.isContentEditable || a.tagName === "INPUT" || a.tagName === "TEXTAREA" || a.tagName === "SELECT")) return;
          location.reload();
        }, REFRESH_MS);
      };
      const pauseRefresh = () => clearInterval(refreshTimer);
      const maybeResumeRefresh = () => { if (!document.querySelector(".drawer.is-open")) startRefresh(); };
      startRefresh();

      // ---- Op menu.
      const opmenu = document.getElementById("opmenu");
      document.querySelector("[data-opmenu-toggle]")?.addEventListener("click", (e) => {
        e.stopPropagation();
        opmenu.classList.toggle("is-open");
      });
      document.addEventListener("click", (e) => {
        if (!opmenu.contains(e.target)) opmenu.classList.remove("is-open");
      });
      const triggerForm = (formId) => {
        const f = document.getElementById(formId);
        if (f) f.submit();
      };

      // ---- Confirm-delete modal. Replaces native window.prompt so the
      // destructive action lives inside the design system. Accepts either
      // "删除" or "DELETE" (case-insensitive) — same sentinel as before.
      const confirmEl = document.getElementById("confirm-delete");
      const confirmInput = document.getElementById("confirm-delete-input");
      const confirmGo = document.getElementById("confirm-delete-go");
      const isDeleteSentinel = (v) => {
        const t = (v || "").trim();
        return t === "删除" || t.toUpperCase() === "DELETE";
      };
      const closeConfirmDelete = () => {
        if (!confirmEl) return;
        confirmEl.classList.remove("is-open");
        confirmEl.setAttribute("aria-hidden", "true");
        if (confirmInput) confirmInput.value = "";
        if (confirmGo) confirmGo.disabled = true;
      };
      const openConfirmDelete = () => {
        if (!confirmEl) return;
        confirmEl.classList.add("is-open");
        confirmEl.setAttribute("aria-hidden", "false");
        if (confirmInput) {
          confirmInput.value = "";
          setTimeout(() => confirmInput.focus(), 30);
        }
        if (confirmGo) confirmGo.disabled = true;
      };
      confirmEl?.querySelectorAll("[data-confirm-close]").forEach((b) => {
        b.addEventListener("click", closeConfirmDelete);
      });
      confirmInput?.addEventListener("input", () => {
        if (confirmGo) confirmGo.disabled = !isDeleteSentinel(confirmInput.value);
      });
      confirmInput?.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          e.preventDefault();
          if (isDeleteSentinel(confirmInput.value)) {
            closeConfirmDelete();
            triggerForm("op-delete");
          }
        } else if (e.key === "Escape") {
          e.preventDefault();
          closeConfirmDelete();
        }
      });
      confirmGo?.addEventListener("click", () => {
        if (!isDeleteSentinel(confirmInput?.value)) return;
        closeConfirmDelete();
        triggerForm("op-delete");
      });

      document.querySelectorAll("[data-action]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const action = btn.dataset.action;
          if (action === "refetch") triggerForm("op-refetch");
          else if (action === "rerun-pro") triggerForm("op-rerun-pro");
          else if (action === "rerun-flash") triggerForm("op-rerun-flash");
          else if (action === "delete") {
            openConfirmDelete();
          }
        });
      });

      // ---- Language toggle. CSS rule: ".lang-only-zh .lang-en-only { display: none }"
      // — adding class .lang-only-zh on the card hides every .lang-en-only descendant.
      document.querySelectorAll("[data-lang3]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const mode = btn.dataset.lang3; // "both" | "zh" | "en"
          const card = document.getElementById("r2-card");
          card.classList.remove("lang-only-zh", "lang-only-en");
          if (mode === "zh") card.classList.add("lang-only-zh");
          if (mode === "en") card.classList.add("lang-only-en");
          document.querySelectorAll("[data-lang3]").forEach((b) => b.classList.toggle("is-active", b === btn));
        });
      });

      // ---- Keyboard shortcuts (only when focus isn't inside editor / input).
      const isEditingFocus = () => {
        const a = document.activeElement;
        if (!a) return false;
        if (a.isContentEditable) return true;
        if (a.tagName === "INPUT" || a.tagName === "TEXTAREA" || a.tagName === "SELECT") return true;
        return false;
      };
      document.addEventListener("keydown", (e) => {
        // Esc: close confirm modal first (most-intrusive), then drawer / op menu.
        if (e.key === "Escape") {
          if (confirmEl?.classList.contains("is-open")) {
            closeConfirmDelete(); e.preventDefault();
            return;
          }
          if (document.querySelector(".drawer.is-open") || opmenu.classList.contains("is-open")) {
            closeDrawers(); opmenu.classList.remove("is-open"); e.preventDefault();
          }
          return;
        }
        // ⌘ / Ctrl combos always work.
        if (e.metaKey || e.ctrlKey) {
          if (e.key === "Enter") {
            e.preventDefault();
            if (publishBlocked) return;
            form.action = `/api/admin/${submissionId}/publish`; form.submit(); return;
          }
          if (e.key === "s") { e.preventDefault(); doAutosave(); return; }
          // NOTE: Cmd+D was previously bound to reject. Removed — destructive
          // shortcuts with no confirm caused silent rejects (single `r` or
          // `R` keystroke while focus left an input was enough). The Reject
          // button in the action bar is now the only path; click is explicit.
        }
        // Single-key shortcuts: only when not typing.
        if (isEditingFocus()) return;
        if (e.key === "Enter") {
          e.preventDefault();
          if (publishBlocked) return;
          form.action = `/api/admin/${submissionId}/publish`; form.submit();
        }
        // NOTE: single-key `R` was previously a reject shortcut — see comment
        // above. Removed to prevent accidental rejects. Use the Reject button.
        else if (e.key === "s" || e.key === "S") { e.preventDefault(); doAutosave(); }
        else if (e.key === "v" || e.key === "V") { e.preventDefault(); openDrawer("src-drawer"); }
        else if (e.key === "i" || e.key === "I") { e.preventDefault(); openDrawer("ai-drawer"); }
        else if (e.key === "b" || e.key === "B") { e.preventDefault(); openDrawer("body-drawer"); }
        else if (e.key === "j" || e.key === "J" || e.key === "ArrowLeft") {
          if (prevId) { e.preventDefault(); location.href = `/admin/${prevId}`; }
        } else if (e.key === "k" || e.key === "K" || e.key === "ArrowRight") {
          if (nextId) { e.preventDefault(); location.href = `/admin/${nextId}`; }
        }
      });

      // ---- Final form-submit sync: make sure mirrors/bullets/tags are current.
      form.addEventListener("submit", () => {
        document.querySelectorAll("[data-mirror]").forEach(syncMirror);
        syncBullets();
        syncTags();
      });
    })();
  </script>
</Admin>
