        {aiNextHints.length > 0 && (
          <div class="r2-ai__group">
            <div class="r2-ai__group-label">Next-read hints</div>
            <div class="chips">
              {aiNextHints.map((h) => <span class="chip" style="cursor: default">→ {h}</span>)}
            </div>
          </div>
        )}

        <div class="r2-ai__group">
          <div class="r2-ai__group-label">Pipeline</div>
          <div class="t-body-sm text-muted" style="line-height: 1.7">
            {row.aiModel && <>model: <span class="t-code">{row.aiModel}</span><br /></>}
            {row.aiLatencyMs ? <>latency: <span class="t-code">{(row.aiLatencyMs / 1000).toFixed(1)}s</span><br /></> : null}
            {row.aiTokens ? <>tokens: <span class="t-code">{row.aiTokens.toLocaleString()}</span><br /></> : null}
            {row.extractedLang && <>detected lang: <span class="t-code">{row.extractedLang}</span></>}
          </div>
          <div class="row" style="gap: 8px; margin-top: 12px; flex-wrap: wrap">
            <form action="/api/admin/process" method="post" style="display: inline">
              <input type="hidden" name="id" value={row.id} />
              <button class="btn btn-secondary" type="submit" name="model" value="deepseek-v4-pro">Re-run V4-Pro</button>
            </form>
            <form action="/api/admin/process" method="post" style="display: inline">
              <input type="hidden" name="id" value={row.id} />
              <button class="btn btn-secondary" type="submit" name="model" value="deepseek-v4-flash">Re-run V4-Flash</button>
            </form>
          </div>
        </div>
