        <div class="r2-actionbar__sections" data-sections-state="failed">
          <span class="r2-actionbar__sections-msg" title={row.aiSectionsError ?? undefined}>
            {`sections 失败${failureErrorShort ? `: ${failureErrorShort}` : ""}`}
          </span>
          {/* form="ar-regen-form" associates this submit with the
              separate form declared after ar-form, so Enter inside any
              ar-form input cannot accidentally trigger a regenerate. */}
