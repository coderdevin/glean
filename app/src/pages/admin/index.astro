---
export const prerender = false;
import Admin from "~/layouts/Admin.astro";
import StatusPill from "~/components/StatusPill.astro";
import { db } from "~/db/client";
import { submissions, type SubmissionStatus } from "~/db/schema";
import { and, desc, inArray, like, or, sql } from "drizzle-orm";
import { formatDateISO, formatTimeHM, siteTz, todayInSiteTz } from "~/lib/datetime";

const env = Astro.locals.runtime.env;
const filterParam = Astro.url.searchParams.get("status");
type FilterKey = "active" | "ready" | "pending" | "published" | "rejected" | "failed" | "all";
const FILTERS: Record<FilterKey, ("pending"|"analyzing"|"composing"|"ready"|"published"|"rejected"|"failed")[]> = {
  active:    ["pending", "analyzing", "composing", "ready"],
  ready:     ["ready"],
  pending:   ["pending", "analyzing", "composing"],
  published: ["published"],
  rejected:  ["rejected"],
  failed:    ["failed"],
  all:       ["pending", "analyzing", "composing", "ready", "published", "rejected", "failed"],
};
const filterKey: FilterKey = (() => {
  if (!filterParam) return "active";
  if (filterParam in FILTERS) return filterParam as FilterKey;
  // Backwards compat: comma list passed in (old links).
  const parts = filterParam.split(",").filter(Boolean) as SubmissionStatus[];
  if (parts.length === 1 && parts[0] === "ready") return "ready";
  if (parts.length === 1 && parts[0] === "published") return "published";
  if (parts.length === 1 && parts[0] === "rejected") return "rejected";
  if (parts.length === 1 && parts[0] === "failed") return "failed";
  if (parts.length >= 2 && parts.includes("pending")) return "pending";
  return "active";
})();

// Flat browse views (published / rejected / failed / pending / all) get
// server-side search + sort + pagination. The composite "active"/"ready"
// triage dashboards keep their bounded single-shot query.
const isFlatList = filterKey !== "active" && filterKey !== "ready";
const PAGE_SIZE = 50;
const q = (Astro.url.searchParams.get("q") ?? "").trim();
const sortParam: "newest" | "score" =
  Astro.url.searchParams.get("sort") === "score" ? "score" : "newest";
const page = Math.max(1, Number.parseInt(Astro.url.searchParams.get("page") ?? "1", 10) || 1);

const drizzle = db(env.DB);

// One grouped query powers the per-tab counts on the filter nav.
const statusCountRows = await drizzle
  .select({ status: submissions.status, n: sql<number>`count(*)` })
  .from(submissions)
  .groupBy(submissions.status);
const countByStatus = new Map(statusCountRows.map((r) => [r.status, Number(r.n)]));
const tabCount = (key: FilterKey) =>
  FILTERS[key].reduce((sum, st) => sum + (countByStatus.get(st) ?? 0), 0);

// Free-text search across title (zh/en), source host, and submitter.
const searchWhere = q
  ? or(
      like(submissions.aiTitleZh, `%${q}%`),
      like(submissions.aiTitleEn, `%${q}%`),
      like(submissions.url, `%${q}%`),
      like(submissions.submitterName, `%${q}%`),
    )
  : undefined;

let rows;
let totalRows: number;
if (isFlatList) {
  const where = and(inArray(submissions.status, FILTERS[filterKey]), searchWhere);
  const [countRow] = await drizzle
    .select({ n: sql<number>`count(*)` })
    .from(submissions)
    .where(where);
  totalRows = Number(countRow?.n ?? 0);
  rows = await drizzle
    .select()
    .from(submissions)
    .where(where)
    .orderBy(sortParam === "score" ? desc(submissions.aiScore) : desc(submissions.createdAt))
    .limit(PAGE_SIZE)
    .offset((page - 1) * PAGE_SIZE);
} else {
  rows = await drizzle
    .select()
    .from(submissions)
    .where(inArray(submissions.status, FILTERS[filterKey]))
    .orderBy(desc(submissions.createdAt))
    .limit(200);
  totalRows = rows.length;
}

// Sort the "Ready" list oldest-first so the top one is also the oldest —
// matches what `/publish` uses for "next" navigation.
const readyOldestFirst = [...rows].filter((r) => r.status === "ready").sort((a, b) => {
  const at = a.createdAt ? new Date(a.createdAt).getTime() : 0;
  const bt = b.createdAt ? new Date(b.createdAt).getTime() : 0;
  return at - bt;
});
const inFlight = rows.filter((r) => r.status === "pending" || r.status === "analyzing" || r.status === "composing");
const published = rows.filter((r) => r.status === "published");
const rejected = rows.filter((r) => r.status === "rejected");
const failed = rows.filter((r) => r.status === "failed");

const upNext = readyOldestFirst[0] ?? null;
const restReady = readyOldestFirst.slice(1);

const tz = siteTz(env);
const today = todayInSiteTz(tz);
const hms = (d: Date | null) => formatTimeHM(d, tz);
// Time-only for items from today; "MM-DD" otherwise — a multi-day browse list
// would otherwise be all ambiguous "13:06"-style times with no date context.
const whenLabel = (d: Date | null) => {
  if (!d) return "";
  const iso = formatDateISO(d, tz);
  return iso === today ? hms(d) : iso.slice(5);
};
const whenTitle = (d: Date | null) => (d ? `${formatDateISO(d, tz)} ${hms(d)}` : "");
const minutesAgo = (d: Date | null) => d ? Math.floor((Date.now() - new Date(d).getTime()) / 60000) : 0;
const host = (url: string) => { try { return new URL(url).host; } catch { return url; } };
const parseTags = (json: string | null): string[] => { try { return JSON.parse(json ?? "[]"); } catch { return []; } };

// Score quality bands: <0.4 reads as low, ≥0.75 as high — so a published list
// can be scanned for outliers ("why did this low score ship?").
const scoreClass = (s: number | null | undefined) => {
  if (s === null || s === undefined) return "";
  const n = Number(s);
  if (n < 0.4) return " q2-row__score--low";
  if (n >= 0.75) return " q2-row__score--high";
  return "";
};

// Hover breakdown for the score cell: the 7 subscores the model already
// produced (stored in ai_subscores_json) + the formula that combines them.
// Surfaces *why* a score is what it is without a schema/prompt change — the
// detail page shows the same numbers, this just makes them scannable in-list.
// A native title tooltip can't language-switch, so each line is bilingual
// (中 + en) — readable whether the admin is viewing zh or en.
const SUBSCORE_ORDER = ["novelty", "depth", "evidence", "effort", "audience_fit", "utility", "bias"] as const;
const SUBSCORE_LABELS: Record<(typeof SUBSCORE_ORDER)[number], string> = {
  novelty: "新颖 novelty",
  depth: "深度 depth",
  evidence: "证据 evidence",
  effort: "投入 effort",
  audience_fit: "受众契合 audience fit",
  utility: "实用 utility",
  bias: "偏向 bias",
};
const scoreTitle = (json: string | null): string => {
  let s: Record<string, unknown> | null;
  try { s = json ? JSON.parse(json) : null; } catch { return ""; }
  if (!s || typeof s !== "object") return "";
  const lines = SUBSCORE_ORDER
    .filter((k) => typeof s![k] === "number")
    .map((k) => `${SUBSCORE_LABELS[k]}  ${Number(s![k]).toFixed(2)}`);
  if (!lines.length) return "";
  return `${lines.join("\n")}\n———\n总分 ≈ 前 6 维均值 − 0.5 × 偏向\nscore ≈ avg(first 6) − 0.5 × bias`;
};

// Pagination math (flat-list views only).
const totalPages = Math.max(1, Math.ceil(totalRows / PAGE_SIZE));
const pageStart = totalRows === 0 ? 0 : (page - 1) * PAGE_SIZE + 1;
const pageEnd = Math.min(page * PAGE_SIZE, totalRows);
// Build a nav href, preserving status/q/sort and applying overrides.
const pageHref = (overrides: { page?: number; sort?: "newest" | "score" } = {}) => {
  const p = new URLSearchParams();
  if (filterKey !== "active") p.set("status", filterKey);
  if (q) p.set("q", q);
  const s = overrides.sort ?? sortParam;
  if (s === "score") p.set("sort", "score");
  const pg = overrides.page ?? page;
  if (pg > 1) p.set("page", String(pg));
  const qs = p.toString();
  return qs ? `/admin?${qs}` : "/admin";
};
const clearSearchHref = filterKey === "active" ? "/admin" : `/admin?status=${filterKey}`;

// The default-provider toggle now lives on /admin/settings.

Astro.response.headers.set("Cache-Control", "no-store");
---
<Admin title={`审核队列 · ${rows.length}`}>
  <main id="main" class="q2">
    <div class="container">
      <header class="q2-header">
        <div class="row row--between" style="align-items: end; flex-wrap: wrap; gap: 12px">
          <div>
            <p class="q2-header__sub">
              {filterKey === "active" ? (
                <>{readyOldestFirst.length} ready · {inFlight.length} in flight</>
              ) : q ? (
                <>{totalRows} {totalRows === 1 ? "result" : "results"} · “{q}”</>
              ) : (
                <>{`${totalRows} ${filterKey}`} · {sortParam === "score" ? "by score" : "newest first"}</>
              )}
            </p>
          </div>
          <nav class="q2-filters" aria-label="Filter">
            <a href="/admin" class={filterKey === "active" ? "is-active" : ""}>Active <span class="q2-filters__n">{tabCount("active")}</span></a>
            <a href="/admin?status=ready" class={filterKey === "ready" ? "is-active" : ""}>Ready <span class="q2-filters__n">{tabCount("ready")}</span></a>
            <a href="/admin?status=pending" class={filterKey === "pending" ? "is-active" : ""}>In flight <span class="q2-filters__n">{tabCount("pending")}</span></a>
            <a href="/admin?status=published" class={filterKey === "published" ? "is-active" : ""}>Published <span class="q2-filters__n">{tabCount("published")}</span></a>
            <a href="/admin?status=rejected" class={filterKey === "rejected" ? "is-active" : ""}>Rejected <span class="q2-filters__n">{tabCount("rejected")}</span></a>
            <a href="/admin?status=failed" class={filterKey === "failed" ? "is-active" : ""}>Failed <span class="q2-filters__n">{tabCount("failed")}</span></a>
            <a href="/admin?status=all" class={filterKey === "all" ? "is-active" : ""}>All <span class="q2-filters__n">{tabCount("all")}</span></a>
          </nav>
        </div>
      </header>

      {isFlatList && (
        <div class="q2-toolbar">
          <form class="q2-search" method="get" action="/admin" role="search">
            <input type="hidden" name="status" value={filterKey} />
            {sortParam === "score" && <input type="hidden" name="sort" value="score" />}
            <input
              type="search"
              name="q"
              value={q}
              placeholder="搜索标题 / 域名 / 提交人…"
              aria-label="Search submissions"
              class="q2-search__input"
            />
            <button type="submit" class="q2-search__btn">搜索</button>
            {q && <a class="q2-search__clear" href={clearSearchHref}>清除</a>}
          </form>
          <div class="q2-sort" role="group" aria-label="Sort">
            <span class="q2-sort__label">排序</span>
            <a href={pageHref({ sort: "newest", page: 1 })} class={sortParam === "newest" ? "is-active" : ""}>最新</a>
            <a href={pageHref({ sort: "score", page: 1 })} class={sortParam === "score" ? "is-active" : ""}>分数</a>
          </div>
        </div>
      )}

      {(filterKey === "active" || filterKey === "ready") && (
        <>
          {upNext ? (
            <a href={`/admin/${upNext.id}`} class="q2-hero" id="q2-upnext">
              <div style="min-width: 0">
                <div class="q2-hero__eyebrow">
                  <span><strong>Up next</strong> · oldest ready</span>
                  <span>Ready · {readyOldestFirst.length} total</span>
                </div>
                <h2 class="q2-hero__title">{upNext.aiTitleZh || upNext.aiTitleEn || upNext.url}</h2>
                <div class="q2-hero__meta">
                  <span>{host(upNext.url)}</span>
                  {parseTags(upNext.aiTagsJson).slice(0, 3).map((t) => <span class="chip" style="cursor: inherit">{t}</span>)}
                  {upNext.aiScore !== null && upNext.aiScore !== undefined && <span title={scoreTitle(upNext.aiSubscoresJson)}>· score {Number(upNext.aiScore).toFixed(2)}</span>}
                  <span>· by {upNext.submitterName?.trim() || "Devin"}</span>
                  <span title={whenTitle(upNext.createdAt)}>· {whenLabel(upNext.createdAt)}</span>
                </div>
              </div>
              <span class="q2-hero__cta">Review → <kbd>R</kbd></span>
            </a>
          ) : (
            <div class="q2-hero q2-hero--empty">
              <span class="lang-zh">没有 ready 的提交。</span>
              <span class="lang-en">No ready submissions.</span>
            </div>
          )}
        </>
      )}

      {restReady.length > 0 && (
        <section class="q2-section">
          <header class="q2-section__head">
            <h2 class="q2-section__title">Ready</h2>
            <span class="q2-section__count">{restReady.length} more</span>
          </header>
          <div class="q2-section__list">
            {restReady.map((r) => (
              <a href={`/admin/${r.id}`} class="q2-row">
                <span class="q2-row__title">{r.aiTitleZh || r.aiTitleEn || r.url}</span>
                <span class="q2-row__meta">{host(r.url)}</span>
                <span class="q2-row__score" title={scoreTitle(r.aiSubscoresJson)}>{r.aiScore === null || r.aiScore === undefined ? "—" : Number(r.aiScore).toFixed(2)}</span>
                <span class="q2-row__time" title={whenTitle(r.createdAt)}>{whenLabel(r.createdAt)}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {inFlight.length > 0 && (filterKey === "active" || filterKey === "pending") && (
        <section class="q2-section">
          <header class="q2-section__head">
            <h2 class="q2-section__title">In flight</h2>
            <span class="q2-section__count">{inFlight.length}</span>
          </header>
          <div class="q2-section__list">
            {inFlight.map((r) => {
              const stage: "extract" | "llm-queued" | "analysis" | "sections" =
                !r.rawR2Key ? "extract"
                : r.status === "pending" || (r.status === "analyzing" && r.processingModel === "extract") ? "llm-queued"
                : r.status === "composing" ? "sections"
                : "analysis";
              const mins = minutesAgo(r.processingStartedAt ?? r.createdAt);
              const stalled =
                stage === "extract" ? mins >= 2
                : stage === "llm-queued" ? mins >= 20
                : mins >= 12;
              const stageLabel =
                stage === "extract" ? "抓取中"
                : stage === "llm-queued" ? "AI 排队中"
                : stage === "sections" ? "Sections 生成中"
                : "AI 分析中";
              return (
                <a href={`/admin/${r.id}`} class={`q2-row${stalled ? " q2-row--stalled" : ""}`}>
                  <span class="q2-row__title">
                    ⏳ {stageLabel} · {host(r.url)}
                  </span>
                  <span class="q2-row__meta">
                    {stalled && <span class="q2-row__stall-pill">卡了 {mins}min</span>}
                  </span>
                  <span class="q2-row__score">{mins || "<1"}min</span>
                  <span class="q2-row__time" title={whenTitle(r.createdAt)}>{whenLabel(r.createdAt)}</span>
                </a>
              );
            })}
          </div>
        </section>
      )}

      {filterKey === "active" && published.length > 0 && (
        <details class="q2-collapse">
          <summary>
            Published <span class="q2-collapse__count">{published.length}</span>
          </summary>
          <div class="q2-section__list" style="margin-top: 12px">
            {published.map((r) => (
              <a href={`/admin/${r.id}`} class="q2-row">
                <span class="q2-row__title" style="color: var(--c-muted)">{r.aiTitleZh || r.aiTitleEn || r.url}</span>
                <span class="q2-row__meta">{host(r.url)}</span>
                <span class="q2-row__score" title={scoreTitle(r.aiSubscoresJson)}>{r.aiScore === null || r.aiScore === undefined ? "—" : Number(r.aiScore).toFixed(2)}</span>
                <span class="q2-row__time" title={whenTitle(r.createdAt)}>{whenLabel(r.createdAt)}</span>
              </a>
            ))}
          </div>
        </details>
      )}

      {filterKey === "active" && rejected.length > 0 && (
        <details class="q2-collapse">
          <summary>
            Rejected <span class="q2-collapse__count">{rejected.length}</span>
          </summary>
          <div class="q2-section__list" style="margin-top: 12px">
            {rejected.map((r) => (
              <a href={`/admin/${r.id}`} class="q2-row">
                <span class="q2-row__title" style="color: var(--c-muted); text-decoration: line-through; text-decoration-color: var(--c-muted-soft)">
                  {r.aiTitleZh || r.aiTitleEn || r.url}
                </span>
                <span class="q2-row__meta">{r.rejectReason ?? host(r.url)}</span>
                <span class="q2-row__score">—</span>
                <span class="q2-row__time" title={whenTitle(r.createdAt)}>{whenLabel(r.createdAt)}</span>
              </a>
            ))}
          </div>
        </details>
      )}

      {filterKey === "active" && failed.length > 0 && (
        <details class="q2-collapse">
          <summary>
            Failed <span class="q2-collapse__count">{failed.length}</span>
          </summary>
          <div class="q2-section__list" style="margin-top: 12px">
            {failed.map((r) => (
              <a href={`/admin/${r.id}`} class="q2-row">
                <span class="q2-row__title" style="color: var(--c-muted)">
                  {r.aiTitleZh || r.aiTitleEn || r.url}
                </span>
                <span class="q2-row__meta">{host(r.url)}</span>
                <span class="q2-row__score">—</span>
                <span class="q2-row__time" title={whenTitle(r.createdAt)}>{whenLabel(r.createdAt)}</span>
              </a>
            ))}
          </div>
        </details>
      )}

      {/* When a specific status is filtered (not "active"), list flat with
          server-side search / sort / pagination and inline row actions. */}
      {isFlatList && rows.length > 0 && (
        <section class="q2-section">
          <header class="q2-section__head">
            <h2 class="q2-section__title">{filterKey}</h2>
            <span class="q2-section__count">{totalRows}</span>
          </header>
          <div class="q2-section__list">
            {rows.map((r) => {
              const title = r.aiTitleZh || r.aiTitleEn || r.url;
              return (
                <div class="q2-row q2-row--browse" data-href={`/admin/${r.id}`}>
                  <span class="q2-row__titlewrap">
                    <a class="q2-row__title" href={`/admin/${r.id}`} title={title}>{title}</a>
                    {r.originalTitle && (
                      <span class="q2-row__orig" title={r.originalTitle}>{r.originalTitle}</span>
                    )}
                  </span>
                  <span class="q2-row__meta">
                    {filterKey === "all" && <StatusPill status={r.status} />}
                    <span>{host(r.url)}</span>
                  </span>
                  <span class={`q2-row__score${scoreClass(r.aiScore)}`} title={scoreTitle(r.aiSubscoresJson)}>
                    {r.aiScore === null || r.aiScore === undefined ? "—" : Number(r.aiScore).toFixed(2)}
                  </span>
                  <span class="q2-row__time" title={whenTitle(r.createdAt)}>{whenLabel(r.createdAt)}</span>
                  <span class="q2-row__actions">
                    <a class="q2-row__action" href={r.url} target="_blank" rel="noopener noreferrer" title="打开原文" aria-label="打开原文">↗</a>
                    <button type="button" class="q2-row__action" data-copy={r.url} title="复制链接" aria-label="复制链接">⧉</button>
                  </span>
                </div>
              );
            })}
          </div>
          {totalPages > 1 && (
            <nav class="q2-pager" aria-label="Pagination">
              {page > 1 ? (
                <a class="q2-pager__btn" href={pageHref({ page: page - 1 })} rel="prev">← 上一页</a>
              ) : (
                <span class="q2-pager__btn is-disabled" aria-disabled="true">← 上一页</span>
              )}
              <span class="q2-pager__status">{pageStart}–{pageEnd} / {totalRows} · 第 {page}/{totalPages} 页</span>
              {page < totalPages ? (
                <a class="q2-pager__btn" href={pageHref({ page: page + 1 })} rel="next">下一页 →</a>
              ) : (
                <span class="q2-pager__btn is-disabled" aria-disabled="true">下一页 →</span>
              )}
            </nav>
          )}
        </section>
      )}

      {rows.length === 0 && (
        <div class="q2-empty">
          {q ? (
            <>
              <span class="lang-zh">没有匹配“{q}”的提交。<a href={clearSearchHref}>清除搜索</a></span>
              <span class="lang-en">No submissions match “{q}”. <a href={clearSearchHref}>Clear search</a></span>
            </>
          ) : (
            <>
              <span class="lang-zh">没有符合筛选的提交。</span>
              <span class="lang-en">No submissions match this filter.</span>
            </>
          )}
        </div>
      )}
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer__bottom" style="margin-top: 0; border: 0; padding-top: 0">
        <span class="t-body-sm" style="color: var(--c-on-dark-soft)">
          admin · CF Access protected
        </span>
        <span class="t-code">{Astro.locals.adminEmail ?? "—"}</span>
      </div>
    </div>
  </footer>

  <script is:inline define:vars={{ upNextId: upNext?.id ?? null }}>
    (() => {
      // R key opens the up-next item.
      document.addEventListener("keydown", (e) => {
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        const a = document.activeElement;
        if (a && (a.tagName === "INPUT" || a.tagName === "TEXTAREA" || a.isContentEditable)) return;
        if ((e.key === "r" || e.key === "R") && upNextId) {
          e.preventDefault();
          location.href = `/admin/${upNextId}`;
        }
      });

      // Browse rows are <div>s (real links/buttons nest inside) — clicking
      // empty space navigates to the detail page; clicks on the title link or
      // an action button are handled by those elements directly.
      document.querySelectorAll(".q2-row--browse").forEach((row) => {
        row.addEventListener("click", (e) => {
          if (e.target.closest("a, button")) return;
          const href = row.getAttribute("data-href");
          if (href) location.href = href;
        });
      });

      // Inline "copy link" buttons.
      document.querySelectorAll("[data-copy]").forEach((btn) => {
        btn.addEventListener("click", async (e) => {
          e.preventDefault();
          e.stopPropagation();
          try {
            await navigator.clipboard.writeText(btn.getAttribute("data-copy"));
            const prev = btn.textContent;
            btn.textContent = "✓";
            btn.classList.add("is-copied");
            setTimeout(() => { btn.textContent = prev; btn.classList.remove("is-copied"); }, 1200);
          } catch {}
        });
      });
    })();
  </script>
</Admin>
