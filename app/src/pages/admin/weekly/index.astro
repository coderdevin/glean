---
export const prerender = false;
import Admin from "~/layouts/Admin.astro";
import { db } from "~/db/client";
import { allWeekliesAdmin } from "~/lib/queries";
import { thisWeekToDate } from "~/lib/weekly";
import { siteTz } from "~/lib/datetime";

const env = Astro.locals.runtime.env;
const issues = await allWeekliesAdmin(db(env.DB));
// Editable default range for the generate form: the current week so far.
const range = thisWeekToDate(new Date(), siteTz(env));
---
<Admin title="周刊 · Weekly">
  <div class="wk container">
    <header class="wk-head">
      <div>
        <div class="wk-eyebrow">编辑台 · Editor</div>
        <h1 class="wk-title">周刊 · Weekly</h1>
      </div>
      <button type="button" class="btn btn-primary wk-gen-open" id="open-generate">生成周刊</button>
    </header>

    <dialog id="generate-modal" class="wk-modal" aria-labelledby="generate-modal-title">
      <form method="POST" action="/api/admin/weekly/generate" class="wk-modal__form">
        <div class="wk-modal__head">
          <h2 class="wk-modal__title" id="generate-modal-title">生成周刊 · New issue</h2>
          <p class="wk-modal__hint">选好日期范围，AI 会把该区间内已发布、且尚未收录的篇目汇成一期草稿。</p>
        </div>
        <div class="wk-modal__fields">
          <div class="admin-field"><label>开始 · From</label>
            <input class="input" type="date" name="date_start" value={range.dateStart} required /></div>
          <div class="admin-field"><label>结束 · To</label>
            <input class="input" type="date" name="date_end" value={range.dateEnd} required /></div>
        </div>
        <div class="wk-modal__actions">
          <button type="button" class="btn btn-secondary" id="cancel-generate">取消</button>
          <button type="submit" class="btn btn-primary">生成周刊</button>
        </div>
      </form>
    </dialog>

    {issues.length === 0 ? (
      <div class="card card--canvas wk-empty">
        <p class="wk-empty__title">还没有任何周刊</p>
        <p class="wk-empty__hint">点右上角「生成周刊」，选好日期范围——AI 会把那段时间已发布的篇目汇成一期草稿。</p>
      </div>
    ) : (
      <ul class="wk-list">
        {issues.map((iss) => (
          <li class="wk-row">
            <a class="wk-row__link" href={`/admin/weekly/${iss.id}`}>
              <span class="wk-row__no">#{String(iss.number).padStart(3, "0")}</span>
              <span class="wk-row__body">
                <span class="wk-row__title">
                  <span class="wk-row__zh">{iss.titleZh}</span>
                  <span class="wk-row__en">{iss.titleEn}</span>
                </span>
                <span class="wk-row__meta">{iss.dateStart} → {iss.dateEnd}</span>
              </span>
              {iss.draftStatus === "drafting" ? (
                <span class="badge badge--amber wk-row__badge">起草中…</span>
              ) : iss.draftStatus === "failed" ? (
                <span class="badge badge--coral wk-row__badge">起草失败</span>
              ) : (
                <span class={`badge ${iss.publishedAt ? "badge--teal" : "badge--amber"} wk-row__badge`}>
                  {iss.publishedAt ? "已发布" : "草稿"}
                </span>
              )}
            </a>
            <a class="wk-row__export"
               href={`/api/admin/weekly/${iss.id}/export?lang=zh&inline=1`}
               target="_blank" rel="noopener"
               title="导出 HTML（打印为 PDF / 复制到邮箱）">导出 HTML</a>
          </li>
        ))}
      </ul>
    )}
  </div>

  <script is:inline>
    (function () {
      const dlg = document.getElementById("generate-modal");
      const openBtn = document.getElementById("open-generate");
      const cancelBtn = document.getElementById("cancel-generate");
      if (!dlg || !openBtn) return;
      openBtn.addEventListener("click", () => dlg.showModal());
      cancelBtn && cancelBtn.addEventListener("click", () => dlg.close());
      // Click the backdrop (outside the form) to dismiss.
      dlg.addEventListener("click", (e) => { if (e.target === dlg) dlg.close(); });
    })();
  </script>
</Admin>

<style>
  .wk {
    max-width: 860px;
    padding: var(--s-lg) 0 var(--s-xxl);
  }

  .wk-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--s-lg);
    flex-wrap: wrap;
    margin-bottom: var(--s-xl);
  }
  .wk-eyebrow {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: var(--c-muted);
  }
  .wk-title {
    font-size: clamp(28px, 5vw, 38px);
    margin: 6px 0 0;
    letter-spacing: -0.01em;
  }

  .wk-gen-open { flex: none; }

  /* Generate modal */
  .wk-modal {
    width: min(440px, calc(100vw - 32px));
    padding: 0;
    border: 1px solid var(--c-hairline);
    border-radius: var(--r-lg);
    background: var(--c-canvas);
    color: inherit;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.18);
  }
  .wk-modal::backdrop {
    background: rgba(30, 24, 20, 0.36);
    backdrop-filter: blur(2px);
  }
  .wk-modal__form { padding: var(--s-lg); }
  .wk-modal__head { margin-bottom: var(--s-md); }
  .wk-modal__title { font-size: 20px; margin: 0 0 var(--s-xs); }
  .wk-modal__hint { margin: 0; color: var(--c-muted); font-size: 13px; line-height: 1.6; }
  .wk-modal__fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-md);
    margin-bottom: var(--s-lg);
  }
  .wk-modal__fields .admin-field { margin-bottom: 0; }
  .wk-modal__fields .input { height: 40px; font-size: 14px; }
  .wk-modal__actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--s-sm);
  }
  @media (max-width: 480px) {
    .wk-modal__fields { grid-template-columns: 1fr; }
  }

  /* Empty state */
  .wk-empty { padding: var(--s-xl); text-align: center; }
  .wk-empty__title { margin: 0 0 var(--s-xs); font-weight: 600; color: var(--c-ink); }
  .wk-empty__hint { margin: 0 auto; max-width: 46ch; color: var(--c-muted); font-size: 14px; line-height: 1.6; }

  /* Issue list */
  .wk-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-sm);
  }
  /* The card is the row itself; the editor link + export button live inside
     it (anchors can't nest, so they're siblings sharing one bordered card). */
  .wk-row {
    display: flex;
    align-items: center;
    padding-right: var(--s-md);
    border: 1px solid var(--c-hairline);
    border-radius: var(--r-lg);
    background: var(--c-canvas);
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .wk-row:hover {
    border-color: var(--c-primary);
    background: var(--c-surface-soft);
  }
  .wk-row__link {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: var(--s-md);
    padding: var(--s-md) var(--s-sm) var(--s-md) var(--s-lg);
    color: inherit;
    text-decoration: none;
  }

  /* Export action — sits beside the status badge inside the same card. */
  .wk-row__export {
    flex: none;
    display: inline-flex;
    align-items: center;
    margin-left: var(--s-sm);
    padding: 7px 14px;
    border: 1px solid var(--c-hairline);
    border-radius: var(--r-lg);
    background: var(--c-surface-soft);
    color: var(--c-muted);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .wk-row__export:hover {
    border-color: var(--c-primary);
    color: var(--c-primary);
    background: var(--c-surface-cream-strong, var(--c-canvas));
  }
  .wk-row__no {
    flex: none;
    font-family: var(--f-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--c-muted);
    width: 3.2em;
  }
  .wk-row__body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
  .wk-row__title { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .wk-row__zh {
    font-size: 15px;
    font-weight: 500;
    color: var(--c-ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .wk-row__en {
    font-size: 12.5px;
    color: var(--c-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .wk-row__meta { font-size: 12px; color: var(--c-muted-soft); margin-top: 2px; }
  .wk-row__badge { flex: none; }

  @media (max-width: 620px) {
    .wk-head { flex-direction: column; align-items: stretch; }
    .wk-gen-open { width: 100%; }
    .wk-row__export { padding: var(--s-sm) var(--s-md); }
  }
</style>
