---
export const prerender = false;
import Admin from "~/layouts/Admin.astro";
import { db } from "~/db/client";
import { picks as picksTable } from "~/db/schema";
import { weeklyById, confirmedSubscriberCount } from "~/lib/queries";
import { eq } from "drizzle-orm";
import type { LayoutSection } from "~/lib/weekly";
import { siteTz, formatDateISO } from "~/lib/datetime";
import { categoryBadge } from "~/lib/category";

const env = Astro.locals.runtime.env;
const id = Astro.params.id!;
const drizzleDb = db(env.DB);
const issue = await weeklyById(drizzleDb, id);
if (!issue) return new Response("Not found", { status: 404 });

const layout: LayoutSection[] = issue.layoutJson ? JSON.parse(issue.layoutJson) : [];
const linked = await drizzleDb.select().from(picksTable).where(eq(picksTable.weeklyIssueId, id));
const pickById = new Map(linked.map((p) => [p.id, p]));
const isDraft = !issue.publishedAt;
// Async AI drafting state (migration 0011). While 'drafting', the editor is
// replaced by a polling placeholder; 'failed' shows a retry banner above it.
const isDrafting = issue.draftStatus === "drafting";
const draftFailed = issue.draftStatus === "failed";
const draftWaitedMin = issue.draftStartedAt
  ? Math.max(0, Math.floor((Date.now() - new Date(issue.draftStartedAt).getTime()) / 60_000))
  : 0;
const subscriberCount = await confirmedSubscriberCount(drizzleDb);
const sentDate = issue.emailSentAt ? formatDateISO(issue.emailSentAt, siteTz(env)) : null;

const no = String(issue.number).padStart(3, "0");
const catLabel: Record<string, string> = { infra: "Infra", data: "Data", code: "Code" };
---
<Admin title={`周刊 #${no} · 编辑`}>
  <div class="wk container">
    <a class="btn btn-text wk-back" href="/admin/weekly">← 所有周刊 · All issues</a>

    <header class="wk-head">
      <div class="wk-head__lede">
        <div class="wk-eyebrow">周刊 · Weekly issue</div>
        <h1 class="wk-no">
          #{no}
          <span class={`badge ${isDraft ? "badge--amber" : "badge--teal"}`}>
            {isDraft ? "草稿 · Draft" : "已发布 · Live"}
          </span>
        </h1>
        <p class="wk-sub">
          {issue.dateStart} <span class="wk-arrow">→</span> {issue.dateEnd}
          <span class="wk-dot"></span>{linked.length} 篇 picks
          <span class="wk-dot"></span>{layout.length} 章 sections
        </p>
      </div>
    </header>

    {isDrafting ? (
      <section class="card card--canvas wk-drafting">
        <div class="wk-drafting__spinner" aria-hidden="true"></div>
        <h2 class="wk-drafting__title">AI 起草中…</h2>
        <p class="wk-drafting__hint">
          正在让 AI 把本期 {linked.length} 篇 picks 编排成草稿，通常 30 秒 – 2 分钟。
          本页每 4 秒自动刷新，完成后会显示可编辑的草稿。
        </p>
        {draftWaitedMin > 0 && (
          <p class="wk-drafting__elapsed">已等待约 {draftWaitedMin} 分钟</p>
        )}
      </section>
    ) : (
    <Fragment>
    {draftFailed && (
      <div class="wk-draft-error">
        <div class="wk-draft-error__body">
          <strong class="wk-draft-error__title">AI 起草失败</strong>
          <p class="wk-draft-error__msg">{issue.draftError ?? "未知错误，请重试。"}</p>
        </div>
        <button form="weekly-form" type="submit" formaction={`/api/admin/weekly/${id}/regenerate`} class="btn btn-primary wk-draft-error__retry">重试 · 重新让 AI 起草</button>
      </div>
    )}

    <form method="POST" action={`/api/admin/weekly/${id}/save`} id="weekly-form" class="wk-stack">
      <!-- Issue metadata -->
      <section class="card card--canvas wk-metacard">
        <div class="wk-row2">
          <div class="admin-field"><label>期号 · Number</label>
            <input class="input" type="number" name="number" value={issue.number} /></div>
          <div class="admin-field"><label>Slug</label>
            <input class="input" name="slug" value={issue.slug} /></div>
          <div class="admin-field"><label>开始日期 · From</label>
            <input class="input" type="date" name="date_start" value={issue.dateStart} /></div>
          <div class="admin-field"><label>结束日期 · To</label>
            <input class="input" type="date" name="date_end" value={issue.dateEnd} /></div>
        </div>
        <div class="admin-field"><label>标题 · 中文</label>
          <input class="input" name="title_zh" value={issue.titleZh} /></div>
        <div class="admin-field"><label>标题 · English</label>
          <input class="input" name="title_en" value={issue.titleEn} /></div>
        <div class="admin-field"><label>导语 · 中文</label>
          <textarea class="textarea" name="intro_zh" rows="3">{issue.introZh}</textarea></div>
        <div class="admin-field"><label>导语 · English</label>
          <textarea class="textarea" name="intro_en" rows="3">{issue.introEn}</textarea></div>
      </section>

      <!-- Sections -->
      <div class="wk-secs-head">
        <div>
          <div class="wk-eyebrow">本期编排 · Layout</div>
          <h2 class="wk-secs-title">章节 · Sections</h2>
        </div>
        <span class="wk-secs-hint">勾掉的篇目会在保存时移出本期</span>
      </div>

      <div id="sections" class="wk-secs">
        {layout.map((sec, si) => (
          <fieldset class="weekly-section wk-sec" data-si={si}>
            <div class="wk-sec__head">
              <span class="wk-sec__no">{String(si + 1).padStart(2, "0")}</span>
              <div class="wk-sec__titles">
                <input class="input sec-zh" value={sec.heading_zh} placeholder="章节标题 · 中文" />
                <input class="input sec-en" value={sec.heading_en} placeholder="Section title · English" />
              </div>
            </div>
            <ul class="wk-picks">
              {sec.pick_ids.map((pid) => {
                const p = pickById.get(pid);
                return (
                  <li class="pick-row wk-pick" data-pid={pid}>
                    <label class="wk-pick__lbl">
                      <input type="checkbox" class="pick-keep wk-pick__cb" checked />
                      <span class="wk-pick__txt">
                        <span class="wk-pick__zh">{p?.titleZh ?? pid}</span>
                        {p?.titleEn && <span class="wk-pick__en">{p.titleEn}</span>}
                      </span>
                      {p && (() => {
                        const b = categoryBadge(p.category);
                        return (
                        <span class={`badge ${b.className} wk-pick__cat`} style={b.style}>
                          {catLabel[p.category] ?? p.category}
                        </span>
                      )})()}
                    </label>
                  </li>
                );
              })}
            </ul>
          </fieldset>
        ))}
      </div>

      <input type="hidden" name="layout_json" id="layout_json" />
    </form>

    <!-- Action toolbar -->
    <div class="wk-actions">
      <button form="weekly-form" type="submit" class="btn btn-primary">保存草稿</button>
      <!-- Submits weekly-form (incl. the date range) to regenerate so editing
           the dates + re-drafting works in one click. -->
      <button form="weekly-form" type="submit" formaction={`/api/admin/weekly/${id}/regenerate`} class="btn btn-secondary">重新让 AI 起草</button>
      {isDraft ? (
        <form method="POST" action={`/api/admin/weekly/${id}/publish`}>
          <button class="btn btn-publish">发布</button>
        </form>
      ) : (
        <form method="POST" action={`/api/admin/weekly/${id}/unpublish`}>
          <button class="btn btn-secondary">取消发布</button>
        </form>
      )}
      <span class="wk-actions__gap"></span>
      <form method="POST" action={`/api/admin/weekly/${id}/delete`}
            onsubmit="return confirm('删除这一期？篇目会被解除关联。')">
        <button class="btn btn-danger">删除</button>
      </form>
    </div>

    <!-- Email delivery -->
    <section class="card card--canvas wk-email">
      <div class="wk-email__head">
        <h2 class="wk-email__title">邮件投递 · Email</h2>
        <span class="badge badge--coral">{subscriberCount} 位订阅者</span>
      </div>
      <p class="wk-email__note">
        已确认订阅者 <strong>{subscriberCount}</strong> 人
        {sentDate
          ? <span><span class="wk-dot"></span>本期已于 <strong>{sentDate}</strong> 发送</span>
          : <span><span class="wk-dot"></span>本期尚未发送</span>}
      </p>
      {isDraft ? (
        <p class="wk-email__warn">发布之后才能给订阅者发邮件。</p>
      ) : (
        <div class="wk-email__btns">
          <form method="POST" action={`/api/admin/weekly/${id}/send`}
                onsubmit={`return confirm('给 ${subscriberCount} 位已确认订阅者发送这一期？')`}>
            <button class="btn btn-primary">{sentDate ? "给新订阅者补发" : "发送给订阅者"}</button>
          </form>
          {sentDate && (
            <form method="POST" action={`/api/admin/weekly/${id}/send?resend=1`}
                  onsubmit="return confirm('重新发送给所有已确认订阅者（包括已收到的人）？')">
              <button class="btn btn-secondary">全部重发</button>
            </form>
          )}
        </div>
      )}
    </section>

    <!-- HTML export (works for drafts too) -->
    <section class="card card--canvas wk-export">
      <div class="wk-export__head">
        <h2 class="wk-export__title">导出 HTML · Export</h2>
        <span class="wk-export__hint">可打印为 PDF，或复制到邮箱直接发送</span>
      </div>
      <p class="wk-export__note">
        生成单文件 HTML：浏览器里「打印 / 另存为 PDF」，或「复制为邮件 HTML」后粘贴进 Outlook / Mac 邮件 / Gmail。
      </p>
      <div class="wk-export__btns">
        <a class="btn btn-primary" href={`/api/admin/weekly/${id}/export?lang=zh&inline=1`} target="_blank" rel="noopener">预览 / 打印（中文）</a>
        <a class="btn btn-secondary" href={`/api/admin/weekly/${id}/export?lang=en&inline=1`} target="_blank" rel="noopener">Preview / Print (EN)</a>
        <span class="wk-export__sep"></span>
        <a class="btn btn-text" href={`/api/admin/weekly/${id}/export?lang=zh`}>下载 .html（中文）</a>
        <a class="btn btn-text" href={`/api/admin/weekly/${id}/export?lang=en`}>Download .html (EN)</a>
      </div>
    </section>
    </Fragment>
    )}
  </div>

  <script is:inline define:vars={{ isDrafting }}>
    // While the AI is drafting, the editor form isn't rendered — just poll by
    // reloading every 4s until draft_status flips to ready/failed.
    if (isDrafting) {
      setTimeout(() => location.reload(), 4000);
    }

    // Serialize the visible section editor into the hidden layout_json field
    // right before the save form submits. Unchecked picks are dropped. Guarded
    // because the form is absent while drafting.
    const weeklyForm = document.getElementById("weekly-form");
    if (weeklyForm) {
      weeklyForm.addEventListener("submit", () => {
        const sections = [...document.querySelectorAll(".weekly-section")].map((fs) => ({
          heading_zh: fs.querySelector(".sec-zh").value,
          heading_en: fs.querySelector(".sec-en").value,
          pick_ids: [...fs.querySelectorAll(".pick-row")]
            .filter((row) => row.querySelector(".pick-keep").checked)
            .map((row) => row.getAttribute("data-pid")),
        }));
        document.getElementById("layout_json").value = JSON.stringify(sections);
      });
    }
  </script>
</Admin>

<style>
  .wk {
    max-width: 860px;
    padding: var(--s-lg) 0 var(--s-xxl);
  }
  .wk-back {
    display: inline-block;
    margin-bottom: var(--s-md);
  }

  /* Async-drafting placeholder */
  .wk-drafting {
    margin-top: var(--s-xl);
    padding: var(--s-xxl) var(--s-lg);
    text-align: center;
  }
  .wk-drafting__spinner {
    width: 32px; height: 32px;
    margin: 0 auto var(--s-md);
    border: 3px solid var(--c-hairline);
    border-top-color: var(--c-primary);
    border-radius: 50%;
    animation: wk-spin 0.8s linear infinite;
  }
  @keyframes wk-spin { to { transform: rotate(360deg); } }
  .wk-drafting__title { font-size: 20px; margin: 0 0 var(--s-xs); }
  .wk-drafting__hint {
    margin: 0 auto;
    max-width: 48ch;
    color: var(--c-muted);
    font-size: 14px;
    line-height: 1.6;
  }
  .wk-drafting__elapsed {
    margin: var(--s-sm) 0 0;
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--c-muted-soft);
  }

  /* Draft-failed banner */
  .wk-draft-error {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-md);
    flex-wrap: wrap;
    margin-top: var(--s-xl);
    padding: var(--s-md) var(--s-lg);
    border: 1px solid var(--c-border-red, #e0b4b4);
    border-radius: var(--r-lg);
    background: var(--c-surface-red, #fbf0f0);
  }
  .wk-draft-error__title { color: var(--c-text-red-dark, #9b3b3b); font-size: 15px; }
  .wk-draft-error__msg {
    margin: 4px 0 0;
    color: var(--c-body);
    font-size: 13px;
    line-height: 1.5;
    word-break: break-word;
  }
  .wk-draft-error__retry { margin: 0; flex: none; }

  /* Masthead */
  .wk-eyebrow {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: var(--c-muted);
  }
  .wk-head__lede { min-width: 0; }
  .wk-no {
    display: flex;
    align-items: center;
    gap: var(--s-sm);
    flex-wrap: wrap;
    font-size: clamp(30px, 5vw, 42px);
    line-height: 1.05;
    margin: 6px 0 0;
    letter-spacing: -0.01em;
  }
  .wk-no .badge { font-size: 12px; vertical-align: middle; }
  .wk-sub {
    margin: var(--s-xs) 0 0;
    color: var(--c-muted);
    font-size: 14px;
  }
  .wk-arrow { color: var(--c-hairline-soft); padding: 0 2px; }
  .wk-dot {
    display: inline-block;
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--c-muted-soft);
    vertical-align: middle;
    margin: 0 9px;
  }

  .wk-stack { margin-top: var(--s-xl); }
  .wk-stack > * + * { margin-top: var(--s-xl); }

  /* Metadata card */
  .wk-metacard {
    display: flex;
    flex-direction: column;
    gap: var(--s-md);
    padding: var(--s-lg);
  }
  .wk-metacard .admin-field { margin-bottom: 0; }
  .wk-row2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-md);
  }

  /* Sections heading */
  .wk-secs-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--s-md);
  }
  .wk-secs-title {
    font-size: 20px;
    margin: 4px 0 0;
  }
  .wk-secs-hint {
    font-size: 12px;
    color: var(--c-muted);
  }

  .wk-secs {
    display: flex;
    flex-direction: column;
    gap: var(--s-md);
    margin-top: var(--s-md);
  }

  /* Section card */
  .wk-sec {
    margin: 0;
    border: 1px solid var(--c-hairline);
    border-radius: var(--r-lg);
    background: var(--c-surface-soft);
    padding: var(--s-md);
  }
  .wk-sec__head {
    display: flex;
    align-items: center;
    gap: var(--s-sm);
    margin-bottom: var(--s-sm);
  }
  .wk-sec__no {
    flex: none;
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--c-muted);
    background: var(--c-surface-cream-strong);
    border-radius: var(--r-sm);
    padding: 5px 9px;
  }
  .wk-sec__titles {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-xs);
    min-width: 0;
  }
  .wk-sec__titles .input {
    height: 38px;
    font-size: 14px;
    font-weight: 500;
  }

  /* Pick rows */
  .wk-picks { list-style: none; margin: 0; padding: 0; }
  .wk-pick { border-top: 1px solid var(--c-hairline); }
  .wk-pick:first-child { border-top: 0; }
  .wk-pick__lbl {
    display: flex;
    align-items: flex-start;
    gap: var(--s-sm);
    padding: 9px 4px;
    cursor: pointer;
  }
  .wk-pick__cb {
    flex: none;
    margin-top: 3px;
    width: 15px; height: 15px;
    accent-color: var(--c-primary);
    cursor: pointer;
  }
  .wk-pick__txt {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .wk-pick__zh { font-size: 14px; color: var(--c-ink); line-height: 1.4; }
  .wk-pick__en { font-size: 12.5px; color: var(--c-muted); line-height: 1.4; }
  .wk-pick__cat { flex: none; align-self: center; font-size: 11px; }
  /* Dim + strike a pick the editor has unchecked (will drop on save). */
  .wk-pick:has(.pick-keep:not(:checked)) .wk-pick__txt {
    opacity: 0.45;
    text-decoration: line-through;
  }

  /* Action toolbar */
  .wk-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--s-sm);
    margin-top: var(--s-lg);
    padding-top: var(--s-lg);
    border-top: 1px solid var(--c-hairline);
  }
  .wk-actions form { margin: 0; }
  .wk-actions__gap { flex: 1 1 auto; }

  /* Email panel */
  .wk-email {
    margin-top: var(--s-xl);
    padding: var(--s-lg);
  }
  .wk-email__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-md);
    margin-bottom: var(--s-xs);
  }
  .wk-email__title { font-size: 18px; margin: 0; }
  .wk-email__note { margin: 0 0 var(--s-md); color: var(--c-body); font-size: 14px; }
  .wk-email__warn { margin: 0; color: var(--c-text-amber-dark); font-size: 14px; }
  .wk-email__btns { display: flex; flex-wrap: wrap; gap: var(--s-sm); }

  /* Export panel */
  .wk-export {
    margin-top: var(--s-xl);
    padding: var(--s-lg);
  }
  .wk-export__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-md);
    flex-wrap: wrap;
    margin-bottom: var(--s-xs);
  }
  .wk-export__title { font-size: 18px; margin: 0; }
  .wk-export__hint { font-size: 12px; color: var(--c-muted); }
  .wk-export__note { margin: 0 0 var(--s-md); color: var(--c-body); font-size: 14px; line-height: 1.6; }
  .wk-export__btns { display: flex; flex-wrap: wrap; align-items: center; gap: var(--s-sm); }
  .wk-export__sep { flex: 1 1 auto; }

  @media (max-width: 600px) {
    .wk-row2,
    .wk-sec__titles { grid-template-columns: 1fr; }
  }
</style>
