---
export const prerender = false;
import Admin from "~/layouts/Admin.astro";
import { db } from "~/db/client";
import { currentWikiIndex, searchPicks, allTagsWithCounts, latestWikiEvent } from "~/lib/queries";
import { lintAll } from "~/lib/lint";

const env = Astro.locals.runtime.env;
const drizzleDb = db(env.DB);
const [wiki, picks, tags, ev] = await Promise.all([
  currentWikiIndex(drizzleDb),
  searchPicks(drizzleDb, { limit: 200 }),
  allTagsWithCounts(drizzleDb),
  latestWikiEvent(drizzleDb),
]);

const findings = lintAll(picks, tags, wiki);
const generated = wiki?.generated_at ? new Date(wiki.generated_at).toISOString().replace("T", " ").slice(0, 16) : null;

// Live build state from the latest "wiki" lifecycle event. A queued/started
// event with no terminal event for >8 min means the worker died mid-build
// (timeout/eviction) — show it as stuck so the page stops claiming "building…"
// forever and the editor can retry.
const STALE_MS = 8 * 60 * 1000;
const inFlight = ev?.status === "queued" || ev?.status === "started";
const evAgeMs = ev?.created_at ? Date.now() - new Date(ev.created_at).getTime() : Infinity;
const stale = inFlight && evAgeMs > STALE_MS;
const building = inFlight && !stale;
const failed = ev?.status === "failed";
const evTime = ev?.created_at ? new Date(ev.created_at).toISOString().replace("T", " ").slice(0, 16) : null;
const stateLabel =
  stale ? "似乎卡住了 · stuck — worker 超时/被回收，请重试"
  : ev?.status === "queued" ? "已请求，排队中 · queued"
  : ev?.status === "started" ? "正在生成 · building…"
  : ev?.status === "failed" ? "上次重建失败 · failed"
  : ev?.status === "ok" ? "已生成 · done"
  : "尚未生成 · not built yet";

Astro.response.headers.set("Cache-Control", "no-store");
---
<Admin title="导览 · Wiki">
  <main id="main" class="q2">
    <div class="container" style="max-width: 920px">
      <header class="q2-header">
        <h1>导览 · Wiki</h1>
        <p class="q2-header__sub">
          已发布的精选是原始数据；重建会用 LLM 把它们综合成一张主题地图，<strong>立即上线</strong>到 <a href="/wiki">/wiki</a>。
        </p>
      </header>

      <section style="margin-block: 1.5rem">
        <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap">
          <form method="POST" action="/api/admin/wiki/rebuild">
            <button type="submit" class="btn btn--primary">重建导览 · Rebuild</button>
          </form>
          {building && (
            <span class="t-code" style="color: #b8860b">● {stateLabel}{evTime ? ` · ${evTime}` : ""} — 本页每 4 秒自动刷新</span>
          )}
          {stale && (
            <span class="t-code" style="color: #c0392b">⚠ {stateLabel}{evTime ? ` · 始于 ${evTime}` : ""}</span>
          )}
          {!inFlight && failed && (
            <span class="t-code" style="color: #c0392b">✕ {stateLabel}{evTime ? ` · ${evTime}` : ""}</span>
          )}
          {!inFlight && !failed && wiki && (
            <span class="t-code text-muted-soft">
              ✓ 生成于 {generated} · {wiki.picks_count} 篇 · {wiki.topics.length} 个主题 · {wiki.model ?? "?"}
            </span>
          )}
          {!inFlight && !failed && !wiki && (
            <span class="t-code text-muted-soft">尚未生成 · 点击重建（异步，几秒后自动刷新）</span>
          )}
        </div>

        {failed && ev?.message && (
          <pre style="margin-top: 12px; padding: 12px; background: #fdecea; color: #611a15; border-radius: 6px; white-space: pre-wrap; word-break: break-word; font-size: 0.82rem; line-height: 1.5">失败原因 · reason:
{ev.message}</pre>
        )}
      </section>

      {building && <script is:inline>{`setTimeout(function(){location.reload()},4000)`}</script>}

      {wiki && (
        <section style="margin-block: 1.5rem">
          <h2 style="font-size: 1rem; margin-bottom: 8px">主题预览 · Topics</h2>
          <p style="opacity: 0.8; margin-bottom: 12px">{wiki.intro_en}</p>
          {wiki.topics.map((t) => (
            <div style="margin-bottom: 14px">
              <strong>{t.title_en}</strong> <span class="text-muted-soft">/ {t.title_zh}</span>
              <span class="t-code text-muted-soft"> · {t.pick_slugs.length} picks</span>
            </div>
          ))}
        </section>
      )}

      <section style="margin-block: 1.5rem">
        <h2 style="font-size: 1rem; margin-bottom: 8px">
          Lint {findings.length > 0 ? `· ${findings.length} 项` : "· ✓ clean"}
        </h2>
        {findings.length === 0 ? (
          <p class="text-muted-soft">没有发现问题。No corpus or wiki issues.</p>
        ) : (
          <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem">
            <thead>
              <tr style="text-align: left; border-bottom: 1px solid var(--hairline, #ddd)">
                <th style="padding: 6px 8px">check</th>
                <th style="padding: 6px 8px">slug</th>
                <th style="padding: 6px 8px">detail</th>
              </tr>
            </thead>
            <tbody>
              {findings.map((f) => (
                <tr style="border-bottom: 1px solid var(--hairline, #eee)">
                  <td style="padding: 6px 8px"><code>{f.check}</code></td>
                  <td style="padding: 6px 8px">{f.slug ?? "—"}</td>
                  <td style="padding: 6px 8px">{f.detail}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </section>
    </div>
  </main>
</Admin>
