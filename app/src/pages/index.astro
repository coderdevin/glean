---
export const prerender = false;
import Site from "~/layouts/Site.astro";
import ArticleCard from "~/components/ArticleCard.astro";
import { db } from "~/db/client";
import { homeFeed } from "~/lib/queries";
import { siteTz, todayInSiteTz } from "~/lib/datetime";
import { issueNo, weeklyDateRange } from "~/lib/weeklyFormat";

const env = Astro.locals.runtime.env;
const today = todayInSiteTz(siteTz(env));
const feed = await homeFeed(db(env.DB), today);

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=30, s-maxage=60, stale-while-revalidate=120",
);

const weekNum = Math.ceil(
  ((Date.now() - Date.UTC(new Date().getUTCFullYear(), 0, 1)) /
    (1000 * 60 * 60 * 24) +
    new Date(Date.UTC(new Date().getUTCFullYear(), 0, 1)).getUTCDay()) /
    7,
);
const todayLabel = new Date(feed.date).toLocaleDateString("en-US", {
  weekday: "short",
  month: "short",
  day: "numeric",
  year: "numeric",
});
// Host shown in the hero curl example. Derived from Astro.site so it tracks
// the deployed domain (set via SITE_URL) instead of a hardcoded placeholder.
const apiHost = new URL(Astro.site?.toString() ?? "https://your-domain.example").host;
---
<Site
  title="Glean · 拾遗 — A bilingual tech zine"
  description="Daily picks worth reading. Weekly issue every Monday. Hand-curated, human-reviewed."
>
  <section class="hero">
    <div class="container">
      <div class="grid grid--hero">
        <div class="stack stack--lg">
          <span class="eyebrow">
            <span class="dot"></span>
            <span class="lang-zh">{new Date().getFullYear()} 年 第 {weekNum} 周 · {feed.date}</span>
            <span class="lang-en">Week {weekNum} · {todayLabel}</span>
          </span>
          <h1 class="t-display-xl">
            <span class="lang-zh">每天 2-3 条值得读的</span>
            <span class="lang-en">2–3 picks worth reading every day</span>
          </h1>
          <p class="t-body-md text-body" style="max-width: 56ch">
            <span class="lang-zh">双语技术刊 · 周一汇总成一期。</span>
            <span class="lang-en">A bilingual tech zine. Weekly digest on Mondays.</span>
          </p>
          <div class="row" style="gap: 12px; flex-wrap: wrap">
            {feed.weekly && (
              <a href={`/weekly/${feed.weekly.number}`} class="btn btn-primary">
                <span class="lang-zh">读最新周刊 →</span>
                <span class="lang-en">Read latest weekly →</span>
              </a>
            )}
            <a href="/daily" class="btn btn-secondary">
              <span class="lang-zh">看今日日刊</span>
              <span class="lang-en">See today’s daily</span>
            </a>
            <a href="#subscribe" class="btn btn-text" style="padding: 0 8px">
              <span class="lang-zh">开刊先通知你 ↓</span>
              <span class="lang-en">Get notified at launch ↓</span>
            </a>
          </div>
          <p class="t-body-sm text-muted">
            <span class="lang-zh">想投一条？<a href="/submit">提交链接</a> · 编辑会审。</span>
            <span class="lang-en">Got something? <a href="/submit">Submit a link</a> · editor will review.</span>
          </p>
        </div>

        <aside class="card card--dark" style="padding: 28px">
          <div class="row row--between" style="margin-bottom: 16px; color: var(--c-on-dark-soft)">
            <div class="traffic-lights" aria-hidden="true">
              <span class="traffic-lights__dot traffic-lights__dot--close"></span>
              <span class="traffic-lights__dot traffic-lights__dot--minimize"></span>
              <span class="traffic-lights__dot traffic-lights__dot--maximize"></span>
            </div>
            <span class="t-code text-muted-soft">~/work/glean</span>
          </div>
          <pre class="t-code" style="margin: 0; color: var(--c-on-dark); line-height: 1.65; white-space: pre-wrap; word-break: break-all"><span style="color: var(--c-accent-amber)">$</span> curl -X POST {apiHost}/api/submit <span style="color: var(--c-muted-soft)">\</span>
    -H <span style="color: var(--c-accent-teal)">"Content-Type: application/json"</span> <span style="color: var(--c-muted-soft)">\</span>
    -d <span style="color: var(--c-accent-teal)">'&#123;"url":"https://blog.cloudflare.com/durable-objects-2026/",
        "note":"DO 终于支持跨地域副本",
        "submitter":"anon"&#125;'</span>

<span style="color: var(--c-on-dark-soft)">→</span> 303 /submit/success?id=<span style="color: var(--c-accent-amber)">01HXR7…</span>
<span style="color: var(--c-on-dark-soft)">→</span> queued for analysis
</pre>
          <div style="margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--scrim-light-8); display: flex; gap: 12px; align-items: center; color: var(--c-on-dark-soft)">
            <span class="badge badge--on-dark">JSON API</span>
            <span class="t-body-sm">
              <span class="lang-zh">无需登录 · 每 IP 每小时 10 条</span>
              <span class="lang-en">No auth · 10 per IP per hour</span>
            </span>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {feed.picks.length > 0 && (
    <section class="section section--tight">
      <div class="container">
        <div class="section-head">
          <div>
            <span class="eyebrow">
              <span class="lang-zh">今日日刊</span>
              <span class="lang-en">Today</span>
            </span>
            <h2 class="section-head__title" style="margin-top: 8px">
              <span class="lang-zh">今日 · {feed.picks.length} 条</span>
              <span class="lang-en">Today · {feed.picks.length} {feed.picks.length === 1 ? "pick" : "picks"}</span>
            </h2>
          </div>
          <div class="section-head__meta">
            <a href={`/daily/${feed.date}`} class="btn btn-text">
              <span class="lang-zh">查看全部 →</span>
              <span class="lang-en">See all →</span>
            </a>
          </div>
        </div>

        <div class="daily-strip">
          {feed.picks.map((pick) => (
            <ArticleCard pick={pick} />
          ))}
        </div>
      </div>
    </section>
  )}

  {feed.weekly && (
    <section class="section--showcase">
      <div class="container">
        <div class="section-head">
          <div>
            <span class="eyebrow">
              <span class="lang-zh">最新周刊</span>
              <span class="lang-en">This week’s issue</span>
            </span>
            <h2 class="section-head__title" style="margin-top: 8px">
              <span class="lang-zh">每周一</span>
              <span class="lang-en">Mondays</span>
            </h2>
          </div>
          <div class="section-head__meta">
            <a href="/weekly" class="btn btn-text">
              <span class="lang-zh">查看历史期号 →</span>
              <span class="lang-en">All past issues →</span>
            </a>
          </div>
        </div>

        <div class="grid grid--cols-2">
          <a class="issue-cover" href={`/weekly/${feed.weekly.number}`} style="text-decoration: none">
            <span class="issue-cover__no">{issueNo(feed.weekly.number)} · CURRENT</span>
            <h3 class="issue-cover__title">
              <span class="lang-zh">{feed.weekly.title_zh}</span>
              <span class="lang-en">{feed.weekly.title_en}</span>
            </h3>
            <p class="issue-cover__lead">
              <span class="lang-zh">{feed.weekly.intro_zh}</span>
              <span class="lang-en">{feed.weekly.intro_en}</span>
            </p>
            <div style="margin-top: 16px; display: flex; gap: 8px; flex-wrap: wrap">
              <span class="badge badge--on-dark"><span class="lang-zh">{feed.weekly.pick_count} 篇</span><span class="lang-en">{feed.weekly.pick_count} picks</span></span>
              <span class="badge badge--on-dark">{weeklyDateRange(feed.weekly.date_start, feed.weekly.date_end)}</span>
            </div>
          </a>

          <div class="card card--canvas" style="padding: 28px">
            <div class="t-caption-up text-muted" style="margin-bottom: 16px">
              <span class="lang-zh">本期亮点</span>
              <span class="lang-en">Inside this issue</span>
            </div>
            <p class="t-body-sm text-muted">
              <a href={`/weekly/${feed.weekly.number}`}>
                <span class="lang-zh">读完整一期 → {feed.weekly.pick_count} 篇</span>
                <span class="lang-en">Read the full issue → {feed.weekly.pick_count} picks</span>
              </a>
            </p>
            <hr class="hairline" />
            <a href={`/weekly/${feed.weekly.number}`} class="btn btn-secondary" style="width: 100%">
              <span class="lang-zh">读完整一期 →</span>
              <span class="lang-en">Read the full issue →</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <section id="subscribe" class="section--tight">
    <div class="container">
      <div class="subscribe-card">
        <div class="subscribe-card__lead">
          <span class="eyebrow">
            <span class="lang-zh">周刊筹备中</span>
            <span class="lang-en">Weekly · coming soon</span>
          </span>
          <h2 class="balance">
            <span class="lang-zh">每周一早上 · 一封邮件</span>
            <span class="lang-en">Mondays · one email</span>
          </h2>
          <p>
            <span class="lang-zh">上周最有意思的 6–10 条 + 一段编辑首语。留个邮箱，开刊第一时间通知你，没有广告。</span>
            <span class="lang-en">Past week’s top 6–10 picks + a short editor’s note. Leave your email and we’ll tell you the moment it launches. No ads.</span>
          </p>
        </div>
        <form class="subscribe-card__form" data-subscribe-form>
          <input type="hidden" name="source" value="hero" />
          <div class="subscribe-card__row">
            <input
              type="email"
              name="email"
              class="input"
              placeholder="you@example.com"
              aria-label="Email address"
              required
            />
            <button type="submit" class="btn btn-primary">
              <span class="subscribe-card__cta-default">
                <span class="lang-zh">通知我</span>
                <span class="lang-en">Notify me</span>
              </span>
              <span class="subscribe-card__cta-done" aria-hidden="true">
                <span class="lang-zh">✓ 已登记</span>
                <span class="lang-en">✓ On the list</span>
              </span>
            </button>
          </div>
          <p class="subscribe-card__status" role="status" aria-live="polite"></p>
          <div class="subscribe-card__channels">
            <a href="/rss/daily.xml">RSS · Daily</a>
            <a href="/rss/weekly.xml">RSS · Weekly</a>
          </div>
        </form>
      </div>
    </div>
  </section>
</Site>
