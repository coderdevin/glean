---
export const prerender = false;
import Site from "~/layouts/Site.astro";
import ArticleCard from "~/components/ArticleCard.astro";
import Lang from "~/components/Lang.astro";
import { db } from "~/db/client";
import { homeFeed } from "~/lib/queries";
import { siteTz, todayInSiteTz } from "~/lib/datetime";
import { issueNo, weeklyDateRange } from "~/lib/weeklyFormat";
import { localizedPath } from "~/lib/i18n";

const env = Astro.locals.runtime.env;
const today = todayInSiteTz(siteTz(env));
const feed = await homeFeed(db(env.DB), today);

const lang = Astro.locals.lang ?? "zh";
const L = (p: string): string => localizedPath(p, lang);

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=30, s-maxage=60, stale-while-revalidate=120",
);

const weekNum = Math.ceil(
  ((Date.now() - Date.UTC(new Date().getUTCFullYear(), 0, 1)) /
    (1000 * 60 * 60 * 24) +
    new Date(Date.UTC(new Date().getUTCFullYear(), 0, 1)).getUTCDay()) /
    7,
);
const todayLabel = new Date(feed.date).toLocaleDateString("en-US", {
  weekday: "short",
  month: "short",
  day: "numeric",
  year: "numeric",
});
// Host shown in the hero curl example. Derived from Astro.site so it tracks
// the deployed domain (set via SITE_URL) instead of a hardcoded placeholder.
const apiHost = new URL(Astro.site?.toString() ?? "https://your-domain.example").host;
---
<Site
  title="Glean · 拾遗 — A bilingual tech zine"
  description="Daily picks worth reading. Weekly issue every Monday. Hand-curated, human-reviewed."
>
  <section class="hero">
    <div class="container">
      <div class="grid grid--hero">
        <div class="stack stack--lg">
          <span class="eyebrow">
            <span class="dot"></span>
            <Lang>
              <Fragment slot="zh">{new Date().getFullYear()} 年 第 {weekNum} 周 · {feed.date}</Fragment>
              <Fragment slot="en">Week {weekNum} · {todayLabel}</Fragment>
            </Lang>
          </span>
          <h1 class="t-display-xl">
            <Lang zh="每天 2-3 条值得读的" en="2–3 picks worth reading every day" />
          </h1>
          <p class="t-body-md text-body" style="max-width: 56ch">
            <Lang zh="双语技术刊 · 周一汇总成一期。" en="A bilingual tech zine. Weekly digest on Mondays." />
          </p>
          <div class="row" style="gap: 12px; flex-wrap: wrap">
            {feed.weekly && (
              <a href={L(`/weekly/${feed.weekly.number}`)} class="btn btn-primary">
                <Lang zh="读最新周刊 →" en="Read latest weekly →" />
              </a>
            )}
            <a href={L("/daily")} class="btn btn-secondary">
              <Lang zh="看今日日刊" en="See today’s daily" />
            </a>
            <a href="#subscribe" class="btn btn-text" style="padding: 0 8px">
              <Lang zh="开刊先通知你 ↓" en="Get notified at launch ↓" />
            </a>
          </div>
          <p class="t-body-sm text-muted">
            <Lang>
              <Fragment slot="zh">想投一条？<a href={L("/submit")}>提交链接</a> · 编辑会审。</Fragment>
              <Fragment slot="en">Got something? <a href={L("/submit")}>Submit a link</a> · editor will review.</Fragment>
            </Lang>
          </p>
        </div>

        <aside class="card card--dark" style="padding: 28px">
          <div class="row row--between" style="margin-bottom: 16px; color: var(--c-on-dark-soft)">
            <div class="traffic-lights" aria-hidden="true">
              <span class="traffic-lights__dot traffic-lights__dot--close"></span>
              <span class="traffic-lights__dot traffic-lights__dot--minimize"></span>
              <span class="traffic-lights__dot traffic-lights__dot--maximize"></span>
            </div>
            <span class="t-code text-muted-soft">~/work/glean</span>
          </div>
          <pre class="t-code" style="margin: 0; color: var(--c-on-dark); line-height: 1.65; white-space: pre-wrap; word-break: break-all"><span style="color: var(--c-accent-amber)">$</span> curl -X POST {apiHost}/api/submit <span style="color: var(--c-muted-soft)">\</span>
    -H <span style="color: var(--c-accent-teal)">"Content-Type: application/json"</span> <span style="color: var(--c-muted-soft)">\</span>
    -d <span style="color: var(--c-accent-teal)">'&#123;"url":"https://blog.cloudflare.com/durable-objects-2026/",
        "note":"DO 终于支持跨地域副本",
        "submitter":"anon"&#125;'</span>

<span style="color: var(--c-on-dark-soft)">→</span> 303 /submit/success?id=<span style="color: var(--c-accent-amber)">01HXR7…</span>
<span style="color: var(--c-on-dark-soft)">→</span> queued for analysis
</pre>
          <div style="margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--scrim-light-8); display: flex; gap: 12px; align-items: center; color: var(--c-on-dark-soft)">
            <span class="badge badge--on-dark">JSON API</span>
            <span class="t-body-sm">
              <Lang zh="无需登录 · 每 IP 每小时 10 条" en="No auth · 10 per IP per hour" />
            </span>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {feed.picks.length > 0 && (
    <section class="section section--tight">
      <div class="container">
        <div class="section-head">
          <div>
            <span class="eyebrow">
              <Lang zh="今日日刊" en="Today" />
            </span>
            <h2 class="section-head__title" style="margin-top: 8px">
              <Lang>
                <Fragment slot="zh">今日 · {feed.picks.length} 条</Fragment>
                <Fragment slot="en">Today · {feed.picks.length} {feed.picks.length === 1 ? "pick" : "picks"}</Fragment>
              </Lang>
            </h2>
          </div>
          <div class="section-head__meta">
            <a href={L(`/daily/${feed.date}`)} class="btn btn-text">
              <Lang zh="查看全部 →" en="See all →" />
            </a>
          </div>
        </div>

        <div class="daily-strip">
          {feed.picks.map((pick) => (
            <ArticleCard pick={pick} />
          ))}
        </div>
      </div>
    </section>
  )}

  {feed.weekly && (
    <section class="section--showcase">
      <div class="container">
        <div class="section-head">
          <div>
            <span class="eyebrow">
              <Lang zh="最新周刊" en="This week’s issue" />
            </span>
            <h2 class="section-head__title" style="margin-top: 8px">
              <Lang zh="每周一" en="Mondays" />
            </h2>
          </div>
          <div class="section-head__meta">
            <a href={L("/weekly")} class="btn btn-text">
              <Lang zh="查看历史期号 →" en="All past issues →" />
            </a>
          </div>
        </div>

        <div class="grid grid--cols-2">
          <a class="issue-cover" href={L(`/weekly/${feed.weekly.number}`)} style="text-decoration: none">
            <span class="issue-cover__no">{issueNo(feed.weekly.number)} · CURRENT</span>
            <h3 class="issue-cover__title">
              <Lang zh={feed.weekly.title_zh} en={feed.weekly.title_en} />
            </h3>
            <p class="issue-cover__lead">
              <Lang zh={feed.weekly.intro_zh} en={feed.weekly.intro_en} />
            </p>
            <div style="margin-top: 16px; display: flex; gap: 8px; flex-wrap: wrap">
              <span class="badge badge--on-dark"><Lang><Fragment slot="zh">{feed.weekly.pick_count} 篇</Fragment><Fragment slot="en">{feed.weekly.pick_count} picks</Fragment></Lang></span>
              <span class="badge badge--on-dark">{weeklyDateRange(feed.weekly.date_start, feed.weekly.date_end)}</span>
            </div>
          </a>

          <div class="card card--canvas issue-contents">
            <div class="t-caption-up text-muted issue-contents__head">
              <Lang zh="本期目录" en="Contents" />
            </div>
            {feed.weeklyToc.length > 0 ? (
              <ol class="issue-contents__list">
                {feed.weeklyToc.map((g, i) => (
                  <li class="issue-contents__group">
                    <div class="issue-contents__sec">
                      <span class="issue-contents__sec-no">{String(i + 1).padStart(2, "0")}</span>
                      <span class="issue-contents__sec-title">
                        <Lang zh={g.zh} en={g.en} />
                      </span>
                      <span class="issue-contents__sec-count">{g.items.length}</span>
                    </div>
                    <ul class="issue-contents__items">
                      {g.items.map((it) => (
                        <li>
                          <a class="issue-contents__item" href={L(`/a/${it.slug}`)}>
                            <Lang zh={it.title_zh} en={it.title_en} />
                          </a>
                        </li>
                      ))}
                    </ul>
                  </li>
                ))}
              </ol>
            ) : (
              <p class="t-body-sm text-muted">
                <Lang zh="本期内容整理中。" en="Contents coming together." />
              </p>
            )}
            <a href={L(`/weekly/${feed.weekly.number}`)} class="btn btn-secondary issue-contents__cta">
              <Lang zh="读完整一期 →" en="Read the full issue →" />
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <section id="subscribe" class="section--tight">
    <div class="container">
      <div class="subscribe-card">
        <div class="subscribe-card__lead">
          <span class="eyebrow">
            <Lang zh="周刊筹备中" en="Weekly · coming soon" />
          </span>
          <h2 class="balance">
            <Lang zh="每周一早上 · 一封邮件" en="Mondays · one email" />
          </h2>
          <p>
            <Lang zh="上周最有意思的 6–10 条 + 一段编辑首语。留个邮箱，开刊第一时间通知你，没有广告。" en="Past week’s top 6–10 picks + a short editor’s note. Leave your email and we’ll tell you the moment it launches. No ads." />
          </p>
        </div>
        <form class="subscribe-card__form" data-subscribe-form>
          <input type="hidden" name="source" value="hero" />
          <div class="subscribe-card__row">
            <input
              type="email"
              name="email"
              class="input"
              placeholder="you@example.com"
              aria-label="Email address"
              required
            />
            <button type="submit" class="btn btn-primary">
              <span class="subscribe-card__cta-default">
                <Lang zh="通知我" en="Notify me" />
              </span>
              <span class="subscribe-card__cta-done" aria-hidden="true">
                <Lang zh="✓ 已登记" en="✓ On the list" />
              </span>
            </button>
          </div>
          <p class="subscribe-card__status" role="status" aria-live="polite"></p>
          <div class="subscribe-card__channels">
            <a href={`/rss/daily.xml${lang === "en" ? "?lang=en" : ""}`}>RSS · Daily</a>
            <a href={`/rss/weekly.xml${lang === "en" ? "?lang=en" : ""}`}>RSS · Weekly</a>
          </div>
        </form>
      </div>
    </div>
  </section>
</Site>
