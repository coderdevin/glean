---
export const prerender = false;
import Site from "~/layouts/Site.astro";
import Lang from "~/components/Lang.astro";
import { localizedPath } from "~/lib/i18n";
import { db } from "~/db/client";
import { allTagsWithCounts, allCategories } from "~/lib/queries";
import { categoryBadge } from "~/lib/category";

const lang = Astro.locals.lang ?? "zh";
const L = (p: string): string => localizedPath(p, lang);

const env = Astro.locals.runtime.env;
const allTags = await allTagsWithCounts(db(env.DB));
const cats = await allCategories(db(env.DB));

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, s-maxage=600, stale-while-revalidate=1800",
);

// Group tags by their (self-growing) category family. Labels come from the
// categories table; a family with no category row falls back to its slug.
// Families are ordered by total pick count desc so the busiest territory leads.
const catName = new Map(cats.map((c) => [c.slug, { zh: c.nameZh, en: c.nameEn }]));
const families = [...new Set(allTags.map((t) => t.family))];
const grouped = families
  .map((key) => ({
    key,
    zh: catName.get(key)?.zh ?? key,
    en: catName.get(key)?.en ?? key,
    tags: allTags
      .filter((t) => t.family === key)
      .sort((a, b) => b.count - a.count || a.slug.localeCompare(b.slug)),
  }))
  .sort(
    (a, b) =>
      b.tags.reduce((s, t) => s + t.count, 0) - a.tags.reduce((s, t) => s + t.count, 0) ||
      a.key.localeCompare(b.key),
  );
const totalPicks = allTags.reduce((s, t) => s + t.count, 0);
---
<Site
  title="所有标签 · All tags — Glean · 拾遗"
  description="按主题浏览所有 Glean 收录的精选 · Browse every Glean pick by tag."
>
  <section class="page-banner">
    <div class="container">
      <span class="eyebrow"><Lang zh="标签" en="Tags" /></span>
      <h1 style="margin-top: 8px">
        <Lang zh="所有标签" en="All tags" />
      </h1>
      <p style="max-width: 60ch; margin-top: 12px" class="text-body">
        <Lang>
          <Fragment slot="zh">按主题浏览每一条收录。共 {allTags.length} 个标签 · {totalPicks} 条精选。</Fragment>
          <Fragment slot="en">
            Browse every pick by topic. {allTags.length} {allTags.length === 1 ? "tag" : "tags"}
            {" · "}{totalPicks} {totalPicks === 1 ? "pick" : "picks"}.
          </Fragment>
        </Lang>
      </p>
    </div>
  </section>

  <section class="section--tight">
    <div class="container">
      {allTags.length === 0 && (
        <div class="prose-block" style="text-align: center; padding: 48px 0">
          <p>
            <Lang zh="还没有标签。第一条精选上线时会自动建立标签。" en="No tags yet. Tags appear automatically when the first pick lands." />
          </p>
        </div>
      )}
      {grouped.map((group) => (
        group.tags.length > 0 && (
          <div style="margin-top: 32px">
            <div class="t-caption-up text-muted" style="margin-bottom: 12px">
              <Lang zh={group.zh} en={group.en} />
            </div>
            <div class="tag-grid">
              {group.tags.map((t) => {
                const b = categoryBadge(t.family);
                return (
                <a
                  href={L(`/tag/${t.slug}`)}
                  class={`badge ${b.className} tag-grid__item${t.count === 0 ? " is-empty" : ""}`}
                  style={`text-decoration: none;${b.style}`}
                >
                  <Lang zh={t.name_zh ?? undefined} en={t.name_en ?? undefined} />
                  <span class="tag-grid__count">· {t.count}</span>
                </a>
              )})}
            </div>
          </div>
        )
      ))}
    </div>
  </section>
</Site>

<style>
  .tag-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag-grid__item {
    font-size: 13px;
    padding: 6px 10px;
    transition: opacity 0.12s ease;
  }
  .tag-grid__item.is-empty {
    opacity: 0.45;
  }
  .tag-grid__item:hover {
    opacity: 1;
    text-decoration: none;
  }
  .tag-grid__count {
    margin-left: 6px;
    font-family: var(--f-mono);
    font-size: 11px;
    opacity: 0.75;
  }
</style>
