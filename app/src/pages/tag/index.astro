---
export const prerender = false;
import Site from "~/layouts/Site.astro";
import { db } from "~/db/client";
import { allTagsWithCounts } from "~/lib/queries";
import { CATEGORIES } from "~/db/schema";

const env = Astro.locals.runtime.env;
const allTags = await allTagsWithCounts(db(env.DB));

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, s-maxage=600, stale-while-revalidate=1800",
);

const FAMILY_LABELS: Record<(typeof CATEGORIES)[number], { zh: string; en: string }> = {
  infra: { zh: "基础设施", en: "Infrastructure" },
  data: { zh: "数据 / AI", en: "Data / AI" },
  code: { zh: "工程 / 代码", en: "Engineering / Code" },
};

const grouped = CATEGORIES.map((key) => ({
  key,
  zh: FAMILY_LABELS[key].zh,
  en: FAMILY_LABELS[key].en,
  tags: allTags
    .filter((t) => t.family === key)
    .sort((a, b) => b.count - a.count || a.slug.localeCompare(b.slug)),
}));
const totalPicks = allTags.reduce((s, t) => s + t.count, 0);
---
<Site
  title="所有标签 · All tags — Glean · 拾遗"
  description="按主题浏览所有 Glean 收录的精选 · Browse every Glean pick by tag."
>
  <section class="page-banner">
    <div class="container">
      <span class="eyebrow"><span class="lang-zh">标签</span><span class="lang-en">Tags</span></span>
      <h1 style="margin-top: 8px">
        <span class="lang-zh">所有标签</span>
        <span class="lang-en">All tags</span>
      </h1>
      <p style="max-width: 60ch; margin-top: 12px" class="text-body">
        <span class="lang-zh">按主题浏览每一条收录。共 {allTags.length} 个标签 · {totalPicks} 条精选。</span>
        <span class="lang-en">
          Browse every pick by topic. {allTags.length} {allTags.length === 1 ? "tag" : "tags"}
          {" · "}{totalPicks} {totalPicks === 1 ? "pick" : "picks"}.
        </span>
      </p>
    </div>
  </section>

  <section class="section--tight">
    <div class="container">
      {allTags.length === 0 && (
        <div class="prose-block" style="text-align: center; padding: 48px 0">
          <p>
            <span class="lang-zh">还没有标签。第一条精选上线时会自动建立标签。</span>
            <span class="lang-en">No tags yet. Tags appear automatically when the first pick lands.</span>
          </p>
        </div>
      )}
      {grouped.map((group) => (
        group.tags.length > 0 && (
          <div style="margin-top: 32px">
            <div class="t-caption-up text-muted" style="margin-bottom: 12px">
              <span class="lang-zh">{group.zh}</span>
              <span class="lang-en">{group.en}</span>
            </div>
            <div class="tag-grid">
              {group.tags.map((t) => (
                <a
                  href={`/tag/${t.slug}`}
                  class={`badge badge--cat-${t.family} tag-grid__item${t.count === 0 ? " is-empty" : ""}`}
                  style="text-decoration: none"
                >
                  <span class="lang-zh">{t.name_zh}</span>
                  <span class="lang-en">{t.name_en}</span>
                  <span class="tag-grid__count">· {t.count}</span>
                </a>
              ))}
            </div>
          </div>
        )
      ))}
    </div>
  </section>
</Site>

<style>
  .tag-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag-grid__item {
    font-size: 13px;
    padding: 6px 10px;
    transition: opacity 0.12s ease;
  }
  .tag-grid__item.is-empty {
    opacity: 0.45;
  }
  .tag-grid__item:hover {
    opacity: 1;
    text-decoration: none;
  }
  .tag-grid__count {
    margin-left: 6px;
    font-family: var(--f-mono);
    font-size: 11px;
    opacity: 0.75;
  }
</style>
