---
export const prerender = false;
import Site from "~/layouts/Site.astro";
import Turnstile from "~/components/Turnstile.astro";

Astro.response.headers.set("Cache-Control", "no-store");
const submitError = Astro.url.searchParams.get("error");
const errorLabels: Record<string, { zh: string; en: string }> = {
  bad_url:     { zh: "URL 看起来不太对。",                en: "That URL didn't look right." },
  rate_limit:  { zh: "提交太频繁了。每小时最多 10 条。",  en: "Too many submissions. 10 per hour, per IP." },
  turnstile:   { zh: "人类验证失败。请刷新重试。",         en: "Human check failed. Please refresh and retry." },
  honeypot:    { zh: "看起来像 bot。",                    en: "Bot detected." },
  server:      { zh: "服务器出错。请稍后重试。",           en: "Server error. Try again later." },
};
const errorCopy = submitError ? errorLabels[submitError] : null;
// Repopulate the form after an error redirect so the visitor doesn't lose
// what they typed (the POST → 303 → GET round-trip would otherwise blank it).
const prefillUrl = Astro.url.searchParams.get("url") ?? "";
const prefillNote = Astro.url.searchParams.get("note") ?? "";
// Host shown in the curl example — derived from Astro.site (SITE_URL) so it
// matches the deployed domain rather than a hardcoded placeholder.
const apiHost = new URL(Astro.site?.toString() ?? "https://your-domain.example").host;
---
<Site
  title="提交链接 · Submit — Glean · 拾遗"
  description="Paste a URL. AI drafts. Editor approves."
  noindex
>
  <section class="page-banner">
    <div class="container">
      <span class="eyebrow">
        <span class="lang-zh">投一条链接</span>
        <span class="lang-en">Submit a link</span>
      </span>
      <h1 style="margin-top: 12px">
        <span class="lang-zh">提交链接</span>
        <span class="lang-en">Submit a link</span>
      </h1>
      <p>
        <span class="lang-zh">贴一条 URL · AI 起草 · 我审完发。</span>
        <span class="lang-en">Paste a URL · AI drafts · I approve and ship.</span>
      </p>
    </div>
  </section>

  <section class="section--tight">
    <div class="container">
      <div class="grid grid--cols-2" style="gap: 48px">
        <form class="card card--canvas" style="padding: 36px" action="/api/submit" method="post" novalidate>
          <div class="stack stack--lg">
            {errorCopy && (
              <div role="alert" class="card" style="padding: 12px 16px; background: color-mix(in oklch, var(--c-error) 12%, var(--c-canvas)); border-left: 4px solid var(--c-error);">
                <span class="lang-zh">{errorCopy.zh}</span>
                <span class="lang-en">{errorCopy.en}</span>
              </div>
            )}

            <div class="field">
              <label for="url">
                <span class="lang-zh">文章链接 URL <span style="color: var(--c-primary)">*</span></span>
                <span class="lang-en">Article URL <span style="color: var(--c-primary)">*</span></span>
              </label>
              <input
                id="url"
                name="url"
                type="url"
                class="input"
                placeholder="https://blog.cloudflare.com/durable-objects-2026/"
                value={prefillUrl}
                required
              />
              <span class="hint">
                <span class="lang-zh">中英皆可 · 自动翻译。</span>
                <span class="lang-en">CN or EN · auto-translated.</span>
              </span>
            </div>

            <div class="field">
              <label for="note">
                <span class="lang-zh">为什么推荐？(可选)</span>
                <span class="lang-en">Why do you recommend it? (optional)</span>
              </label>
              <textarea
                id="note"
                name="note"
                class="textarea"
                placeholder="一句话告诉编辑这条值得读的理由。"
                maxlength="500"
              >{prefillNote}</textarea>
              <span class="hint">
                <span class="lang-zh">只给编辑 · 不公开。</span>
                <span class="lang-en">Editor only · not public.</span>
              </span>
            </div>

            <Turnstile action="submit" />

            <input type="text" name="website" class="honeypot" tabindex="-1" autocomplete="off" />

            <div class="row" style="gap: 12px; align-items: center">
              <button type="submit" class="btn btn-primary">
                <span class="lang-zh">提交 →</span>
                <span class="lang-en">Submit →</span>
              </button>
              <span class="t-body-sm text-muted-soft">
                <span class="lang-zh">无需登录 · 每 IP 每小时 10 条</span>
                <span class="lang-en">No login · 10 per IP per hour</span>
              </span>
            </div>
          </div>
        </form>

        <aside class="stack stack--xl">
          <div>
            <span class="eyebrow">
              <span class="lang-zh">之后发生什么</span>
              <span class="lang-en">What happens next</span>
            </span>
            <h2 class="t-display-sm" style="margin-top: 12px">
              <span class="lang-zh">从粘贴到上刊 · 4 步</span>
              <span class="lang-en">Paste to publish · 4 steps</span>
            </h2>
          </div>

          <ol class="stack stack--lg" style="list-style: none; margin: 0; padding: 0">
            <li style="display: grid; grid-template-columns: 36px 1fr; gap: 12px; align-items: start">
              <span class="badge badge--coral" style="height: 24px; justify-content: center; min-width: 28px">1</span>
              <div>
                <div class="t-title-md">
                  <span class="lang-zh">入队</span>
                  <span class="lang-en">Queued</span>
                </div>
                <p class="t-body-sm text-body" style="margin: 4px 0 0">
                  <span class="lang-zh">URL 落库 · 给你一个查询 ID。</span>
                  <span class="lang-en">URL stored · you get a lookup ID.</span>
                </p>
              </div>
            </li>
            <li style="display: grid; grid-template-columns: 36px 1fr; gap: 12px; align-items: start">
              <span class="badge badge--coral" style="height: 24px; justify-content: center; min-width: 28px">2</span>
              <div>
                <div class="t-title-md">
                  <span class="lang-zh">AI 加工</span>
                  <span class="lang-en">AI pass</span>
                </div>
                <p class="t-body-sm text-body" style="margin: 4px 0 0">
                  <span class="lang-zh">抓正文 · 双语 · 要点 · 标签 · 一句点评。~30 秒。</span>
                  <span class="lang-en">Extract · translate · bullets · tags · note. ~30s.</span>
                </p>
              </div>
            </li>
            <li style="display: grid; grid-template-columns: 36px 1fr; gap: 12px; align-items: start">
              <span class="badge badge--coral" style="height: 24px; justify-content: center; min-width: 28px">3</span>
              <div>
                <div class="t-title-md">
                  <span class="lang-zh">人工审核</span>
                  <span class="lang-en">Human review</span>
                </div>
                <p class="t-body-sm text-body" style="margin: 4px 0 0">
                  <span class="lang-zh">我读一眼 · 可改可拒 · 通常 1 小时内。</span>
                  <span class="lang-en">I read, edit, or reject · usually within an hour.</span>
                </p>
              </div>
            </li>
            <li style="display: grid; grid-template-columns: 36px 1fr; gap: 12px; align-items: start">
              <span class="badge badge--coral" style="height: 24px; justify-content: center; min-width: 28px">4</span>
              <div>
                <div class="t-title-md">
                  <span class="lang-zh">进当日日刊</span>
                  <span class="lang-en">Lands in today’s daily</span>
                </div>
                <p class="t-body-sm text-body" style="margin: 4px 0 0">
                  <span class="lang-zh">通过即公开 · 高分会进下周一的周刊。</span>
                  <span class="lang-en">Public on approval · top picks land in Monday’s weekly.</span>
                </p>
              </div>
            </li>
          </ol>

          <div class="card card--dark" style="padding: 24px; margin-bottom: 0">
            <div class="t-caption-up" style="color: var(--c-accent-amber); margin-bottom: 8px">
              <span class="lang-zh">命令行用户</span>
              <span class="lang-en">Terminal-first?</span>
            </div>
            <pre class="t-code" style="margin: 0; color: var(--c-on-dark); line-height: 1.65; white-space: pre-wrap; word-break: break-all"><span style="color: var(--c-accent-amber)">$</span> curl -X POST {apiHost}/api/submit <span style="color: var(--c-muted-soft)">\</span>
    -H <span style="color: var(--c-accent-teal)">"Content-Type: application/json"</span> <span style="color: var(--c-muted-soft)">\</span>
    -d <span style="color: var(--c-accent-teal)">'&#123;"url":"https://example.com/article"&#125;'</span></pre>
            <p class="t-body-sm" style="margin: 10px 0 0; color: var(--c-on-dark-soft)">
              <span class="lang-zh">无需登录 · 每 IP 每小时 10 条</span>
              <span class="lang-en">No auth · 10 per IP per hour</span>
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Site>
