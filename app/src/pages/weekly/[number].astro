---
export const prerender = false;
import Site from "~/layouts/Site.astro";
import NotFound from "~/components/NotFound.astro";
import SubscribeCard from "~/components/SubscribeCard.astro";
import { db } from "~/db/client";
import { allWeeklies, picksForWeekly, weeklyByNumber } from "~/lib/queries";
import { issueNo, weeklyDateRange, weeklyReadDuration } from "~/lib/weeklyFormat";
import type { LayoutSection } from "~/lib/weekly";

const numberStr = Astro.params.number;
const number = numberStr ? Number(numberStr) : NaN;
const valid = Number.isInteger(number) && number > 0;

const env = Astro.locals.runtime.env;
const drizzleDb = db(env.DB);
const issue = valid ? await weeklyByNumber(drizzleDb, number) : null;

// Everything below is computed only when the issue exists; the template guards
// on `issue` and renders <NotFound> (with a 404 status) otherwise.
let picks: Awaited<ReturnType<typeof picksForWeekly>> = [];
let toc: { zh: string; en: string; items: { pick: (typeof picks)[number]; n: number }[] }[] = [];
let readMinutes = 0;
let weekNum: number | null = null;
type Neighbor = { number: number; titleZh: string; titleEn: string };
let older: Neighbor | null = null; // 上一期 (smaller number)
let newer: Neighbor | null = null; // 下一期 (larger number)

if (issue) {
  picks = await picksForWeekly(drizzleDb, issue.id);
  readMinutes = picks.reduce((a, p) => a + p.read_minutes, 0);

  // Build [heading, picks[]] groups in layout order; collect leftovers.
  const layout: LayoutSection[] = issue.layoutJson ? JSON.parse(issue.layoutJson) : [];
  const pickById = new Map(picks.map((p) => [p.id, p]));
  type Group = { zh: string; en: string; list: typeof picks };
  const groups: Group[] = [];
  const seen = new Set<string>();
  for (const sec of layout) {
    const list = sec.pick_ids.map((id) => pickById.get(id)).filter(Boolean) as typeof picks;
    list.forEach((p) => seen.add(p.id));
    if (list.length > 0) groups.push({ zh: sec.heading_zh, en: sec.heading_en, list });
  }
  const leftover = picks.filter((p) => !seen.has(p.id));
  if (leftover.length > 0) groups.push({ zh: "其他", en: "More", list: leftover });

  // 1-based running index so the TOC (rendered first) and body anchors (#p-N) match.
  let _n = 0;
  toc = groups.map((g) => ({
    zh: g.zh,
    en: g.en,
    items: g.list.map((p) => ({ pick: p, n: ++_n })),
  }));

  weekNum = (() => {
    if (!issue.dateStart) return null;
    const d = new Date(issue.dateStart + "T00:00:00Z");
    const oneJan = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
    return Math.ceil(((d.getTime() - oneJan.getTime()) / 86400000 + oneJan.getUTCDay() + 1) / 7);
  })();

  // Prev/next neighbors. allWeeklies is published-only, desc by number, so the
  // older issue sits at idx+1 and the newer at idx-1.
  const all = await allWeeklies(drizzleDb);
  const idx = all.findIndex((w) => w.number === issue.number);
  if (idx >= 0) {
    const o = all[idx + 1];
    const n = all[idx - 1];
    if (o) older = { number: o.number, titleZh: o.titleZh, titleEn: o.titleEn };
    if (n) newer = { number: n.number, titleZh: n.titleZh, titleEn: n.titleEn };
  }
}

if (!issue) {
  Astro.response.status = 404;
} else {
  Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=60, s-maxage=86400, stale-while-revalidate=86400",
  );
}
const readDur = weeklyReadDuration(readMinutes);
---
<Site
  title={issue ? `${issueNo(issue.number)} — ${issue.titleEn} · Glean · 拾遗` : "未找到 · Not found — Glean · 拾遗"}
  description={issue?.introEn ?? ""}
  noindex={!issue}
>
  {!issue ? (
    <NotFound kind="weekly" />
  ) : (
  <Fragment>
  <div class="reading-progress" aria-hidden="true"><span class="reading-progress__bar" id="reading-progress-bar"></span></div>
  <section class="container" style="padding-top: 32px">
    <a href="/weekly" class="btn btn-text" style="margin-bottom: 16px; display: inline-block">
      <span class="lang-zh">← 所有期号</span><span class="lang-en">← All issues</span>
    </a>
    <div class="issue-masthead" data-no={String(issue.number).padStart(3, "0")}>
      <span class="issue-masthead__eyebrow">
        <span>{issueNo(issue.number)}</span>
        {weekNum && (
          <>
            <span style="opacity: 0.5">/</span>
            <span>
              <span class="lang-zh">{issue.dateStart.slice(0,4)} 第 {weekNum} 周</span>
              <span class="lang-en">Week {weekNum}, {issue.dateStart.slice(0,4)}</span>
            </span>
          </>
        )}
      </span>
      <h1 class="issue-masthead__title">
        <span class="lang-zh">{issue.titleZh}</span>
        <span class="lang-en">{issue.titleEn}</span>
      </h1>
      <p class="issue-masthead__lead">
        <span class="lang-zh">{issue.introZh}</span>
        <span class="lang-en">{issue.introEn}</span>
      </p>
      <div class="issue-masthead__meta">
        <span class="badge">{weeklyDateRange(issue.dateStart, issue.dateEnd)}</span>
        <span class="badge"><span class="lang-zh">{picks.length} 篇</span><span class="lang-en">{picks.length} picks</span></span>
        {readMinutes > 0 && (
          <span class="badge"><span class="lang-zh">{readDur.zh}</span><span class="lang-en">{readDur.en}</span></span>
        )}
      </div>
    </div>
  </section>

  <div class:list={["container", "issue-layout", toc.length > 0 && "issue-layout--sidebar"]}>
    {toc.length > 0 && (
      <aside class="issue-toc" aria-label="本期目录 · Contents">
        <details class="issue-toc__panel" open>
          <summary class="issue-toc__summary">
            <span><span class="lang-zh">本期目录</span><span class="lang-en">Contents</span></span>
            <span class="issue-toc__now" data-toc-now></span>
            <span class="issue-toc__summary-meta">{picks.length}<span class="issue-toc__chev" aria-hidden="true">▾</span></span>
          </summary>
          <nav class="issue-toc__sticky">
            <ol class="issue-toc__list">
              {toc.map((g, i) => (
                <li class="issue-toc__group">
                  <a class="issue-toc__link" href={`#sec-${i}`} data-toc={`sec-${i}`}>
                    <span class="issue-toc__num">{String(i + 1).padStart(2, "0")}</span>
                    <span class="issue-toc__text">
                      <span class="lang-zh">{g.zh}</span>
                      <span class="lang-en">{g.en}</span>
                    </span>
                    <span class="issue-toc__count">{g.items.length}</span>
                  </a>
                  <ul class="issue-toc__sublist">
                    {g.items.map((it) => (
                      <li>
                        <a class="issue-toc__sublink" href={`#p-${it.n}`} title={it.pick.title_zh}>
                          <span class="issue-toc__subnum">{String(it.n).padStart(2, "0")}</span>
                          <span class="issue-toc__subtext">
                            <span class="lang-zh">{it.pick.title_zh}</span>
                            <span class="lang-en">{it.pick.title_en}</span>
                          </span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </li>
              ))}
            </ol>
          </nav>
        </details>
      </aside>
    )}

    <main class="issue-content">
    {toc.map((g, catIdx) => (
      <section id={`sec-${catIdx}`} class="issue-section">
        <div class="issue-section__head">
          <div>
            <div class="issue-section__eyebrow">
              <span class="lang-zh">章节 {String(catIdx + 1).padStart(2, "0")}</span>
              <span class="lang-en">Section {String(catIdx + 1).padStart(2, "0")}</span>
            </div>
            <h2 class="issue-section__title">
              <span class="lang-zh">{g.zh}</span>
              <span class="lang-en">{g.en}</span>
            </h2>
          </div>
          <span class="issue-section__count">{g.items.length} / {picks.length}</span>
        </div>

        <div class="pick-list">
          {g.items.map((it) => {
            const pick = it.pick;
            const idx = String(it.n).padStart(2, "0");
            return (
              <article class="pick-item" id={`p-${it.n}`}>
                <div class="pick-item__meta">
                  <span>{pick.source_host}</span>
                  <span>·</span>
                  <span>{pick.read_minutes} min</span>
                </div>
                <span class="pick-item__index">{idx}</span>
                <div class="pick-item__main">
                  <h3 class="pick-item__title">
                    <a href={`/a/${pick.slug}`}>
                      <span class="lang-zh">{pick.title_zh}<span class="alt">{pick.title_en}</span></span>
                      <span class="lang-en">{pick.title_en}<span class="alt">{pick.title_zh}</span></span>
                    </a>
                  </h3>
                  <p class="pick-item__note">
                    <span class="lang-zh">{pick.summary_zh}</span>
                    <span class="lang-en">{pick.summary_en}</span>
                  </p>
                  {(pick.editor_note_zh || pick.editor_note_en) && (
                    <div class="pick-item__editor">
                      <span class="pick-item__editor-label">Editor</span>
                      <span class="pick-item__editor-text">
                        <span class="lang-zh">{pick.editor_note_zh}</span>
                        <span class="lang-en">{pick.editor_note_en}</span>
                      </span>
                    </div>
                  )}
                  <div class="pick-item__footer">
                    <div class="pick-item__tags">
                      {pick.tags.map((t) => (
                        <a class="pick-item__tag" href={`/tag/${t.slug}`}>{t.name_en}</a>
                      ))}
                    </div>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    ))}

    {picks.length === 0 && (
      <div class="prose-block" style="text-align: center; padding: 48px 0">
        <p>
          <span class="lang-zh">这期周刊尚未编入内容。</span>
          <span class="lang-en">This issue has no picks yet.</span>
        </p>
      </div>
    )}
    </main>
  </div>

  {(older || newer) && (
    <nav class="container issue-pager" aria-label="期号导航 · Issues">
      {older ? (
        <a class="issue-pager__link issue-pager__link--prev" href={`/weekly/${older.number}`}>
          <span class="issue-pager__dir">
            <span class="lang-zh">← 上一期 · {issueNo(older.number)}</span>
            <span class="lang-en">← Prev · {issueNo(older.number)}</span>
          </span>
          <span class="issue-pager__title">
            <span class="lang-zh">{older.titleZh}</span>
            <span class="lang-en">{older.titleEn}</span>
          </span>
        </a>
      ) : <span class="issue-pager__slot"></span>}
      <a class="issue-pager__all" href="/weekly">
        <span class="lang-zh">所有期号</span><span class="lang-en">All issues</span>
      </a>
      {newer ? (
        <a class="issue-pager__link issue-pager__link--next" href={`/weekly/${newer.number}`}>
          <span class="issue-pager__dir">
            <span class="lang-zh">下一期 · {issueNo(newer.number)} →</span>
            <span class="lang-en">Next · {issueNo(newer.number)} →</span>
          </span>
          <span class="issue-pager__title">
            <span class="lang-zh">{newer.titleZh}</span>
            <span class="lang-en">{newer.titleEn}</span>
          </span>
        </a>
      ) : <span class="issue-pager__slot"></span>}
    </nav>
  )}

  <SubscribeCard source="weekly-issue" />

  <button class="to-top" id="to-top" type="button" aria-label="回到顶部 · Back to top">↑</button>

  <script is:inline>
    (function () {
      const links = [...document.querySelectorAll(".issue-toc__link")];
      const sections = [...document.querySelectorAll(".issue-section[id]")];
      const nowLabel = document.querySelector("[data-toc-now]");

      // --- Scroll-spy: highlight the current section in the sidebar TOC, and
      //     surface its name in the (mobile) collapsed-TOC summary. ---
      if (links.length && sections.length) {
        const byId = new Map(links.map((a) => [a.getAttribute("data-toc"), a]));
        let current = null;
        const activate = (id) => {
          if (id === current) return;
          current = id;
          links.forEach((a) => a.classList.toggle("is-active", a.getAttribute("data-toc") === id));
          const a = byId.get(id);
          if (nowLabel && a) {
            const t = a.querySelector(".issue-toc__text");
            nowLabel.textContent = t ? t.textContent.trim() : "";
          }
        };
        const obs = new IntersectionObserver(
          (entries) => {
            const inView = entries
              .filter((e) => e.isIntersecting)
              .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
            if (inView[0]) activate(inView[0].target.id);
          },
          { rootMargin: "-20% 0px -65% 0px", threshold: 0 },
        );
        sections.forEach((s) => obs.observe(s));
        // TOC stays expanded by default; the mobile summary toggles it.
      }

      // --- Reading progress bar + back-to-top, throttled via rAF. ---
      const bar = document.getElementById("reading-progress-bar");
      const toTop = document.getElementById("to-top");
      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const max = document.documentElement.scrollHeight - window.innerHeight;
          const p = max > 0 ? Math.min(1, window.scrollY / max) : 0;
          if (bar) bar.style.transform = `scaleX(${p})`;
          if (toTop) toTop.classList.toggle("is-visible", window.scrollY > window.innerHeight);
          ticking = false;
        });
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
      if (toTop) {
        toTop.addEventListener("click", () =>
          window.scrollTo({ top: 0, behavior: "smooth" }),
        );
      }
    })();
  </script>
  </Fragment>
  )}
</Site>
