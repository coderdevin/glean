---
export const prerender = false;
import Site from "~/layouts/Site.astro";
import { db } from "~/db/client";
import { picksForWeekly, weeklyByNumber } from "~/lib/queries";
import type { LayoutSection } from "~/lib/weekly";

const numberStr = Astro.params.number;
const number = numberStr ? Number(numberStr) : NaN;
if (!Number.isInteger(number) || number <= 0) {
  return new Response("Not found", { status: 404 });
}

const env = Astro.locals.runtime.env;
const drizzleDb = db(env.DB);
const issue = await weeklyByNumber(drizzleDb, number);
if (!issue) return new Response("Not found", { status: 404 });

const picks = await picksForWeekly(drizzleDb, issue.id);
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, s-maxage=86400, stale-while-revalidate=86400",
);

const layout: LayoutSection[] = issue.layoutJson ? JSON.parse(issue.layoutJson) : [];
const pickById = new Map(picks.map((p) => [p.id, p]));
const readMinutes = picks.reduce((a, p) => a + p.read_minutes, 0);

// Build [heading, picks[]] groups in layout order; collect leftovers.
type Group = { zh: string; en: string; list: typeof picks };
const groups: Group[] = [];
const seen = new Set<string>();
for (const sec of layout) {
  const list = sec.pick_ids.map((id) => pickById.get(id)).filter(Boolean) as typeof picks;
  list.forEach((p) => seen.add(p.id));
  if (list.length > 0) groups.push({ zh: sec.heading_zh, en: sec.heading_en, list });
}
const leftover = picks.filter((p) => !seen.has(p.id));
if (leftover.length > 0) groups.push({ zh: "其他", en: "More", list: leftover });

const weekNum = (() => {
  if (!issue.dateStart) return null;
  const d = new Date(issue.dateStart + "T00:00:00Z");
  const oneJan = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
  return Math.ceil(((d.getTime() - oneJan.getTime()) / 86400000 + oneJan.getUTCDay() + 1) / 7);
})();

// Annotate each pick with a running 1-based index so the TOC (rendered first)
// and the body anchors (#p-N) reference the same numbers.
let _n = 0;
const toc = groups.map((g) => ({
  zh: g.zh,
  en: g.en,
  items: g.list.map((p) => ({ pick: p, n: ++_n })),
}));
---
<Site
  title={`#${String(issue.number).padStart(3, "0")} — ${issue.titleEn} · Glean · 拾遗`}
  description={issue.introEn}
>
  <section class="container" style="padding-top: 32px">
    <a href="/weekly" class="btn btn-text" style="margin-bottom: 16px; display: inline-block">
      <span class="lang-zh">← 所有期号</span><span class="lang-en">← All issues</span>
    </a>
    <div class="issue-masthead" data-no={String(issue.number).padStart(3, "0")}>
      <span class="issue-masthead__eyebrow">
        <span>Issue · {String(issue.number).padStart(3, "0")}</span>
        {weekNum && (
          <>
            <span style="opacity: 0.5">/</span>
            <span>
              <span class="lang-zh">{issue.dateStart.slice(0,4)} 第 {weekNum} 周</span>
              <span class="lang-en">Week {weekNum}, {issue.dateStart.slice(0,4)}</span>
            </span>
          </>
        )}
      </span>
      <h1 class="issue-masthead__title">
        <span class="lang-zh">{issue.titleZh}</span>
        <span class="lang-en">{issue.titleEn}</span>
      </h1>
      <p class="issue-masthead__lead">
        <span class="lang-zh">{issue.introZh}</span>
        <span class="lang-en">{issue.introEn}</span>
      </p>
      <div class="issue-masthead__meta">
        <span class="badge"><span class="lang-zh">{issue.dateStart} → {issue.dateEnd}</span><span class="lang-en">{issue.dateStart} – {issue.dateEnd}</span></span>
        <span class="badge"><span class="lang-zh">{picks.length} 篇</span><span class="lang-en">{picks.length} picks</span></span>
        {readMinutes > 0 && (
          <span class="badge"><span class="lang-zh">约 {readMinutes} 分钟</span><span class="lang-en">~{readMinutes} min</span></span>
        )}
      </div>
    </div>
  </section>

  <div class:list={["container", "issue-layout", groups.length > 0 && "issue-layout--sidebar"]}>
    {groups.length > 0 && (
      <aside class="issue-toc" aria-label="本期目录 · Contents">
        <details class="issue-toc__panel" open>
          <summary class="issue-toc__summary">
            <span><span class="lang-zh">本期目录</span><span class="lang-en">Contents</span></span>
            <span class="issue-toc__summary-meta">{picks.length}<span class="issue-toc__chev" aria-hidden="true">▾</span></span>
          </summary>
          <nav class="issue-toc__sticky">
            <ol class="issue-toc__list">
              {toc.map((g, i) => (
                <li class="issue-toc__group">
                  <a class="issue-toc__link" href={`#sec-${i}`} data-toc={`sec-${i}`}>
                    <span class="issue-toc__num">{String(i + 1).padStart(2, "0")}</span>
                    <span class="issue-toc__text">
                      <span class="lang-zh">{g.zh}</span>
                      <span class="lang-en">{g.en}</span>
                    </span>
                    <span class="issue-toc__count">{g.items.length}</span>
                  </a>
                  <ul class="issue-toc__sublist">
                    {g.items.map((it) => (
                      <li>
                        <a class="issue-toc__sublink" href={`#p-${it.n}`} title={it.pick.title_zh}>
                          <span class="issue-toc__subnum">{String(it.n).padStart(2, "0")}</span>
                          <span class="issue-toc__subtext">
                            <span class="lang-zh">{it.pick.title_zh}</span>
                            <span class="lang-en">{it.pick.title_en}</span>
                          </span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </li>
              ))}
            </ol>
          </nav>
        </details>
      </aside>
    )}

    <main class="issue-content">
    {toc.map((g, catIdx) => (
      <section id={`sec-${catIdx}`} class="issue-section">
        <div class="issue-section__head">
          <div>
            <div class="issue-section__eyebrow">
              <span class="lang-zh">章节 {String(catIdx + 1).padStart(2, "0")}</span>
              <span class="lang-en">Section {String(catIdx + 1).padStart(2, "0")}</span>
            </div>
            <h2 class="issue-section__title">
              <span class="lang-zh">{g.zh}</span>
              <span class="lang-en">{g.en}</span>
            </h2>
          </div>
          <span class="issue-section__count">{g.items.length} / {picks.length}</span>
        </div>

        <div class="pick-list">
          {g.items.map((it) => {
            const pick = it.pick;
            const idx = String(it.n).padStart(2, "0");
            return (
              <article class="pick-item" id={`p-${it.n}`}>
                <span class="pick-item__index">{idx}</span>
                <div class="pick-item__main">
                  <div class="pick-item__meta">
                    <span>{pick.source_host}</span>
                    <span>·</span>
                    <span>{pick.read_minutes} min</span>
                  </div>
                  <h3 class="pick-item__title">
                    <a href={`/a/${pick.slug}`}>
                      <span class="lang-zh">{pick.title_zh}<span class="alt">{pick.title_en}</span></span>
                      <span class="lang-en">{pick.title_en}<span class="alt">{pick.title_zh}</span></span>
                    </a>
                  </h3>
                  <p class="pick-item__note">
                    <span class="lang-zh">{pick.summary_zh}</span>
                    <span class="lang-en">{pick.summary_en}</span>
                  </p>
                  {(pick.editor_note_zh || pick.editor_note_en) && (
                    <div class="pick-item__editor">
                      <span class="pick-item__editor-label">Editor</span>
                      <span class="pick-item__editor-text">
                        <span class="lang-zh">{pick.editor_note_zh}</span>
                        <span class="lang-en">{pick.editor_note_en}</span>
                      </span>
                    </div>
                  )}
                  <div class="pick-item__footer">
                    <div class="pick-item__tags">
                      {pick.tags.map((t) => (
                        <a class="pick-item__tag" href={`/tag/${t.slug}`}>{t.name_en}</a>
                      ))}
                    </div>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    ))}

    {picks.length === 0 && (
      <div class="prose-block" style="text-align: center; padding: 48px 0">
        <p>
          <span class="lang-zh">这期周刊尚未编入内容。</span>
          <span class="lang-en">This issue has no picks yet.</span>
        </p>
      </div>
    )}
    </main>
  </div>

  <script is:inline>
    // Scroll-spy: highlight the sidebar TOC link for the section currently in
    // the upper viewport band. Pure IntersectionObserver, no deps.
    (function () {
      const links = [...document.querySelectorAll(".issue-toc__link")];
      if (links.length === 0) return;
      const byId = new Map(links.map((a) => [a.getAttribute("data-toc"), a]));
      const sections = [...document.querySelectorAll(".issue-section[id]")];
      if (sections.length === 0) return;
      let current = null;
      const activate = (id) => {
        if (id === current) return;
        current = id;
        links.forEach((a) => a.classList.toggle("is-active", a.getAttribute("data-toc") === id));
      };
      const obs = new IntersectionObserver(
        (entries) => {
          const inView = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (inView[0]) activate(inView[0].target.id);
        },
        { rootMargin: "-20% 0px -65% 0px", threshold: 0 },
      );
      sections.forEach((s) => obs.observe(s));
      // The TOC is expanded by default everywhere (the <details> stays `open`);
      // on mobile the summary still lets the reader collapse it manually.
    })();
  </script>
</Site>
