---
export const prerender = false;
import Site from "~/layouts/Site.astro";
import Lang from "~/components/Lang.astro";
import SubscribeCard from "~/components/SubscribeCard.astro";
import { db } from "~/db/client";
import { allWeeklies } from "~/lib/queries";
import { issueNo, weeklyDateRange, weeklyReadDuration } from "~/lib/weeklyFormat";
import { localizedPath } from "~/lib/i18n";

const lang = Astro.locals.lang ?? "zh";
const L = (p: string): string => localizedPath(p, lang);
const env = Astro.locals.runtime.env;
const issues = await allWeeklies(db(env.DB));
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, s-maxage=300, stale-while-revalidate=600",
);
const fmtPubZh = (d: Date | null) => {
  if (!d) return "";
  const dt = new Date(d);
  return `${dt.getUTCMonth() + 1} 月 ${dt.getUTCDate()} 日`;
};
const fmtPubEn = (d: Date | null) => {
  if (!d) return "";
  return new Date(d).toLocaleDateString("en-US", { month: "short", day: "numeric" });
};
---
<Site
  title="所有周刊 · All weeklies — Glean · 拾遗"
  description="One issue every Monday, grouped by theme."
>
  <section class="page-banner">
    <div class="container">
      <span class="eyebrow">
        {issues.length > 0 ? (
          <Lang><Fragment slot="zh">{issues.length} 期 · 每周一</Fragment><Fragment slot="en">{issues.length} {issues.length === 1 ? "issue" : "issues"} · Mondays</Fragment></Lang>
        ) : (
          <Lang zh="首期筹备中 · 每周一" en="First issue coming · Mondays" />
        )}
      </span>
      <h1 style="margin-top: 12px">
        <Lang zh="每周一一期 · 按主题分章" en="One issue every Monday · grouped by theme" />
      </h1>
    </div>
  </section>

  <section class="section--tight" style="padding-top: 16px">
    <div class="container">
      {issues.length === 0 && (
        <div class="prose-block" style="text-align: center; padding: 48px 0">
          <p>
            <Lang zh="还没有发布的周刊。第一期会在周一发布。" en="No weekly issues yet. Issue 001 will land on a Monday." />
          </p>
        </div>
      )}
      <div class="issue-list">
        {issues.map((iss, i) => (
          <a class="issue-list-card" href={L(`/weekly/${iss.number}`)}>
            <div class="issue-list-card__eyebrow">
              <span>{issueNo(iss.number)}</span>
              {i === 0 && (
                <span class="issue-list-card__latest">
                  <Lang zh="最新" en="Latest" />
                </span>
              )}
              <span class="issue-list-card__date">
                {weeklyDateRange(iss.dateStart, iss.dateEnd)}
                {iss.publishedAt && (
                  <>
                    {" · "}
                    <Lang><Fragment slot="zh">{fmtPubZh(iss.publishedAt)}发布</Fragment><Fragment slot="en">pub {fmtPubEn(iss.publishedAt)}</Fragment></Lang>
                  </>
                )}
              </span>
            </div>
            <div class="issue-list-card__no" aria-hidden="true">{String(iss.number).padStart(3, "0")}</div>
            <div class="issue-list-card__body">
              <h2 class="issue-list-card__title">
                <Lang zh={iss.titleZh} en={iss.titleEn} />
              </h2>
              <p class="issue-list-card__lead">
                <Lang zh={iss.introZh} en={iss.introEn} />
              </p>
              <div class="issue-list-card__meta">
                <span>
                  <Lang><Fragment slot="zh">{iss.pick_count} 篇</Fragment><Fragment slot="en">{iss.pick_count} picks</Fragment></Lang>
                </span>
                {iss.section_count > 0 && (
                  <>
                    <span class="dot-sep"></span>
                    <span>
                      <Lang><Fragment slot="zh">{iss.section_count} 章</Fragment><Fragment slot="en">{iss.section_count} sections</Fragment></Lang>
                    </span>
                  </>
                )}
                {iss.read_minutes > 0 && (
                  <>
                    <span class="dot-sep"></span>
                    <span>
                      <Lang zh={weeklyReadDuration(iss.read_minutes).zh} en={weeklyReadDuration(iss.read_minutes).en} />
                    </span>
                  </>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <SubscribeCard source="weekly-archive" />
</Site>
