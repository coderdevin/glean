---
export const prerender = false;
import Site from "~/layouts/Site.astro";
import SubscribeCard from "~/components/SubscribeCard.astro";
import { db } from "~/db/client";
import { allWeeklies } from "~/lib/queries";
import { issueNo, weeklyDateRange, weeklyReadDuration } from "~/lib/weeklyFormat";

const env = Astro.locals.runtime.env;
const issues = await allWeeklies(db(env.DB));
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, s-maxage=300, stale-while-revalidate=600",
);
const fmtPubZh = (d: Date | null) => {
  if (!d) return "";
  const dt = new Date(d);
  return `${dt.getUTCMonth() + 1} 月 ${dt.getUTCDate()} 日`;
};
const fmtPubEn = (d: Date | null) => {
  if (!d) return "";
  return new Date(d).toLocaleDateString("en-US", { month: "short", day: "numeric" });
};
---
<Site
  title="所有周刊 · All weeklies — Glean · 拾遗"
  description="One issue every Monday, grouped by theme."
>
  <section class="page-banner">
    <div class="container">
      <span class="eyebrow">
        {issues.length > 0 ? (
          <>
            <span class="lang-zh">{issues.length} 期 · 每周一</span>
            <span class="lang-en">{issues.length} {issues.length === 1 ? "issue" : "issues"} · Mondays</span>
          </>
        ) : (
          <>
            <span class="lang-zh">首期筹备中 · 每周一</span>
            <span class="lang-en">First issue coming · Mondays</span>
          </>
        )}
      </span>
      <h1 style="margin-top: 12px">
        <span class="lang-zh">每周一一期 · 按主题分章</span>
        <span class="lang-en">One issue every Monday · grouped by theme</span>
      </h1>
    </div>
  </section>

  <section class="section--tight" style="padding-top: 16px">
    <div class="container">
      {issues.length === 0 && (
        <div class="prose-block" style="text-align: center; padding: 48px 0">
          <p>
            <span class="lang-zh">还没有发布的周刊。第一期会在周一发布。</span>
            <span class="lang-en">No weekly issues yet. Issue 001 will land on a Monday.</span>
          </p>
        </div>
      )}
      <div class="issue-list">
        {issues.map((iss, i) => (
          <a class="issue-list-card" href={`/weekly/${iss.number}`}>
            <div class="issue-list-card__eyebrow">
              <span>{issueNo(iss.number)}</span>
              {i === 0 && (
                <span class="issue-list-card__latest">
                  <span class="lang-zh">最新</span><span class="lang-en">Latest</span>
                </span>
              )}
              <span class="issue-list-card__date">
                {weeklyDateRange(iss.dateStart, iss.dateEnd)}
                {iss.publishedAt && (
                  <>
                    {" · "}
                    <span class="lang-zh">{fmtPubZh(iss.publishedAt)}发布</span>
                    <span class="lang-en">pub {fmtPubEn(iss.publishedAt)}</span>
                  </>
                )}
              </span>
            </div>
            <div class="issue-list-card__no" aria-hidden="true">{String(iss.number).padStart(3, "0")}</div>
            <div class="issue-list-card__body">
              <h2 class="issue-list-card__title">
                <span class="lang-zh">{iss.titleZh}</span>
                <span class="lang-en">{iss.titleEn}</span>
              </h2>
              <p class="issue-list-card__lead">
                <span class="lang-zh">{iss.introZh}</span>
                <span class="lang-en">{iss.introEn}</span>
              </p>
              <div class="issue-list-card__meta">
                <span>
                  <span class="lang-zh">{iss.pick_count} 篇</span>
                  <span class="lang-en">{iss.pick_count} picks</span>
                </span>
                {iss.section_count > 0 && (
                  <>
                    <span class="dot-sep"></span>
                    <span>
                      <span class="lang-zh">{iss.section_count} 章</span>
                      <span class="lang-en">{iss.section_count} sections</span>
                    </span>
                  </>
                )}
                {iss.read_minutes > 0 && (
                  <>
                    <span class="dot-sep"></span>
                    <span>
                      <span class="lang-zh">{weeklyReadDuration(iss.read_minutes).zh}</span>
                      <span class="lang-en">{weeklyReadDuration(iss.read_minutes).en}</span>
                    </span>
                  </>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <SubscribeCard source="weekly-archive" />
</Site>
