---
export const prerender = false;
import Site from "~/layouts/Site.astro";
import Lang from "~/components/Lang.astro";
import { localizedPath } from "~/lib/i18n";
import { eq } from "drizzle-orm";
import { db } from "~/db/client";
import { submissions } from "~/db/schema";
import { successView } from "~/lib/submissionStatus";

const lang = Astro.locals.lang ?? "zh";
const L = (p: string): string => localizedPath(p, lang);

const id = Astro.url.searchParams.get("id");
if (!id || !/^[0-9A-HJKMNP-TV-Z]{26}$/.test(id)) {
  return Astro.redirect(L("/submit"), 303);
}

const env = Astro.locals.runtime.env;
const rows = await db(env.DB)
  .select()
  .from(submissions)
  .where(eq(submissions.id, id))
  .limit(1);
const row = rows[0];
if (!row) return Astro.redirect(L("/submit"), 303);

Astro.response.headers.set("Cache-Control", "no-store");

// Initial view rendered server-side; the client polls /api/submit/status and
// updates this in place (no full-page refresh) until the status is terminal.
const view = successView(row);
const { stepIndex, isTerminal, headline: headlineCopy, sub: subCopy } = view;
const isDup = Astro.url.searchParams.get("dup") === "1";

const rel = (d: Date) => {
  const s = Math.max(0, Math.floor((Date.now() - new Date(d).getTime()) / 1000));
  if (s < 60) return `${s}s ago`;
  if (s < 3600) return `${Math.floor(s / 60)}m ago`;
  if (s < 86400) return `${Math.floor(s / 3600)}h ago`;
  return `${Math.floor(s / 86400)}d ago`;
};

---
<Site title="收到 · Queued — Glean" noindex>
  <div class="container" style="padding-top: 64px; padding-bottom: 96px">
    <a href={L("/submit")} class="btn btn-text" style="margin-bottom: 24px; display: inline-block">
      <Lang zh="← 再提交一条" en="← Submit another" />
    </a>

    {isDup && (
      <div style="margin-bottom: 16px; padding: 10px 14px; border: 1px solid var(--c-hairline); border-radius: 6px; background: var(--c-surface-card); font-size: 14px; color: var(--c-muted)">
        <Lang zh="这条链接之前已经提交过 · 跳到原投稿状态" en="This URL was already submitted · showing the original" />
      </div>
    )}

    <noscript>
      <p style="text-align: center; margin-bottom: 16px" class="t-body-sm text-muted">
        <Lang>
          <Fragment slot="zh">开启 JavaScript 可自动刷新状态，或 <a href={L(`/submit/success?id=${row.id}`)}>手动刷新</a>。</Fragment>
          <Fragment slot="en">Enable JavaScript for live status, or <a href={L(`/submit/success?id=${row.id}`)}>refresh</a>.</Fragment>
        </Lang>
      </p>
    </noscript>

    <div class="success-card" data-submission-id={row.id} data-terminal={String(isTerminal)}>
      <div class="success-card__check" aria-hidden="true">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12 l5 5 l9-11" />
        </svg>
      </div>
      <span class="eyebrow"><Lang zh="投稿已入队" en="Queued" /></span>
      <h1 id="js-success-headline" style="font-family: var(--f-display); font-weight: 500; font-size: 40px; letter-spacing: -0.6px; margin: 12px 0 8px">
        <span class="lang-zh">{headlineCopy.zh}</span>
        <span class="lang-en">{headlineCopy.en}</span>
      </h1>
      <p id="js-success-sub" class="t-body-md text-body" style="max-width: 50ch; margin: 0 auto">
        <span class="lang-zh">{subCopy.zh}</span>
        <span class="lang-en">{subCopy.en}</span>
      </p>
      <div class="success-card__id" aria-label="Queue ID">
        <Lang zh="ID · " en="ID · " />{row.id}
      </div>
      <p id="js-success-cta" style="margin-top: 24px" hidden={!view.hasPick}>
        <a href={L(`/daily`)} class="btn btn-primary">
          <Lang zh="看今日日刊 →" en="See today’s daily →" />
        </a>
      </p>
    </div>

    <div class="progress-steps" style="max-width: 760px; margin-left: auto; margin-right: auto">
      {[
        { n: "01", zh: "入队",      en: "Queued",          note_zh: row.createdAt ? rel(row.createdAt) : "",     note_en: row.createdAt ? rel(row.createdAt) : "" },
        { n: "02", zh: "AI 加工中", en: "AI pass running", note_zh: "~30 秒",                                     note_en: "~30s" },
        { n: "03", zh: "人工审核", en: "Human review",     note_zh: "通常 ≤ 1 小时",                              note_en: "Usually ≤ 1 hr" },
        { n: "04", zh: "进当日日刊", en: "Today's daily",   note_zh: "通过即公开",                                  note_en: "Public on approval" },
      ].map((s, i) => {
        const idx = i + 1;
        const cls =
          row.status === "rejected"
            ? idx === 1 ? "is-done" : ""
            : idx < stepIndex ? "is-done"
            : idx === stepIndex ? "is-current"
            : "";
        return (
          <div class={`progress-steps__cell ${cls}`} data-step={idx}>
            <div class="n">{s.n}</div>
            <div class="name"><Lang zh={s.zh} en={s.en} /></div>
            <div class="note"><Lang zh={s.note_zh} en={s.note_en} /></div>
          </div>
        );
      })}
    </div>

    {!isTerminal && (
      <div id="js-success-track" style="max-width: 480px; margin: 48px auto 0">
        <div class="card card--canvas" style="padding: 24px">
          <span class="eyebrow"><Lang zh="想知道结果？" en="Track it?" /></span>
          <h3 style="font-family: var(--f-display); font-size: 22px; margin: 8px 0 12px">
            <Lang zh="留个邮箱，发了通知你" en="Email me when it ships" />
          </h3>
          <form data-subscribe-form>
            <input type="hidden" name="source" value="submit-success" />
            <div style="display: flex; gap: 6px">
              <input class="input" type="email" name="email" placeholder="you@example.com" aria-label="Email address" style="flex: 1; height: 44px" required />
              <button class="btn btn-primary" type="submit" style="padding: 0 16px">
                <span class="subscribe-card__cta-default">
                  <Lang zh="通知我" en="Notify me" />
                </span>
                <span class="subscribe-card__cta-done" aria-hidden="true">
                  <Lang zh="✓ 已订阅" en="✓ Subscribed" />
                </span>
              </button>
            </div>
            <p class="subscribe-card__status t-body-sm" role="status" aria-live="polite" style="margin: 8px 0 0"></p>
            <p class="t-body-sm text-muted-soft" style="margin: 8px 0 0">
              <Lang zh="只发这一封 · 不订阅周刊。" en="Single-use · no weekly signup." />
            </p>
          </form>
        </div>
      </div>
    )}

    <div style="text-align: center; margin-top: 48px">
      <a class="btn btn-secondary" href={L("/daily")}>
        <Lang zh="回到今日日刊" en="Back to today’s daily" />
      </a>
    </div>
  </div>

  <script is:inline>
    // Live status polling. Replaces the old full-page <meta refresh> so the
    // "notify me" email field isn't wiped every few seconds. Updates the
    // headline, sub-copy, progress strip, and pick CTA in place, then stops
    // once the submission reaches a terminal state.
    (function () {
      const root = document.querySelector(".success-card[data-submission-id]");
      if (!root || root.getAttribute("data-terminal") === "true") return;
      const id = root.getAttribute("data-submission-id");
      const headline = document.getElementById("js-success-headline");
      const sub = document.getElementById("js-success-sub");
      const cta = document.getElementById("js-success-cta");
      const track = document.getElementById("js-success-track");
      const cells = document.querySelectorAll(".progress-steps__cell");

      const setCopy = (el, zh, en) => {
        if (!el) return;
        const z = el.querySelector(".lang-zh");
        const e = el.querySelector(".lang-en");
        if (z) z.textContent = zh;
        if (e) e.textContent = en;
      };

      const apply = (v) => {
        if (v.headline) setCopy(headline, v.headline.zh, v.headline.en);
        if (v.sub) setCopy(sub, v.sub.zh, v.sub.en);
        cells.forEach((c, i) => {
          const idx = i + 1;
          c.classList.remove("is-done", "is-current");
          if (v.status === "rejected") {
            if (idx === 1) c.classList.add("is-done");
          } else if (idx < v.stepIndex) {
            c.classList.add("is-done");
          } else if (idx === v.stepIndex) {
            c.classList.add("is-current");
          }
        });
        if (cta) cta.hidden = !v.hasPick;
        if (v.isTerminal) {
          if (track) track.hidden = true;
          root.setAttribute("data-terminal", "true");
        }
      };

      let timer = null;
      const stop = () => { if (timer) { clearInterval(timer); timer = null; } };
      const poll = async () => {
        try {
          const res = await fetch("/api/submit/status?id=" + encodeURIComponent(id), {
            headers: { accept: "application/json" },
          });
          if (!res.ok) return; // transient (404 race / 5xx) — keep polling
          const v = await res.json();
          apply(v);
          if (v.isTerminal) stop();
        } catch (_) { /* network blip — keep polling */ }
      };

      timer = setInterval(poll, 6000);
      // Don't poll a hidden tab; resume (and fetch once) when it's visible again.
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) { stop(); return; }
        if (!timer && root.getAttribute("data-terminal") !== "true") {
          poll();
          timer = setInterval(poll, 6000);
        }
      });
    })();
  </script>
</Site>
