# Copy this file to `.dev.vars` and fill in real values for local dev.
# `.dev.vars` is gitignored. `.dev.vars.example` is committed as a template.
#
# Set OPENAI_API_KEY or DEEPSEEK_API_KEY (or both), then run `pnpm dev`.
# LLM_PROVIDER overrides auto-detect when both keys are present.

# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

# Turnstile / cookie signing — leave unset in dev (turnstile bypass auto-applies).
# TURNSTILE_SECRET=
# COOKIE_SIGNING_KEY=dev-key-please-change

# Transactional email (Resend). Leave RESEND_API_KEY unset in dev — confirmation
# and weekly emails are then logged to the console instead of actually sent.
# RESEND_API_KEY=re_...
# EMAIL_FROM=Glean 拾遗 <weekly@glean.smartcoder.ai>
# EMAIL_REPLY_TO=hello@glean.smartcoder.ai

# Admin allowlist. In DEV you can also send the `x-glean-admin-dev: 1` header
# to bypass auth entirely; ADMIN_EMAILS is only enforced when a real Access
# identity reaches the middleware.
# ADMIN_EMAILS=you@example.com,coworker@example.com
