name = "glean-llm"
main = "src/index.ts"
compatibility_date = "2026-04-01"
compatibility_flags = ["nodejs_compat"]
# The fetch handler (POST /process) is a DEV-ONLY entry point (Pages proxies
# to localhost). Never expose it on workers.dev in prod — it is unauthenticated
# and triggers real LLM/extract runs.
workers_dev = false

# Shares D1 + R2 with the extract worker (and the Pages app).
[[d1_databases]]
binding = "DB"
database_name = "glean"
database_id = "REPLACE_WITH_D1_ID"
migrations_dir = "../../migrations"

[[r2_buckets]]
binding = "RAW"
bucket_name = "glean-raw"

# Same KV namespace the Pages app reads, so cache busts from the daily
# auto-publish cron (and sections rebuilds) invalidate the live pages.
[[kv_namespaces]]
binding = "CACHE"
id = "REPLACE_WITH_CACHE_KV_ID"

[vars]
# Editorial timezone — the daily auto-publish cron assigns picks to "today" in
# this zone (06:00 Beijing must land on the new local day, not yesterday UTC).
SITE_TZ = "Asia/Shanghai"
# Default provider for the auto pipeline. ModelScope (DeepSeek-V4-Flash) has a
# free daily quota; runtime-switchable from /admin (app_settings.llm_provider).
LLM_PROVIDER = "modelscope"
# Cross-provider fallback: when the ModelScope call fails (429 / quota gone /
# 5xx / timeout) AND there's no explicit per-run override, retry once on
# DeepSeek V4-Pro. The "deepseek-" prefix routes this spec to the DeepSeek
# provider (baseUrl + DEEPSEEK_API_KEY), not just a model-name swap.
LLM_FALLBACK_MODEL = "deepseek-v4-pro"
# Wiki rebuild only: clustering the catalog needs a fast non-reasoning model.
# V4-Pro streams minutes of reasoning tokens and trips the wiki call timeout
# (every build before this var existed died with "The operation was aborted").
WIKI_MODEL = "modelscope:deepseek-ai/DeepSeek-V4-Flash"

# Cron triggers (all fire scheduled() in src/index.ts; it branches on cron):
#   */5 * * * *  reaper — sweep submissions/weeklies stranded past the 15-min
#                worker ceiling into 'failed' (else they show "running…" forever)
#   0 22 * * *   daily auto-publish — 06:00 Asia/Shanghai; publishes the oldest
#                3 'ready' submissions so the editor needn't do it each morning
[triggers]
crons = ["*/5 * * * *", "0 22 * * *"]

[[queues.consumers]]
queue = "glean-llm"
max_batch_size = 1            # one LLM call per message; no point batching
max_batch_timeout = 5
# concurrency=3: keep LLM throughput moving when one V4-Pro sections stream is
# slow or wedged, while still capping provider/token exposure to three calls.
max_concurrency = 3
# retries=0: any LLM failure (schema/truncation OR transient 429/5xx) is
# treated as terminal. Retrying a failed run almost always burns more
# DeepSeek budget for the same answer; the admin "Re-run V4-Pro" button is
# the explicit retry path. Keeps the event-log timeline clean too.
max_retries = 0
# visibility_timeout=900s: V4-Pro reasoning calls commonly run ~200s and can
# legitimately sit quiet while reasoning. Match the 15-minute Queue Consumer
# wall-time ceiling so a healthy long run is not redelivered underneath itself.
visibility_timeout_ms = 900000
dead_letter_queue = "glean-llm-dlq"

# Producer side of the same queue — used to enqueue a "phase=sections"
# message when admin clicks "重新生成 sections" from a Pages route. We can't
# call runSectionsPhase synchronously from Pages (30s SSR limit vs. ~2-4 min
# sections call), so the Pages route enqueues here and a fresh worker
# delivery does the work.
[[queues.producers]]
binding = "INGEST_LLM"
queue = "glean-llm"

[dev]
port = 8788

# Secrets to set with `wrangler secret put <NAME> -c workers/llm-consumer/wrangler.toml`:
#   MODELSCOPE_API_KEY   — default LLM (ms-...; DeepSeek-V4-Flash, free daily quota)
#   DEEPSEEK_API_KEY     — fallback provider (deepseek-v4-pro reasoning model)
#   OPENAI_API_KEY       — alternative, or for any OpenAI-compatible endpoint
#   LLM_PROVIDER         — optional, "modelscope" | "deepseek" | "openai"
#   LLM_MODEL            — optional, override default model for the env provider
#   LLM_BASE_URL         — optional, override OpenAI endpoint URL
#   LLM_FALLBACK_MODEL   — optional, provider/model spec to fall back to
#   LLM_SECTIONS_MODEL   — optional, model spec for the sections phase only;
#                          defaults to the provider's Flash (V4-Flash) model
